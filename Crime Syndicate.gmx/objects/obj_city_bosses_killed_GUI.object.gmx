            <string>alarm[0] = room_speed * 10
countDown = 10

if instance_exists(obj_city_bosses_battle_screen)
{
    obj_city_bosses_battle_screen.finisherMove = true
}

if global.earnedChampionJockey == false
{
    global.trophyName = "Champion Jockey";
    global.trophyGradeText = "Bronze";
    global.earnedChampionJockey = true
    global.trophyGrade = 1;
    global.trophiesEarned += 1;
    
    ini_open("profile14.ini")
    ini_write_real("Profile","Icon",1)
    ini_close()
    
    ini_open("savedata.ini")
    ini_write_real("Trophies", "earnedChampionJockey", global.earnedChampionJockey);
    ini_write_real("Trophies", "trophiesEarned", global.trophiesEarned);
    ini_close();
    
    show_debug_message("Champion Jockey | Trophy Given")
    
    if !instance_exists(obj_draw_trophy_notification)
    {
        instance_create(29,84,obj_draw_trophy_notification)
    }
}
