if global.currentCity == "NEW_YORK"
{
    if global.newYorkCityBossTierOneIsDefeated == true &amp;&amp; obj_city_bosses_tier_one_button.isCurrent == true
    {
        draw_set_color(c_black)
        draw_text_ext(660, 300, "The Player has defeated " + string(global.cityBossNameTierOne), 17, 500)
        draw_set_color(c_white)
        draw_text_ext(565, 461, "+" + string(global.currentNewYorkCityBossTierOneCash), 17, 500)
        draw_text_ext(547, 533, "+" + string(global.currentNewYorkCityBossTierOneXP), 17, 500)
        draw_set_color(c_black)
        draw_text_ext(660, 650, "Closing menu in: " + string(countDown) + " seconds", 17, 500)
    }

