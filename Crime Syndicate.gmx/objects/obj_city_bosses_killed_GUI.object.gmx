            <string>///Write City Boss Variables

if global.currentCity == "NEW_YORK"
{
    ini_open("savedata.ini")

    ini_write_real("citybosses","newYorkCityBossTierOneIsDefeated",global.newYorkCityBossTierOneIsDefeated) 
    ini_write_real("citybosses","newYorkCityBossTierOneInBattle",global.newYorkCityBossTierOneInBattle) 

    ini_write_real("citybosses","newYorkCityBossTierTwoIsDefeated",global.newYorkCityBossTierTwoIsDefeated) 
    ini_write_real("citybosses","newYorkCityBossTierTwoInBattle",global.newYorkCityBossTierTwoInBattle) 

    ini_write_real("citybosses","newYorkCityBossTierThreeIsDefeated",global.newYorkCityBossTierThreeIsDefeated) 
    ini_write_real("citybosses","newYorkCityBossTierThreeInBattle",global.newYorkCityBossTierThreeInBattle) 
    
    ini_close();
}

else if global.currentCity == "CHICAGO"
{
    ini_open("savedata.ini")

    ini_write_real("citybosses","chicagoCityBossTierOneIsDefeated",global.chicagoCityBossTierOneIsDefeated) 
    ini_write_real("citybosses","chicagoCityBossTierOneInBattle",global.chicagoCityBossTierOneInBattle) 

    ini_write_real("citybosses","chicagoCityBossTierTwoIsDefeated",global.chicagoCityBossTierTwoIsDefeated) 
