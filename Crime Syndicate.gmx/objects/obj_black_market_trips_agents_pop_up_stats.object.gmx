        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Slot 1, 2 and 10, 11
//Note all code should match for all slots except this one.
draw_self();
draw_set_font(ft_properties);
draw_set_color(c_white);

if obj_black_market_trips_agents_panel_gui.mouseEnterCurrentSlot == 1 &amp;&amp; obj_black_market_trips_agents_panel_gui.mouseEnterCurrentPage == 1
{
    //by default show this
    draw_text(x + 10,y,string("Slot Status: ") + string(global.slot1Status))
    draw_text(x + 10,y + 140,string("Agent Rating: ") + string(obj_black_market_trips_agents_panel_gui.slot1Rating))
    
    //if slot is empty then
    if global.slot1Status == "EMPTY"
    {
        draw_text(x + 10,y + 20,string("Agent Generate Cost: ") + "$" + string(scr_number_sep(global.slotPrice,",",3))) 
    }
    
    //if slot is purchased then
    if global.slot1Status != "EMPTY"
    {
        draw_text(x + 10,y + 40,string("Agent Rent Cost: ") + string(global.slot1AgentFee))
        draw_text(x + 10,y + 80,string("Agent Happiness: ") + string(global.slot1AgentHappy) + "%")
        draw_text(x + 10,y + 100,string("Agent Effiency: ") + string(global.slot1AgentEff) + "%")
        draw_text(x + 10,y + 120,string("Agent Loot Odds: ") + string(global.slot1AgentLootOdds) + "%")
        
        draw_text(x + 10,y + 200,string("Agent Level:"))
        draw_text(x + 275,y + 232,string(global.slot1AgentLevel))
        draw_healthbar(x + 20, y + 240, x + 270, y + 250, obj_black_market_trips_agents_panel_gui.slot1BarCurrent, c_black, c_teal, c_blue, 0, true, true)
    }    
}

//---

