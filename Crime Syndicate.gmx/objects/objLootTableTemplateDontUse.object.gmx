        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Make sure money gets displayed right
if (global.Copper &gt; 99) {
   global.Copper = 0;
   global.Silver += 1;
}

if (global.Silver &gt; 99) {
   global.Silver = 0;
   global.Gold += 1;
}
</string>
          </argument>
        </arguments>
      </action>
