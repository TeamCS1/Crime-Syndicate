    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Draw the loot gained from loot windows
scrDrawText(view_xview[0] + 5, view_yview[0] + view_hview[0] - 25,"Loot: " + string(global.Loot),c_black,fntGUI,1,fa_left);
scrDrawText(view_xview[0] + 105, view_yview[0] + view_hview[0] - 25,"Copper: " + string(global.Copper),c_black,fntGUI,1,fa_left);
scrDrawText(view_xview[0] + 205, view_yview[0] + view_hview[0] - 25,"Silver: " + string(global.Silver),c_black,fntGUI,1,fa_left);
scrDrawText(view_xview[0] + 305, view_yview[0] + view_hview[0] - 25,"Gold: " + string(global.Gold),c_black,fntGUI,1,fa_left);

// Instructions
if (instructions) {
   scrDrawText(view_xview[0] + 5,view_yview[0] + 5,"Press Space to open loot window.",c_black,fntGUI,1,fa_left);
}
</string>
          </argument>
        </arguments>
      </action>
