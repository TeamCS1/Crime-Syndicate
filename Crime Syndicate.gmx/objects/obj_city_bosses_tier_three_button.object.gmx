        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Write Tier 3 - Done
if global.currentCity == "NEW_YORK"
{
    if global.newYorkCityBossTierThreeInBattle == false &amp;&amp; global.newYorkCityBossTierThreeIsDefeated == false
    {
        //If not in battle and not defeated
        global.cityBossesDifficulty = "VETERAN"

        global.cityBossATK = 100
        global.cityBossDEF = 100
        global.cityBossAILevel = 30

        ini_open("savedata.ini")

        ini_write_real("citybosses", "newYorkCityBossTierThreeInBattle", global.newYorkCityBossTierThreeInBattle);

        ini_write_real("citybosses", "currentNewYorkCityBossBarTierThree", global.currentNewYorkCityBossBarTierThree);
        ini_write_real("citybosses", "currentNewYorkCityBossBarTierThreeMaximum", global.currentNewYorkCityBossBarTierThreeMaximum);
        ini_write_real("citybosses", "currentNewYorkCityBossBarTierThreeCount", global.currentNewYorkCityBossBarTierThreeCount);
        ini_write_real("citybosses", "currentNewYorkCityBossTierThreeXP", global.currentNewYorkCityBossTierThreeXP);
        ini_write_real("citybosses", "currentNewYorkCityBossTierThreeCash", global.currentNewYorkCityBossTierThreeCash);

        ini_close();
    }

    else if global.newYorkCityBossTierThreeInBattle == true &amp;&amp; global.newYorkCityBossTierThreeIsDefeated == false
    {
        //If in battle and not defeated!  Post-phThree option here.
    }
}

//---

else if global.currentCity == "CHICAGO"
{
    if global.chicagoCityBossTierThreeInBattle == false &amp;&amp; global.chicagoCityBossTierThreeIsDefeated == false
    {
