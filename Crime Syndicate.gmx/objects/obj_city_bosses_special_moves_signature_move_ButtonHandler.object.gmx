    <event eventtype="6" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Damage Output Code

randomize();

//Selects the difficulty
ranVarianceAI = 0;

if global.cityBossesDifficulty == "BEGINNER"
{
    ranVarianceAI = irandom_range(1,2)
}

else if global.cityBossesDifficulty == "INTERMEDIATE"
{
    ranVarianceAI = irandom_range(3,4)
}

else if global.cityBossesDifficulty == "VETERAN"
{
    ranVarianceAI = irandom_range(5,9)
}

ranVariancePlayer = irandom_range(8,20)

show_debug_message("City Bosses Difficulty for Signature Move.")
show_debug_message(global.cityBossesDifficulty)

//Crit chance check - 1 in 4 chance
critChance = choose(1,2,3,4)

if critChance == 1 || critChance == 2 || critChance == 3
{
    tierOneBossDamage = 0
    playerDamage = 0
    
    tierOneBossDamage = global.cityBossATK + global.cityBossAILevel - global.defenceProtection + ranVarianceAI
    
    if tierOneBossDamage &lt; 1
    {
        tierOneBossDamage = 1
    }
    show_debug_message("Boss:")
    show_debug_message(tierOneBossDamage)
    
    playerDamage = (global.attackDamage + global.currentPlayerLevel - global.cityBossDEF + ranVariancePlayer * 15) * global.cityBossesMult
    
    if playerDamage &lt; 1
    {
        playerDamage = 1
    }
    show_debug_message("Player:")
    show_debug_message(playerDamage)
}

else if critChance == 4
{
    tierOneBossDamage = 0
    playerDamage = 0
    
    tierOneBossDamage = global.cityBossATK + global.cityBossAILevel - global.defenceProtection + ranVarianceAI
    
    if tierOneBossDamage &lt; 1
    {
        tierOneBossDamage = 1
    }
    
    show_debug_message(" ")
    show_debug_message("Boss:")
    show_debug_message(tierOneBossDamage)
    
    playerDamage = (global.attackDamage + global.currentPlayerLevel - global.cityBossDEF + ranVariancePlayer * 15) * global.cityBossesMult
    
    if playerDamage &lt; 1
    {
        playerDamage = 1
    }
    
    playerDamage = playerDamage * 3
    
    show_debug_message("Player: Crit Attack!")
    show_debug_message(playerDamage)
}

show_debug_message(critChance)

if global.cityBossesDifficulty == "BEGINNER"
{
    instance_create(550,490,obj_city_bosses_QTEs_three)
    show_debug_message("QTE 3 Created")
}

else if global.cityBossesDifficulty == "INTERMEDIATE"
{
    instance_create(450,490,obj_city_bosses_QTEs_five)
    show_debug_message("QTE 5 Created")
}

else if global.cityBossesDifficulty == "VETERAN"
{
    instance_create(250,490,obj_city_bosses_QTEs_seven)
    show_debug_message("QTE 7 Created")
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
