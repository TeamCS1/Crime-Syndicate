<object>
  <spriteName>spr_createPersonalMedic</spriteName>
  <solid>0</solid>
  <visible>-1</visible>
  <depth>-11</depth>
  <persistent>0</persistent>
  <parentName>&lt;undefined&gt;</parentName>
  <maskName>&lt;undefined&gt;</maskName>
  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>x = window_get_width() / 2
y = window_get_height() / 2

healthConditionString = "Checking...";
healthConditionColour = c_black;
healthConditionCost = -1;

if !instance_exists(obj_createPersonalMedicHealTrigger)
{
    instance_create(x + 320,y + 172,obj_createPersonalMedicHealTrigger)
    scr_log_message("CREATE: obj_createPersonalMedicHealTrigger")
}

if !instance_exists(obj_createPersonalMedicCloseTrigger)
{
    instance_create(x + 436,y + 172,obj_createPersonalMedicCloseTrigger)
    scr_log_message("CREATE: obj_createPersonalMedicCloseTrigger")
}

alarm[0] = room_speed * 0.1;

</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="2" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Loop Check Every 1 Sec
checkPercent = -1;

checkPercent = global.healthCount / global.healthCountMax * 100  

if checkPercent &gt;= 0 &amp;&amp; checkPercent &lt;= 25
{
    healthConditionString = "Critical";
    healthConditionColour = c_red;
}

else if checkPercent &gt;= 26 &amp;&amp; checkPercent &lt;= 50
{
    healthConditionString = "Bad";
    healthConditionColour = c_orange;
}

else if checkPercent &gt;= 51 &amp;&amp; checkPercent &lt;= 74
{
    healthConditionString = "Good";
    healthConditionColour = c_green;
}

else if checkPercent &gt;= 75 &amp;&amp; checkPercent &lt;= 100
{
    healthConditionString = "Perfect";
    healthConditionColour = make_colour_rgb(218,165,32);
}

//100 is multiplier...
diff = global.healthCountMax - global.healthCount;
healthConditionCost = diff *  global.currentPlayerLevel * 101.3;

//prevent overflow
if diff &gt; 2147483600
{
    diff = 2147483600;
}

if healthConditionCost &lt; 0
{
    healthConditionCost = 0;
} 
alarm[0] = room_speed * 0.1;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>422</id>
        <kind>1</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>0</useapplyto>
        <exetype>0</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_self();
draw_set_halign(fa_left);
draw_set_valign(fa_top);
draw_set_font(ft_properties);
draw_set_color(c_black);
draw_text(x + 10,y + 5,"Personal Medic");

draw_text_ext(x + 100,y + 60,"Your character is in:",30,400);

draw_set_color(healthConditionColour);
draw_text(x + 320,y + 60, string(healthConditionString) + " Condition");

draw_set_color(c_black);
draw_text(x + 100,y + 120,"Heal to 100% Health for: $" + scr_number_sep(string(round(healthConditionCost)),",",3))
draw_set_color(c_black);
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>424</id>
        <kind>2</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>0</useapplyto>
        <exetype>0</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
      </action>
    </event>
