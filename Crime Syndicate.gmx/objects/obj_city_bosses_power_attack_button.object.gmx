            global.healthCount = global.healthCount - tierOneBossDamage / 2.0
            global.currentNewYorkCityBossBarMultiplierTierOne += 25
        }
    }

    else if global.londonCityBossTierTwoInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentLondonCityBossBarTierTwoCount != 1
        {
            global.currentLondonCityBossBarTierTwoCount -= playerDamage;
            global.staminaCount -= 5.0;
            global.healthCount = global.healthCount - tierOneBossDamage / 2.0
            global.currentNewYorkCityBossBarMultiplierTierOne += 25
        }
    }

    else if global.londonCityBossTierThreeInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentLondonCityBossBarTierThreeCount != 1
        {
            global.currentLondonCityBossBarTierThreeCount -= playerDamage;
            global.staminaCount -= 5.0;
            global.healthCount = global.healthCount - tierOneBossDamage / 2.0
            global.currentNewYorkCityBossBarMultiplierTierOne += 25
        }
    }
