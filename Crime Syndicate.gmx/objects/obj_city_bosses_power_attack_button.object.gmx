        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Damage Output Code
randomize();

//Selects the difficulty
ranVarianceAI = 0;

if global.currentCity == "NEW_YORK"
{
    if global.cityBossesDifficulty == "BEGINNER"
    {
        ranVarianceAI = irandom_range(1, 2)
        global.cityBossATK = 25;
        global.cityBossDEF = 25;
        global.cityBossAILevel = 10;
    }

    else if global.cityBossesDifficulty == "INTERMEDIATE"
    {
        ranVarianceAI = irandom_range(3, 4)
        global.cityBossATK = 45;
        global.cityBossDEF = 90;
        global.cityBossAILevel = 20;
    }

    else if global.cityBossesDifficulty == "VETERAN"
    {
        ranVarianceAI = irandom_range(5, 9)
        global.cityBossATK = 125;
        global.cityBossDEF = 125;
        global.cityBossAILevel = 30;
    }
}

if global.currentCity == "CHICAGO"
{
    if global.cityBossesDifficulty == "BEGINNER"
    {
        ranVarianceAI = irandom_range(1, 2)
        global.cityBossATK = 100;
        global.cityBossDEF = 100;
        global.cityBossAILevel = 40;
    }

    else if global.cityBossesDifficulty == "INTERMEDIATE"
    {
        ranVarianceAI = irandom_range(3, 4)
        global.cityBossATK = 150;
        global.cityBossDEF = 150;
        global.cityBossAILevel = 50;
    }

    else if global.cityBossesDifficulty == "VETERAN"
    {
        ranVarianceAI = irandom_range(5, 9)
        global.cityBossATK = 200;
        global.cityBossDEF = 200;
        global.cityBossAILevel = 60;
    }
}

if global.currentCity == "LONDON"
{
    if global.cityBossesDifficulty == "BEGINNER"
    {
        ranVarianceAI = irandom_range(1, 2)
        global.cityBossATK = 250;
        global.cityBossDEF = 250;
        global.cityBossAILevel = 70;
    }

    else if global.cityBossesDifficulty == "INTERMEDIATE"
    {
        ranVarianceAI = irandom_range(3, 4)
        global.cityBossATK = 300;
        global.cityBossDEF = 300;
        global.cityBossAILevel = 80;
    }

    else if global.cityBossesDifficulty == "VETERAN"
    {
        ranVarianceAI = irandom_range(5, 9)
        global.cityBossATK = 350;
        global.cityBossDEF = 350;
        global.cityBossAILevel = 90;
    }
}

if global.currentCity == "LAS_VEGAS"
{
    if global.cityBossesDifficulty == "BEGINNER"
    {
        ranVarianceAI = irandom_range(1, 2)
        global.cityBossATK = 400;
        global.cityBossDEF = 400;
        global.cityBossAILevel = 100;
    }

    else if global.cityBossesDifficulty == "INTERMEDIATE"
    {
        ranVarianceAI = irandom_range(3, 4)
        global.cityBossATK = 450;
        global.cityBossDEF = 450;
        global.cityBossAILevel = 110;
    }

    else if global.cityBossesDifficulty == "VETERAN"
    {
        ranVarianceAI = irandom_range(5, 9)
        global.cityBossATK = 500;
        global.cityBossDEF = 500;
        global.cityBossAILevel = 120;
    }
}

ranVariancePlayer = irandom_range(8, 20)

show_debug_message(global.cityBossesDifficulty)

//Crit chance check - 1 in 4 chance
critChance = choose(1, 2, 3, 4)

if critChance == 1 || critChance == 2 || critChance == 3
{
    tierOneBossDamage = 0
    playerDamage = 0

    tierOneBossDamage = global.cityBossATK + global.cityBossAILevel - global.defenceProtection + ranVarianceAI

    if tierOneBossDamage &lt; 1
    {
        tierOneBossDamage = 1
    }
    show_debug_message("Boss:")
    show_debug_message(tierOneBossDamage)

    playerDamage = (global.attackDamage + global.currentPlayerLevel - global.cityBossDEF + ranVariancePlayer * 5)

    if playerDamage &lt; 1
    {
        playerDamage = 1
    }
    show_debug_message("Player:")
    show_debug_message(playerDamage)
}

else if critChance == 4
{
    tierOneBossDamage = 0
    playerDamage = 0

    tierOneBossDamage = global.cityBossATK + global.cityBossAILevel - global.defenceProtection + ranVarianceAI

    if tierOneBossDamage &lt; 1
    {
        tierOneBossDamage = 1
    }

    show_debug_message(" ")
    show_debug_message("Boss:")
    show_debug_message(tierOneBossDamage)

    playerDamage = (global.attackDamage + global.currentPlayerLevel - global.cityBossDEF + ranVariancePlayer * 5)

    if playerDamage &lt; 1
    {
        playerDamage = 1
    }

    playerDamage = playerDamage * 3

    show_debug_message("Player: Crit Attack!")
    show_debug_message(playerDamage)
}

show_debug_message(critChance)

//Attack Phase 

//New York
if global.currentCity == "NEW_YORK"
{
    if global.newYorkCityBossTierOneInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentNewYorkCityBossBarTierOneCount != 1
        {
            global.currentNewYorkCityBossBarTierOneCount -= playerDamage;
            global.staminaCount -= 5.0;
            global.healthCount = global.healthCount - tierOneBossDamage / 2.0
            global.currentNewYorkCityBossBarMultiplierTierOne += 25
        }
    }

    else if global.newYorkCityBossTierTwoInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentNewYorkCityBossBarTierTwoCount != 1
        {
            global.currentNewYorkCityBossBarTierTwoCount -= playerDamage;
            global.staminaCount -= 5.0;
            global.healthCount = global.healthCount - tierOneBossDamage / 2.0
            global.currentNewYorkCityBossBarMultiplierTierOne += 25
        }
    }

    else if global.newYorkCityBossTierThreeInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentNewYorkCityBossBarTierThreeCount != 1
        {
            global.currentNewYorkCityBossBarTierThreeCount -= playerDamage;
            global.staminaCount -= 5.0;
            global.healthCount = global.healthCount - tierOneBossDamage / 2.0
            global.currentNewYorkCityBossBarMultiplierTierOne += 25
        }
    }
}

//Chicago
if global.currentCity == "CHICAGO"
{
    if global.chicagoCityBossTierOneInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentChicagoCityBossBarTierOneCount != 1
        {
            global.currentChicagoCityBossBarTierOneCount -= playerDamage;
            global.staminaCount -= 5.0;
