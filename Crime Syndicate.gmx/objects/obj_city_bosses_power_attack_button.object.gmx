//Las Vegas
if global.currentCity == "LAS_VEGAS"
{
    if global.lasVegasCityBossTierOneInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentLasVegasCityBossBarTierOneCount != 1
