        }
    }

    else if global.chicagoCityBossTierTwoInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentChicagoCityBossBarTierTwoCount != 1
        {
            global.currentChicagoCityBossBarTierTwoCount -= playerDamage;
            global.staminaCount -= 5.0;
            global.healthCount = global.healthCount - tierOneBossDamage / 2.0
            global.currentNewYorkCityBossBarMultiplierTierOne += 25
        }
    }

    else if global.chicagoCityBossTierThreeInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentChicagoCityBossBarTierThreeCount != 1
        {
            global.currentChicagoCityBossBarTierThreeCount -= playerDamage;
            global.staminaCount -= 5.0;
            global.healthCount = global.healthCount - tierOneBossDamage / 2.0
            global.currentNewYorkCityBossBarMultiplierTierOne += 25
        }
    }
}

//London
if global.currentCity == "LONDON"
{
    if global.londonCityBossTierOneInBattle == true
    {
        if global.staminaCount &gt;= 5.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.currentLondonCityBossBarTierOneCount != 1
        {
            global.currentLondonCityBossBarTierOneCount -= playerDamage;
