            <string>scr_OpenPhone();

image_speed = 0;
length = 320;
currentPage = 0;
horizText = 1610;
darkCol = make_colour_rgb(72,72,72)

x = 1047;
y = 910;

notifications = ds_list_create();
ds_list_add(notifications, "Clicking on an icon will warp you to that Minigame.");
ds_list_add(notifications, "Press [E] to upgrade your character!");
ds_list_add(notifications, "You can hide your phone using 'down.'");
ds_list_add(notifications, "You can change up which Agents are equipped.");
ds_list_add(notifications, "Press [ESC] to bring up the Pause Menu.");
ds_list_add(notifications, "Several new Trophies have been added, collect them all!");
ds_list_add(notifications, "Be prepared to fight hitman targets.");
ds_list_add(notifications, "Defeating harder hitmen yields better rewards.");
ds_list_add(notifications, "Hospital visits can be expensive, watch your health! &lt;25");
ds_list_add(notifications, "Click on the Status Bar to heal any lost health.");
ds_list_add(notifications, "New properties are now available to be purchased.");
ds_list_add(notifications, "Buy Blackmarket Properties to increase inventory space!");
ds_list_add(notifications, "View your Inventory in the Blackmarket Hub.");
ds_list_add(notifications, "Equip/Unequip Items in the Blackmarket Hub.");
ds_list_add(notifications, "Invest into high-end properties to increase your cash flow.");
ds_list_add(notifications, "Properties make money while you're out doing jobs.");
ds_list_add(notifications, "You can view your statistics from the Progression Tab.");
ds_list_add(notifications, "Defeat Tier 2 of a City Boss to unlock the next city!");
ds_list_add(notifications, "Save your game on Web using the Import/Export feature!");
ds_list_add(notifications, "Sometimes it's best to use less Transportation Slots to save Expenses.");
ds_list_add(notifications, "Character loadouts are coming soon!");

randomize();
ds_list_shuffle(notifications);
global.notificationsList = notifications[| irandom(ds_list_size(notifications)-1)];

myHour = date_get_hour(date_current_datetime());
myMinute = date_get_minute(date_current_datetime());
zeroNum = "";
day = "";

switch(current_weekday)
   {
        case 0: day = "Sun"; break;
        case 1: day = "Mon"; break;
        case 2: day = "Tue"; break;
        case 3: day = "Wed"; break;
        case 4: day = "Thu"; break;
        case 5: day = "Fri"; break;
        case 6: day = "Sat"; break;
   }

alarm[0] = room_speed * 0.1;
</string>
          </argument>
        </arguments>
      </action>
