        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Draws Phone Text
draw_self();
draw_set_halign(fa_left)
draw_set_valign(fa_top);
draw_set_font(ft_phone_date_and_time)
draw_set_color(c_white);
draw_text(1775,910, string(day) + " " + string(myHour) + ":" + string(zeroNum) + string(myMinute))

draw_set_color(c_orange);
draw_set_font(ft_phone_notifications)
draw_text_ext(1428,910,string(global.notificationsList),20,length)

draw_set_color(c_white);
draw_set_font(ft_phone_notifications);
draw_text(1050,910,string("Syndicate Operating System v5.0"))

if currentPage == 0
{
    
}

else if currentPage == -18
{
    //Draw Digital Store
    draw_set_font(ft_phone_headings)
    draw_set_color(c_black);
    draw_text_ext(horizText,495,string("Digital Store"),15,240)

    draw_set_font(ft_phone_body)
    draw_set_color(darkCol);
    draw_text_ext(horizText,516,string("Purchase Cosmetics, Themes, Ringtones and more!"),15,240)

    //Draw Hostile Takeover
    draw_set_font(ft_phone_headings)
    draw_set_color(c_black);
    draw_text_ext(horizText,560,string("Hostile Takeover"),15,240)

    draw_set_font(ft_phone_body)
    draw_set_color(darkCol);
    draw_text_ext(horizText,580,string("Bring your Clan Mobsters into a RTS Battle Mode."),15,240)

    //Draw Real Estate
    draw_set_font(ft_phone_headings)
    draw_set_color(c_black);
    draw_text_ext(horizText,630,string("Cabaret Glamour"),15,240)

    draw_set_font(ft_phone_body)
    draw_set_color(darkCol);
    draw_text_ext(horizText,650,string("Manage your own Cabaret Club in Japan!"),15,240)

    //Draw Hitmen Jobs
    draw_set_font(ft_phone_headings)
    draw_set_color(c_black);
    draw_text_ext(horizText,690,string("Dealing Drugs"),15,240)

    draw_set_font(ft_phone_body)
    draw_set_color(darkCol);
    draw_text_ext(horizText,710,string("You go back on the streets to uncover a murder plot."),15,240)

    //World Domination World
    draw_set_font(ft_phone_headings)
    draw_set_color(c_black);
    draw_text_ext(horizText,750,string("World Domination Mode"),15,240)

    draw_set_font(ft_phone_body)
    draw_set_color(darkCol);
    draw_text_ext(horizText,770,string("Purchase countries and develop infrastructure."),15,240)
}
