}

else if global.jobTwoBarRankLondon == 5
{
    ratingListOne = "A";
}

else if global.jobTwoBarRankLondon == 6
{
    ratingListOne = "S";
}

//page 2 section only

if global.jobSevenBarLondon &gt;= 100 &amp;&amp; global.jobSevenBarRankLondon != 6
{
