        if global.currentNewYorkCityBossBarTierOneCount &lt;= 1 &amp;&amp; global.staminaCount &gt;= 3.0 &amp;&amp; global.healthCount &gt; 25.0 &amp;&amp; global.newYorkCityBossTierOneIsDefeated == false
        {
            global.currentNewYorkCityBossBarTierOneCount = 0;
            global.staminaCount -= 3.0;
            global.cityBossesMult = 1;

            global.moneyCount += global.currentNewYorkCityBossTierOneCash
            global.currentXP += global.currentNewYorkCityBossTierOneXP
            global.skillPointsRemaining += 5

            cityBossIsDead = true;

            global.newYorkCityBossTierOneIsDefeated = true;
            global.newYorkCityBossTierOneInBattle = false;

            ini_open("savedata.ini")

            ini_write_real("citybosses", "newYorkCityBossTierOneIsDefeated", global.newYorkCityBossTierOneIsDefeated)
            ini_write_real("citybosses", "newYorkCityBossTierOneInBattle", global.newYorkCityBossTierOneInBattle)

            ini_close();
            
            instance_create(416,224,obj_city_bosses_killed_GUI)
