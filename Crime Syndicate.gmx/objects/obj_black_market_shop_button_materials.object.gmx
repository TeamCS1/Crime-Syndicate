            <kind>1</kind>
            <string>//if the current tab is not the shop menu
if obj_black_market_shop_gui_upper_piece.currentPage != 2
{
    with obj_black_market_slots
    {
        instance_destroy();
    }
    
    with obj_make_inventory
    {
        instance_destroy();
    }
    
    //Re-create the inventory with the correct page.
    obj_black_market_shop_gui_upper_piece.currentPage = 2;
    
    if !instance_exists(obj_make_inventory)
    {
        instance_create(x,y,obj_make_inventory)
    }
}

//highlights
obj_black_market_shop_button_shop.image_index = 2;
obj_black_market_shop_button_inventory.image_index = 2;
obj_black_market_shop_button_materials.image_index = 0;

//add in the subheadings for the materials section
if !instance_exists(obj_black_market_inventory_button_loot)
{
    instance_create(x,y,obj_black_market_inventory_button_loot);
}

if !instance_exists(obj_black_market_inventory_button_blueprints)
{
    instance_create(x,y,obj_black_market_inventory_button_blueprints);
}

//garbage collection - destroy dropdown as we don't need it on this page
