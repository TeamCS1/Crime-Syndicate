            <kind>1</kind>
            <string>if (showListWeapon)
{
    if (mouse_wheel_up())
    {
        lowerPos = max(lowerPos-1, 0);
        upperPos = lowerPos+10;
    }
    else
    if (mouse_wheel_down())
    {
        upperPos = min(upperPos+1, 99);
        lowerPos = upperPos-10;
    }
    
    if selectedValue == 23
    {
        selectedValue = 0
        selectedValue = list[pos];
