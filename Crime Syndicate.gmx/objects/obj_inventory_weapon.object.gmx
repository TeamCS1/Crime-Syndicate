        <arguments>
          <argument>
            <kind>1</kind>
            <string>if (showListWeapon)
{
    var x1 = 713;    //20
    var x2 = 925;   //changes how far the bar goes
   
    for (var i = 0; i &lt; 10; i++)
    {
        var pos = lowerPos + i;
        var y1 = 20 + i * 20;
        var y2 = y1+19;     //19
        draw_rectangle(710, 165, 925, 1050, 1);
       
        var entry = list[pos];
        draw_text(x1, + y2 + 128, string(entry));  //change y position
       
        if (point_in_rectangle(mouse_x, mouse_y, x1, y1, x2, y2))
        {   
            draw_rectangle(x1+20, y1+20, x2-20, y2-20, 1);
            if (mouse_check_button_pressed(mb_left))
            {
                //showListWeapon = false;
                selectedValue = list[pos];
            }
        }
    }
}

draw_text(140, 20, "selected: " + string(selectedValue));
</string>
