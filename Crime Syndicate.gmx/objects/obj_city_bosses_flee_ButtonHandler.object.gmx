        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Flee Script
onClickFlee = true;

if onClickFlee == true
{
    if global.moneyCount &gt;= fleeFee || global.moneyCountMillion &gt; 0
    {
        //paying with millions
        if global.moneyCount &lt; fleeFee
        {
            global.moneyCountMillion -= 1;
            global.moneyCount += 1000000;
            global.moneyCount -= fleeFee

            scr_cityBossesMenuCleanup();
        }

        //paying without limit break
        else if global.moneyCount &gt;= fleeFee
        {
            global.moneyCount -= fleeFee
            scr_cityBossesMenuCleanup();
        }

        show_debug_message("OUTPUT: Flee Price Paid.")
        
        //Give Trophy Script
        if global.earnedFightOrFlight == false
        {
        global.trophyName = "Fight or Flight";
        global.trophyGradeText = "Bronze";
        global.earnedFightOrFlight = true
        global.trophyGrade = 1;
        global.trophiesEarned += 1;
    
        ini_open("profile15.ini")
        ini_write_real("Profile","Icon",1)
        ini_close()
    
        ini_open("savedata.ini")
        ini_write_real("Trophies", "earnedFightOrFlight", global.earnedFightOrFlight);
        ini_write_real("Trophies", "trophiesEarned", global.trophiesEarned);
        ini_close();
    
        show_debug_message("Fight or Flight | Trophy Given")
    
        if !instance_exists(obj_draw_trophy_notification)
        {
            instance_create(29,84,obj_draw_trophy_notification)
        }
        }
        
        //NEW YORK
        
        if global.currentCity == "NEW_YORK"
        {
            if global.newYorkCityBossTierOneInBattle == true
            {
                global.newYorkCityBossTierOneInBattle = false;
                global.newYorkCityBossTierOneIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "newYorkCityBossTierOneInBattle", global.newYorkCityBossTierOneInBattle)
                ini_write_real("citybosses", "newYorkCityBossTierOneIsDefeated", global.newYorkCityBossTierOneIsDefeated)

                ini_close();
            }

            else if global.newYorkCityBossTierTwoInBattle == true
            {
                global.newYorkCityBossTierTwoInBattle = false;
                global.newYorkCityBossTierTwoIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "newYorkCityBossTierTwoInBattle", global.newYorkCityBossTierTwoInBattle)
                ini_write_real("citybosses", "newYorkCityBossTierTwoIsDefeated", global.newYorkCityBossTierTwoIsDefeated)

                ini_close();
            }

            else if global.newYorkCityBossTierThreeInBattle == true
            {
                global.newYorkCityBossTierThreeInBattle = false;
                global.newYorkCityBossTierThreeIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "newYorkCityBossTierThreeInBattle", global.newYorkCityBossTierThreeInBattle)
                ini_write_real("citybosses", "newYorkCityBossTierThreeIsDefeated", global.newYorkCityBossTierThreeIsDefeated)

                ini_close();
            }

        }
        
        //--- CHICAGO
        
        if global.currentCity == "CHICAGO"
        {

            if global.chicagoCityBossTierOneInBattle == true
            {
                global.chicagoCityBossTierOneInBattle = false;
                global.chicagoCityBossTierOneIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "chicagoCityBossTierOneInBattle", global.chicagoCityBossTierOneInBattle)
                ini_write_real("citybosses", "chicagoCityBossTierOneIsDefeated", global.chicagoCityBossTierOneIsDefeated)

                ini_close();
            }

            else if global.chicagoCityBossTierTwoInBattle == true
            {
                global.chicagoCityBossTierTwoInBattle = false;
                global.chicagoCityBossTierTwoIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "chicagoCityBossTierTwoInBattle", global.chicagoCityBossTierTwoInBattle)
                ini_write_real("citybosses", "chicagoCityBossTierTwoIsDefeated", global.chicagoCityBossTierTwoIsDefeated)

                ini_close();
            }

            else if global.chicagoCityBossTierThreeInBattle == true
            {
                global.chicagoCityBossTierThreeInBattle = false;
                global.chicagoCityBossTierThreeIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "chicagoCityBossTierThreeInBattle", global.chicagoCityBossTierThreeInBattle)
                ini_write_real("citybosses", "chicagoCityBossTierThreeIsDefeated", global.chicagoCityBossTierThreeIsDefeated)

                ini_close();
            }

        } 
        
        //--- LONDON
        
        if global.currentCity == "LONDON"
        {

            if global.londonCityBossTierOneInBattle == true
            {
                global.londonCityBossTierOneInBattle = false;
                global.londonCityBossTierOneIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "londonCityBossTierOneInBattle", global.londonCityBossTierOneInBattle)
                ini_write_real("citybosses", "londonCityBossTierOneIsDefeated", global.londonCityBossTierOneIsDefeated)

                ini_close();
            }

            else if global.londonCityBossTierTwoInBattle == true
            {
                global.londonCityBossTierTwoInBattle = false;
                global.londonCityBossTierTwoIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "londonCityBossTierTwoInBattle", global.londonCityBossTierTwoInBattle)
                ini_write_real("citybosses", "londonCityBossTierTwoIsDefeated", global.londonCityBossTierTwoIsDefeated)

                ini_close();
            }

            else if global.londonCityBossTierThreeInBattle == true
            {
                global.londonCityBossTierThreeInBattle = false;
                global.londonCityBossTierThreeIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "londonCityBossTierThreeInBattle", global.londonCityBossTierThreeInBattle)
                ini_write_real("citybosses", "londonCityBossTierThreeIsDefeated", global.londonCityBossTierThreeIsDefeated)

                ini_close();
            }

        }
        
        //--- LAS VEGAS
        if global.currentCity == "LAS_VEGAS"
        {

            if global.lasVegasCityBossTierOneInBattle == true
            {
                global.lasVegasCityBossTierOneInBattle = false;
                global.lasVegasCityBossTierOneIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "lasVegasCityBossTierOneInBattle", global.lasVegasCityBossTierOneInBattle)
                ini_write_real("citybosses", "lasVegasCityBossTierOneIsDefeated", global.lasVegasCityBossTierOneIsDefeated)

                ini_close();
            }

            else if global.lasVegasCityBossTierTwoInBattle == true
            {
                global.lasVegasCityBossTierTwoInBattle = false;
                global.lasVegasCityBossTierTwoIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "lasVegasCityBossTierTwoInBattle", global.lasVegasCityBossTierTwoInBattle)
                ini_write_real("citybosses", "lasVegasCityBossTierTwoIsDefeated", global.lasVegasCityBossTierTwoIsDefeated)

                ini_close();
            }

            else if global.lasVegasCityBossTierThreeInBattle == true
            {
                global.lasVegasCityBossTierThreeInBattle = false;
                global.lasVegasCityBossTierThreeIsDefeated = false;

                ini_open("savedata.ini")

                ini_write_real("citybosses", "lasVegasCityBossTierThreeInBattle", global.lasVegasCityBossTierThreeInBattle)
                ini_write_real("citybosses", "lasVegasCityBossTierThreeIsDefeated", global.lasVegasCityBossTierThreeIsDefeated)

                ini_close();
            }

        } 
    }

    else
    {
        show_message("Insufficient Funds.");
    }
}
</string>
          </argument>
        </arguments>
      </action>
