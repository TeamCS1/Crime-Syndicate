            <string>if global.newYorkPropertySelection == "Uninspiring Garage" 
&amp;&amp; global.moneyCount &gt;= (5000 * 1)   //User has Normal HUD Active
{
    global.propertiesUninspiringGarageQuantityOwned += 1;
    global.moneyCount -= (5000 * 1);
}

else if global.newYorkPropertySelection == "Uninspiring Garage" 
&amp;&amp; global.moneyCountMillion &gt;= 1    //Falls into million money parameters, if there is any.
{
    global.moneyCount += 1000000
    global.moneyCountMillion -= 1;
    
    global.propertiesUninspiringGarageQuantityOwned += 1
    global.moneyCount -= (5000 * 1);
}

else if global.newYorkPropertySelection == "Uninspiring Garage" 
&amp;&amp; global.moneyCountBillion &gt;= 1    //Falls into billion money parameters, if there is any.
{
    global.moneyCountMillion += 1000
    global.moneyCountBillion -= 1;
    
    global.propertiesUninspiringGarageQuantityOwned += 1
    global.moneyCount -= (5000 * 1);
}

