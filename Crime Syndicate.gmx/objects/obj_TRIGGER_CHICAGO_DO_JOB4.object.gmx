            <string>if global.chicagoOnJob == "list1" &amp;&amp; global.currentPlayerLevel &gt;= 28
{
    if global.staminaCount &gt;= 20 &amp;&amp; !instance_exists(objLootWindow)
    {
        global.moneyCount += 350000;
        global.currentXP += 38
        global.staminaCount -= 20
        
        //If the bar is less than or equal to full and the rank is not S, give completion
        if global.jobFourBarChicago &lt; 100 &amp;&amp; global.jobFourBarRankChicago &lt; 6
        {
            global.chicagoCompletion += 0.025
        }
        
        //Gives the final amount when maxed out fully.
        if global.jobFourBarChicago == 100 &amp;&amp; global.jobFourBarRankChicago == 6
        {
            global.chicagoCompletion += 2.5
        }
        
        global.jobFourBarChicago += 2
        global.jobsCompleted += 1;
        scr_JobPanelJobLootChances();
    }
}

if global.chicagoOnJob == "list2" &amp;&amp; global.currentPlayerLevel &gt;= 38
{
