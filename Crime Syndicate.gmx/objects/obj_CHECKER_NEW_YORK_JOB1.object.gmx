            <kind>1</kind>
            <string>if global.newYorkOnJob == "list1" &amp;&amp; global.currentPlayerLevel &gt;= 0
{
    if global.staminaCount &gt;= 1 &amp;&amp; !instance_exists(objLootWindow)
    {
        //If the bar is less than or equal to full and the rank is not S, give completion
        if global.jobOneBarNewYork &lt; 100 &amp;&amp; global.jobOneBarRankNewYork &lt; 6
        {
            global.newYorkCompletion += 0.025;
        }
        
        //Gives the final amount when maxed out fully.
        if global.jobOneBarNewYork == 100 &amp;&amp; global.jobOneBarRankNewYork == 6
        {
            global.newYorkCompletion += 2.5;
        }
        scr_JobPanelDoJob(200,1,1,1);
        global.jobOneBarNewYork += 2;
        scr_JobPanelJobLootChances();
    }
}

if global.newYorkOnJob == "list2" &amp;&amp; global.currentPlayerLevel &gt;= 10
{
    if global.staminaCount &gt;= 16 &amp;&amp; !instance_exists(objLootWindow)
    {
        
        //If the bar is less than or equal to full and the rank is not S, give completion
        if global.jobSixBarNewYork &lt; 100 &amp;&amp; global.jobSixBarRankNewYork &lt; 6
        {
            global.newYorkCompletion += 0.025;
        }
        
        //Gives the final amount when maxed out fully.
        if global.jobSixBarNewYork == 100 &amp;&amp; global.jobSixBarRankNewYork == 6
        {
            global.newYorkCompletion += 2.5;
        }
        scr_JobPanelDoJob(35000,24,16,1);
        global.jobSixBarNewYork += 2;
        scr_JobPanelJobLootChances();
    }
}
</string>
