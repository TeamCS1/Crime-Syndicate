        <arguments>
          <argument>
            <kind>1</kind>
            <string>//purchase if money is 1m and have no other money
if global.tripsSlot3 == "Locked" &amp;&amp; global.moneyCountMillion &gt; 1
{
    global.moneyCountMillion -= 1;
    global.moneyCount += 500000

    global.tripsSlot3 = "Owned";
    global.slot3Name = "Slot 3"
    image_index = 1;
}

else if global.tripsSlot3 == "Locked" &amp;&amp; global.moneyCount &gt; 500000
{
    global.moneyCount -= 500000
    global.tripsSlot3 = "Owned";
    global.slot3Name = "Slot 3"
    image_index = 1;
}

else if global.tripsSlot3 == "Equipped"
{
    global.tripsSlot3 = "Owned";
    image_index = 1;
}

else if global.tripsSlot3 == "Owned" 
{
    global.tripsSlot3 = "Equipped";
    image_index = 2;    
}
</string>
