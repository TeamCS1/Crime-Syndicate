      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///HUD
if room == rm_blackmarket_shop_menu_main
{
    draw_sprite_ext(spr_cash_health_HUD,image_index,1493,7,1,1,0,c_white,1);
}

//CASH
draw_set_font(ft_money);
draw_set_color(c_green);
draw_set_valign(fa_top);
draw_set_halign(fa_left);

// Only draw outside of certain rooms
if room_get_name(room) != "rm_options_main" &amp;&amp; room_get_name(room) != "rm_progression"
{
    if global.moneyCountBillion &lt;= 0
    {
        draw_text(x + 20, 64, "CASH    $" + string(scr_number_sep(global.moneyCount, ",", 3)) + string(global.moneySuffix));
    }
    else // Billion money active
    {
        // Format million part as 3-digit decimal (like 001, 045, 999)
        var millionText = string(global.moneyCountMillion);
        if global.moneyCountMillion &lt; 10
        {
            millionText = "00" + millionText;
        }
        else if global.moneyCountMillion &lt; 100
        {
            millionText = "0" + millionText;
        }

        draw_text(x + 20, 64, "CASH    $" + string(global.moneyCountBillion) + "." + millionText + " " + string(global.moneySuffix));
    }
}

//HEALTH
//no need to change font, uses money font
draw_set_color(c_red);

if room_get_name(room) != "rm_options_main" || room_get_name(room) != "rm_progression"
{
    draw_text(x + 20,15, "HEALTH    " + string(round(global.healthCount)) + "/" + string(global.healthCountMax));
}

//STAMINA
draw_set_color(make_colour_rgb(255, 128, 0));
//no need to change font, uses money font

if room_get_name(room) != "rm_options_main" || room_get_name(room) != "rm_progression"
{
    draw_set_valign(fa_left);
    draw_text_ext(x + 20,111, "STAMINA    " + string(global.staminaCount) + "/" + string(global.staminaCountMax),25,450);
}

//XP BAR
draw_set_font(ft_xp_counter)

if room_get_name(room) != "rm_options_main" || room_get_name(room) != "rm_progression"
{
    if room == rm_hitmen_menu_template 
    {
        draw_set_colour(c_black);
        draw_text(x + 20, 207, "Lv. " + string(global.currentPlayerLevel) + "  " + "Remaining  " + string(global.currentXP) + "/" + string(global.currentXPNeededToLevelUp) + "XP")
    }

    else if room == rm_properties 
    {
        draw_set_colour(c_black);
        draw_text(x + 20, 207, "Lv. " + string(global.currentPlayerLevel) + "  " + "Remaining  " + string(global.currentXP) + "/" + string(global.currentXPNeededToLevelUp) + "XP")
    }

    else if room == rm_property_listings 
    {
        draw_set_colour(c_black);
        draw_text(x + 20, 207, "Lv. " + string(global.currentPlayerLevel) + "  " + "Remaining  " + string(global.currentXP) + "/" + string(global.currentXPNeededToLevelUp) + "XP")
    }
    
    else if room == rm_blackmarket_home 
    {
        draw_set_colour(c_black);
        draw_text(x + 20, 207, "Lv. " + string(global.currentPlayerLevel) + "  " + "Remaining  " + string(global.currentXP) + "/" + string(global.currentXPNeededToLevelUp) + "XP")
    }
    
    else if room == rm_blackmarket_trips_menu
    {
        draw_set_colour(c_black);
        draw_text(x + 20, 207, "Lv. " + string(global.currentPlayerLevel) + "  " + "Remaining  " + string(global.currentXP) + "/" + string(global.currentXPNeededToLevelUp) + "XP")
    }
    
    else if room == rm_blackmarket_shop_menu_main
    {
        draw_set_colour(c_black);
        draw_text(x + 20, 207, "Lv. " + string(global.currentPlayerLevel) + "  " + "Remaining  " + string(global.currentXP) + "/" + string(global.currentXPNeededToLevelUp) + "XP")
    }

    else
    {
        draw_set_colour(c_white); 
        draw_text(x + 20, 207, "Lv. " + string(global.currentPlayerLevel) + "  " + "Remaining  " + string(global.currentXP) + "/" + string(global.currentXPNeededToLevelUp) + "XP")
    }
}

//draw_text(x,y,string(depth))
</string>
