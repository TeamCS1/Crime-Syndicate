        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_self();


if currentPage == 0 &amp;&amp; toDraw == true
{

draw_rectangle_colour(1070, 300 , 1780, 1000 ,c_black,c_black,c_black,c_red,false)

draw_set_font(ft_city_bosses_heading)
draw_set_color(c_orange)
draw_text_ext(1150,300,"City Bosses Battle System Help",25,1000)


draw_set_font(ft_city_bosses_body)
draw_set_color(c_white)
draw_text_ext(1070,340,"Banking - Doing Damage to the City Boss by using any of the Simple Attacks increases this bar, once the bar is full, the multiplier increases by one. This represents your multiplier times by your Attack Damage.  
                       #Special Moves - The Signature Move uses the Bank Multiplier to carry out a devastating attack to the City Boss. This is a very powerful move, so time it right while the City Boss has a lot of Health. This initiates a Quick Time Event (QTE).
                       #Special Moves - The Final Blow Move can only be used while the City Boss is at the brink of death. This move automatically locks out the other options. This initiates a Quick Time Event (QTE).
                       #Quick Time Events - These are carried out by performing a Special Move while it's active. QTE's are difficulty dependant on the City Boss's difficulty. In order to beat a QTE, you must beat the Target Zone Score by holding the correct key in the 'Zone'.
                       #Target Zone Score - These are shown when a QTE is active, as you hold points in a Zone, these are accumulated together to form your total score. 
                       ##Page 1 / 2 | Change Page - Arrow Keys",25,700)
}

else if currentPage == 1 &amp;&amp; toDraw == true
{

draw_rectangle_colour(1070, 300 , 1780, 1000 ,c_black,c_black,c_black,c_red,false)

draw_set_font(ft_city_bosses_heading)
draw_set_color(c_orange)
draw_text_ext(1150,300,"City Bosses Battle System Help",25,1000)


draw_set_font(ft_city_bosses_body)
draw_set_color(c_white)
draw_text_ext(1070,340,"Battle Options - The Fleeing mechanic allows you to leave your current City Boss Battle for a fee, if you're not up for it, remember that the fee is higher if your on a higher difficulty! This option creates a fresh instance of a new City Boss.
                       #Battle Options - The Postphone mechanic allows you to suspend your current City Boss Battle, ultimately allowing you to come back to the Battle at anytime. This is useful if you wish to visit other parts of the game such as Properties Management. Though be wary of the Battle Timer reaching 0, as that would be a automatic loss.
                       #Battle Stats - These show various key information about the current City Boss Battle for example, the total amount of QTE's performed.
                       ###########Page 2 / 2 | Change Page - Arrow Keys",25,700)
}

</string>
          </argument>
        </arguments>
      </action>
