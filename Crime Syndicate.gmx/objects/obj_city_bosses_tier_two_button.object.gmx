          <argument>
            <kind>1</kind>
            <string>///Creates City Bosses Menu - New York 

//If starting battle
if global.newYorkCityBossTierTwoInBattle == false &amp;&amp; global.newYorkCityBossTierTwoIsDefeated == false &amp;&amp; global.currentCity == "NEW_YORK" &amp;&amp; global.currentPlayerLevel &gt;= 20 
{
    //Creates City Bosses Battle Menu
    if !instance_exists(obj_city_bosses_battle_screen)
    {
        instance_create(17, 22, obj_city_bosses_battle_screen)
    }
    
    show_debug_message("CREATE: obj_city_bosses_battle_screen")

    //Destroys City Bosses Menu
    with obj_city_bosses_menu
    {
        instance_destroy();
        show_debug_message("DESTROY: obj_city_bosses_menu")
    }

    //Destroys any Hover Popup Boxes
    if instance_exists(obj_city_bosses_pop_up_box)
    {
        with obj_city_bosses_pop_up_box
        {
            instance_destroy();
            show_debug_message("DESTROY: obj_city_bosses_pop_up_box")
        }
    }

    //Checks what City you're in and destroys that City active job instances
    if global.currentCity == "NEW_YORK"
    {
        if instance_exists(obj_mug_a_low_life_bar1)
        {
            with obj_mug_a_low_life_bar1
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_steal_a_car_bar2)
        {
            with obj_steal_a_car_bar2
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_deal_some_bad_drugs_bar3)
        {
            with obj_deal_some_bad_drugs_bar3
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_rob_j_store_bar4)
        {
            with obj_rob_j_store_bar4
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_rob_small_bank_bar5)
        {
            with obj_rob_small_bank_bar5
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_CHECKER_NEW_YORK_JOB1)
        {
            with obj_CHECKER_NEW_YORK_JOB1
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_CHECKER_NEW_YORK_JOB2)
        {
            with obj_CHECKER_NEW_YORK_JOB2
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_CHECKER_NEW_YORK_JOB3)
        {
            with obj_CHECKER_NEW_YORK_JOB3
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_CHECKER_NEW_YORK_JOB4)
        {
            with obj_CHECKER_NEW_YORK_JOB4
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_CHECKER_NEW_YORK_JOB5)
        {
            with obj_CHECKER_NEW_YORK_JOB5
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_worldMapNewYorkControl)
        {
            with obj_worldMapNewYorkControl
            {
                instance_destroy();
            }
        }
    }

    //Removes the Button after transition to Battle Screen
    if instance_exists(obj_city_bosses_tier_one_button)
    {
        with obj_city_bosses_tier_one_button
        {
            x -= 1000
        }
    }
    
    //Removes the Button after transition to Battle Screen
    if instance_exists(obj_city_bosses_tier_two_button)
    {
        with obj_city_bosses_tier_two_button
        {
            x -= 1000
        }
    }
    
    //Removes the Button after transition to Battle Screen
    if instance_exists(obj_city_bosses_tier_three_button)
    {
        with obj_city_bosses_tier_three_button
        {
            x -= 1000
        }
    }
    
    global.newYorkCityBossTierTwoInBattle = true;
}
