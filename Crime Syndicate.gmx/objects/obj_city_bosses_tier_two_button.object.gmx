        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Write Tier 2 - Done
if global.currentCity == "NEW_YORK"
{
    if global.newYorkCityBossTierTwoInBattle == false &amp;&amp; global.newYorkCityBossTierTwoIsDefeated == false
    {
        //If not in battle and not defeated
        global.cityBossesDifficulty = "INTERMEDIATE"

        global.cityBossATK = 45
        global.cityBossDEF = 90
        global.cityBossAILevel = 20

        ini_open("savedata.ini")

        ini_write_real("citybosses", "newYorkCityBossTierTwoInBattle", global.newYorkCityBossTierTwoInBattle);

        ini_write_real("citybosses", "currentNewYorkCityBossBarTierTwo", global.currentNewYorkCityBossBarTierTwo);
        ini_write_real("citybosses", "currentNewYorkCityBossBarTierTwoMaximum", global.currentNewYorkCityBossBarTierTwoMaximum);
        ini_write_real("citybosses", "currentNewYorkCityBossBarTierTwoCount", global.currentNewYorkCityBossBarTierTwoCount);
        ini_write_real("citybosses", "currentNewYorkCityBossTierTwoXP", global.currentNewYorkCityBossTierTwoXP);
        ini_write_real("citybosses", "currentNewYorkCityBossTierTwoCash", global.currentNewYorkCityBossTierTwoCash);

        ini_close();
    }

    else if global.newYorkCityBossTierTwoInBattle == true &amp;&amp; global.newYorkCityBossTierTwoIsDefeated == false
    {
        //If in battle and not defeated!  Post-phTwo option here.
    }
}

