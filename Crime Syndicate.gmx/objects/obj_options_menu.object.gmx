{
    draw_set_font(ft_options);
    draw_set_color(c_black);
    draw_text(1621,290,string(window_get_width()) + "x" + string(window_get_height()));
    draw_text(1621,345,string(global.resolutionSizeText));
    draw_text(1621,690,string("English"));
    draw_text(1621,740,string("Light Theme"));
    draw_text(1621,790,string(global.fpsMode)+ "fps");
    
