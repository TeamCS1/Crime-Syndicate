      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Income Generator 

if room == rm_properties
{   
    draw_set_valign(fa_left);
    draw_set_font(ft_properties);
    draw_set_colour(c_white); 

    if global.totalPropertiesIncomeBillion == 0 //If its the normal money amount.
    {
        draw_text(1288,680, "+$" + string(scr_number_sep(global.totalPropertiesIncome,",",3)))
    }

    else if global.totalPropertiesIncomeBillion &gt; 0 //If the money is over the billion amount.

    {
        draw_text(1288,680, "+$" + string(global.totalPropertiesIncomeBillion) + "." + string(global.totalPropertiesIncomeMillion) + " " + string(global.totalPropertiesIncomeSuffix))
    }
    
    draw_set_colour(c_black); 
    draw_text(1288,745,"$" + string(scr_number_sep(global.currentHourRate,",",3)))
    draw_set_colour(c_red);
    draw_text(1288,820,"-$" + string(scr_number_sep(totalUpkeep,",",3)))
    draw_set_colour(c_black);
    draw_text(1288,890,"$" + string(scr_number_sep(global.currentHourRate - totalUpkeep,",",3)))
    //draw_text_ext(1350,630,"Current Rate Raw Values Added: " + string(scr_number_sep(currentRate,",",3)),20,400)
    //draw_text_ext(1350,660,"Current Seconds Rate: " + string(scr_number_sep(currentSecondsRate,",",3)),20,400)
    //draw_text_ext(1350,690,"current Minute Rate: " + string(scr_number_sep(currentMinuteRate,",",3)),20,400)
}








</string>
          </argument>
        </arguments>
      </action>
