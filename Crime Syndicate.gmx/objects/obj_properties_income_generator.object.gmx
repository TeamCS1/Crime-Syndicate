    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///resets the values before adding on!
global.currentHourRate = 0;
tempVar1 = 0
tempVar2 = 0
tempVar3 = 0
tempVar4 = 0
tempVar5 = 0
tempVar6 = 0
tempVar7 = 0
tempVar8 = 0
tempVar9 = 0
totalUpkeep = 0;
prop1 = 0;
prop2 = 0;
prop3 = 0;
prop4 = 0;
prop5 = 0;
prop6 = 0;
prop7 = 0;
prop8 = 0;
prop9 = 0;

//The following calculations work in game, furthermore values need to be modified
//using the decimal multiplier
if global.propertiesUninspiringGarageQuantityOwned &gt;= 1
{
    tempVar1 = (0.500 * global.propertiesUninspiringGarageQuantityOwned)
    global.totalPropertiesIncome += tempVar1
} //0.125

if global.propertiesArchaicDinerQuantityOwned &gt;= 1
{
    tempVar2 = (2.2 * global.propertiesArchaicDinerQuantityOwned)
    global.totalPropertiesIncome += tempVar2
}

if global.propertiesTaxiDepotQuantityOwned &gt;= 1
{
    tempVar3 = (3.2 * global.propertiesTaxiDepotQuantityOwned)
    global.totalPropertiesIncome += tempVar3
}

if global.propertiesChinaShopQuantityOwned &gt;= 1
{
    tempVar4 = (4.5 * global.propertiesChinaShopQuantityOwned)
    global.totalPropertiesIncome += tempVar4
}

if global.propertiesMiaNightClubQuantityOwned &gt;= 1
{
    tempVar5 = (8.0 * global.propertiesMiaNightClubQuantityOwned)
    global.totalPropertiesIncome += tempVar5
}

if global.propertiesKenjiCasinoQuantityOwned &gt;= 1
{
    tempVar6 = (10.0 * global.propertiesKenjiCasinoQuantityOwned)
    global.totalPropertiesIncome += tempVar6
}

if global.propertiesHighriseBuildingQuantityOwned &gt;= 1
{
    tempVar7 = (12.0 * global.propertiesHighriseBuildingQuantityOwned)
    global.totalPropertiesIncome += tempVar7
}

if global.propertiesGrandCabaretClubQuantityOwned &gt;= 1
{
    tempVar8 = (14.0 * global.propertiesGrandCabaretClubQuantityOwned)
    global.totalPropertiesIncome += tempVar8
}

if global.propertiesDecadePenthouseQuantityOwned &gt;= 1
{
    tempVar9 = (16.0 * global.propertiesDecadePenthouseQuantityOwned)
    global.totalPropertiesIncome += tempVar9
}

//Income Generator, Money Sorter
if global.totalPropertiesIncome &gt;= 2000000000
{
    global.totalPropertiesIncome = 0;
    global.totalPropertiesIncomeBillion += 2;
    global.totalPropertiesIncomeSuffix = "Billion";
}

if global.totalPropertiesIncomeBillion &gt; 0
{
    if global.totalPropertiesIncome &gt;= 1000000
    {
        global.totalPropertiesIncomeMillion += 1
        global.totalPropertiesIncome -= 1000000
    }

    else if global.totalPropertiesIncomeMillion &gt;= 1000
    {
        global.totalPropertiesIncomeBillion += 1;
        global.totalPropertiesIncomeMillion -= 1000;
    }
    
    else if global.totalPropertiesIncomeBillion &gt;= 9999
    {
        global.totalPropertiesIncomeBillion = 9999;
    }
}

//income rate calculation
currentRate = tempVar1 + tempVar2 + tempVar3 + tempVar4 + tempVar5 + tempVar6 + tempVar7 + tempVar8 + tempVar9
currentSecondsRate = currentRate * 1
currentMinuteRate = currentSecondsRate * 60
global.currentHourRate = currentMinuteRate * 60 //rate in 1 minute

//upkeep calculation
if global.propertiesUninspiringGarageQuantityOwned &gt;= 1
{
    prop1 = (100 * global.propertiesUninspiringGarageQuantityOwned);
}

if global.propertiesArchaicDinerQuantityOwned &gt;= 1
{
    prop2 = (1250 * global.propertiesArchaicDinerQuantityOwned);
} 

if global.propertiesTaxiDepotQuantityOwned &gt;= 1
{
    prop3 = (4750 * global.propertiesTaxiDepotQuantityOwned);
}

if global.propertiesChinaShopQuantityOwned &gt;= 1
{
    prop4 = (8200 * global.propertiesChinaShopQuantityOwned)
}

if global.propertiesMiaNightClubQuantityOwned &gt;= 1
{
    prop5 = (10000 * global.propertiesMiaNightClubQuantityOwned)
}

if global.propertiesKenjiCasinoQuantityOwned &gt;= 1
{
    prop6 = (12250 * global.propertiesKenjiCasinoQuantityOwned)
}

if global.propertiesHighriseBuildingQuantityOwned &gt;= 1
{
    prop7 = (18750 * global.propertiesHighriseBuildingQuantityOwned)
}

if global.propertiesGrandCabaretClubQuantityOwned &gt;= 1
{
    prop8 = (23750 * global.propertiesGrandCabaretClubQuantityOwned)
}

if global.propertiesDecadePenthouseQuantityOwned &gt;= 1
{
    prop9 = (26250 * global.propertiesDecadePenthouseQuantityOwned)
}

totalUpkeep = (prop1 + prop2 + prop3 + prop4 + prop5 + prop6 + prop7 + prop8 + prop9);

if  global.propertiesUninspiringGarageQuantityOwned &gt;= 1 ||
    global.propertiesArchaicDinerQuantityOwned &gt;= 1 ||
    global.propertiesTaxiDepotQuantityOwned &gt;= 1 ||
    global.propertiesChinaShopQuantityOwned &gt;= 1 ||
    global.propertiesMiaNightClubQuantityOwned &gt;= 1 ||
    global.propertiesKenjiCasinoQuantityOwned &gt;= 1 ||
    global.propertiesHighriseBuildingQuantityOwned &gt;= 1 ||
    global.propertiesGrandCabaretClubQuantityOwned &gt;= 1 ||
    global.propertiesDecadePenthouseQuantityOwned &gt;= 1
{
    //only do this once every 60 seconds
    if (start_timer == true) 
    {
        timer = room_speed * 60;
        show_debug_message("Started Timer")
    }
    
    if (timer &gt; 0) 
    {
        timer--;
    }
    
    if (timer &lt;= 0)
    {
        global.totalPropertiesIncome = (global.totalPropertiesIncome - totalUpkeep)
        timer = room_speed * 60; // This is important, or the timer will trigger every step once it runs out
        start_timer = true;
        start_timer = false;
        show_debug_message("Applied Upkeep!")
    }
}

</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>422</id>
