        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_font(ft_properties_body);
draw_set_colour(c_black);
draw_text_ext(734,310,string(newYorkPropertySelection),20, 295);  //This controls the selected property string.

//menu properties
