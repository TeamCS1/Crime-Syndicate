    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//Init first property as that shows first
newYorkPropertySelection = "Uninspiring Garage";
propertyDescription = "An uninspiring garage, what'd you expect? Store your rubbish in here, and hope you don't get robbed during the night.";
global.newYorkPropertySelection = "Uninspiring Garage";
propertyCost = 5000;
propertyUpkeepType = 100;
propertyQuantity = -1;

alarm[0] = room_speed * 0.1

</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="2" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Property calculations

global.calculatedNewYorkPropertyCost = 0
global.calculatedNewYorkPropertyCostMillions = 0
global.calculatedNewYorkPropertyCostBillions = 0
global.calculatedNewYorkPropertyCostTrillions = 0

global.calculatedNewYorkPropertyCost = global.newYorkPropertyToCost * global.propertiesQuantity

    if global.calculatedNewYorkPropertyCost &lt; 999999 &amp;&amp; global.calculatedNewYorkPropertyCostMillions == 0
    {
        global.moneySuffixProperties = "";
        show_debug_message("Less than 1M Statement Executed")
    }
    
    if global.moneySuffixProperties == "Million"
    {
    
    show_debug_message("Higher than or equal to 1M Statement Executed")
            
    //Checks whether the millions is greater than 0 and that the property cost is equal to 0
    
        if global.calculatedNewYorkPropertyCostMillions &gt; 0 &amp;&amp; global.calculatedNewYorkPropertyCost == 0
        {
            global.calculatedNewYorkPropertyCostMillions *= global.propertiesQuantity
            show_debug_message("Millions, None Normal Money")
        }
            
        //Checks whether the millions is greater than 0 and that the property cost is greater than 0
        else if global.calculatedNewYorkPropertyCostMillions &gt; 0 &amp;&amp; global.calculatedNewYorkPropertyCost &gt; 0
        {  
            while global.calculatedNewYorkPropertyCost &gt;= 1000000
            {
                show_debug_message("Inside While Loop")
                global.calculatedNewYorkPropertyCostMillions += 1
                global.calculatedNewYorkPropertyCost -= 1000000
            }
                
            global.calculatedNewYorkPropertyCost *= global.propertiesQuantity
                
            show_debug_message("Millions and Normal Money Added Together")
            show_debug_message("Exit While Loop")
        }
        
    }
    
    while global.calculatedNewYorkPropertyCost &gt;= 1000000
    {
        global.calculatedNewYorkPropertyCostMillions += 1
        global.calculatedNewYorkPropertyCost -= 1000000
        global.moneySuffixProperties = "Million";
    }

    while global.calculatedNewYorkPropertyCostMillions &gt;= 1000
    {
        global.calculatedNewYorkPropertyCostBillions += 1;
        global.calculatedNewYorkPropertyCostMillions -= 1000;
        global.moneySuffixProperties = "Billion";
        global.calculatedNewYorkPropertyCostBillions *= global.propertiesQuantity
        show_debug_message("Billion Statement Executed")
    }
    
    while global.calculatedNewYorkPropertyCostBillions &gt;= 1000
    {
        global.calculatedNewYorkPropertyCostTrillions += 1;
        global.calculatedNewYorkPropertyCostBillions -= 1000;
        global.moneySuffixProperties = "Trillion";
        global.calculatedNewYorkPropertyCostTrillions *= global.propertiesQuantity
        show_debug_message("Trillion Statement Executed")
    }
    
    alarm[0] = room_speed * 0.1
</string>
          </argument>
        </arguments>
      </action>
    </event>
