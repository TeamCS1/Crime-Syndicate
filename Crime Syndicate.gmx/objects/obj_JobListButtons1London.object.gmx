            <kind>1</kind>
            <string>//if the current page was city bosses change page texture
if global.londonOnJob == "citybosses_london"
{
    with obj_city_bosses_menu
    {
        if instance_exists(obj_city_bosses_menu)
        {
            instance_destroy()
            instance_create(x,y,obj_TEXTURE_LONDON_PAGE1_2)
            show_debug_message("CREATE: obj_TEXTURE_LONDON_PAGE1_2")
        }
    }
}

//Updates click event to current list is equal to list1
global.londonOnJob = "list1";

if global.londonOnJob == "list1"
{
    image_index = 1;
    
    with obj_JobListButtons2London
    {
        image_index = 2
    }
    
    with obj_TEXTURE_LONDON_PAGE1_2
    {
        image_index = 0;
    }
    
    with obj_city_bosses_button_LONDON
    {
        image_index = 2
    }
}

//Create mouse icon if it doesn't exist
if !instance_exists(obj_mouse_wheel_icon_anim)
{
    instance_create(x,y,obj_mouse_wheel_icon_anim)
}
    
//add the controller back in to allow changing of cities
if !instance_exists(obj_worldMapLondonControl)
{
    instance_create(x,y,obj_worldMapLondonControl)
}

//Destroy city boss tier buttons just in case they exist.
scr_CleanseCityBossesMenuButtons();
