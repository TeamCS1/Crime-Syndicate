        <arguments>
          <argument>
            <kind>1</kind>
            <string>if y &gt;= scrollCutOff
{
    draw_sprite(spr_inventory_slots_list,1,x,y)
}

draw_set_font(ft_in_game)
draw_set_color(c_black)
draw_set_valign(fa_center)

//Draws item name and descriptions depending on the tab you're on.
//Normal properties

if(printOut) &amp;&amp; obj_property_management_make_inventory.currentPage == 0
{
    if y &gt;= scrollCutOff
    {
        draw_text_transformed_colour(x + 8,y + 12,name,1,1,0,c_red,c_blue,c_red,c_blue,1)
        draw_set_halign(fa_right);
        draw_text_transformed_colour(x + 680,y + 12,"Base Price: $" + string(scr_number_sep(price,",",3)),1,1,0,c_red,c_blue,c_red,c_blue,1)
        draw_text_transformed_colour(x + 680,y + 40,"Quantity: " + string(quantity),1,1,0,c_red,c_blue,c_red,c_blue,1)
        draw_set_halign(fa_left);
    }
}

//Blackmarket properties
else if(printOut) &amp;&amp; obj_property_management_make_inventory.currentPage == 1
{
    if y &gt;= scrollCutOff
    {
        draw_text_transformed_colour(x + 8,y + 12,name,1,1,0,c_red,c_blue,c_red,c_blue,1)
        draw_set_halign(fa_right);
        draw_text_transformed_colour(x + 680,y + 12,"Base Price: $" + string(scr_number_sep(price,",",3)),1,1,0,c_red,c_blue,c_red,c_blue,1)
        draw_set_halign(fa_left);
    }
}

else
{
    if y &gt;= scrollCutOff
    {
        //draw_text_transformed_colour(x + 8,y + 12,name,1,1,0,c_red,c_blue,c_red,c_blue,1)
    }    
}


