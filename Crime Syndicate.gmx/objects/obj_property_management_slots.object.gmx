        <arguments>
          <argument>
            <kind>1</kind>
            <string>itemEntered = id; 

with itemEntered
{
     obj_properties_new_york_menu_pointer.newYorkPropertySelection = itemEntered.name;
     global.newYorkPropertySelection = itemEntered.name; 
     obj_properties_new_york_menu_pointer.propertyDescription = itemEntered.desc;
     obj_properties_new_york_menu_pointer.propertyCost = itemEntered.price;
     obj_properties_new_york_menu_pointer.propertyUpkeepType = itemEntered.upkeep;
     obj_properties_new_york_menu_pointer.propertyQuantity = itemEntered.quantity;
}
</string>
