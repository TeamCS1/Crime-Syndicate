          <argument>
            <kind>1</kind>
            <string>///Update property slots.
printOut = true;

if obj_property_management_make_inventory.currentPage == 0   //Melee weapons
{
    with(instance_find(obj_property_management_slots, 0)) //ID 0
    {
        name = "Uninspiring Garage";
        desc = "An uninspiring garage, what'd you expect? Store your rubbish in here, and hope you don't get robbed during the night.";
        price = 5000;
        quantity = global.propertiesUninspiringGarageQuantityOwned;
        upkeep = 100;       
    }

    with(instance_find(obj_property_management_slots, 1)) //ID 1
    {
        name = "Archaic Diner";
        desc = "A once family owned diner now home to a rat infestation. Call the Twin Home experts!";
        price = 45000;
        quantity = global.propertiesArchaicDinerQuantityOwned;
        upkeep = 1250;
    }

    with(instance_find(obj_property_management_slots, 2)) //ID 2
    {
        name = "Run-downed Taxi Depot";
        desc = "An eastern european man with a lot of debts used to operate this taxi depot. He slept under his desk for a year."
        price = 75000;
        quantity = global.propertiesTaxiDepotQuantityOwned; 
        upkeep = 4750;
    }

    with(instance_find(obj_property_management_slots, 3)) //ID 3
    {
        name = "Antique Store";
        desc = "Some rascals keep smashing the place up with baseball bats, can you run protection for us?";
        price = 125000;
        quantity = global.propertiesChinaShopQuantityOwned;
        upkeep = 8200;
    }

    with(instance_find(obj_property_management_slots, 4))
    {
        name = "Mia's Night Club";
        desc = "Given as a gift to the girlfriend, even put her name on the plaque. Now I've lost two items I didn't care about.";
        price = 250000;
        quantity = global.propertiesMiaNightClubQuantityOwned;
        upkeep = 10000;
    }

    with(instance_find(obj_property_management_slots, 5))
    {
        name = "Kenji's Casino";
        desc = "Named after the co-leader of the Yakuza, Kenji Kasuga. There are also rumours that the police have an investment in the casino.";
        price = 375000;
        quantity = global.propertiesKenjiCasinoQuantityOwned;
        upkeep = 12250;
    }

    with(instance_find(obj_property_management_slots, 6))
    {
        name = "Highrise Building";
        desc = "Relatively new and is partly under construction. Some folks have said it was built over a world heritage site.";
        price = 500000;
        quantity = global.propertiesHighriseBuildingQuantityOwned;
        upkeep = 18750;
    }

    with(instance_find(obj_property_management_slots, 7))
    {
        name = "Grand Cabaret Club";
        desc = "A club for the very best of people, many so called dragon 'enthusiasts' have fought here for the title, but only one wins.";
        price = 750000;
        quantity = global.propertiesGrandCabaretClubQuantityOwned;
        upkeep = 23750;
    }

    with(instance_find(obj_property_management_slots, 8))
    {
        name = "Decade Penthouse";
        desc = "A penthouse that was built before the first world war and rebuilt after the second. Decades of money has gone into the project.";
        price = 1000000;
        quantity = global.propertiesDecadePenthouseQuantityOwned;
        upkeep = 26250;
    }

    with(instance_find(obj_property_management_slots, 9))
    {
        name = "";
        desc = "";
        price = 0;
    }
    
    with(instance_find(obj_property_management_slots, 10))
    {
        name = "";
        desc = "";
        price = 0;
    }
    
    with(instance_find(obj_property_management_slots, 11))
    {
        name = "";
        desc = "";
        price = 0;
    }
    
    with(instance_find(obj_property_management_slots, 12))
