        price = 0;
    }
    
    with(instance_find(obj_property_management_slots, 15))
    {
        name = "";
        desc = "";
        price = 0;
    }
}

else if obj_property_management_make_inventory.currentPage == 1 //Reserved for Armour only
{
    with(instance_find(obj_property_management_slots, 0)) //ID 0
    {
        name = "Stealth Suit";
        desc = "An invisible suit, perfect when fighting enemies with short-term memory.";
        portrait = spr_outfit_stealth_suit;
        price = 1000;
        attackDamage = 10;
        defenceProtection = 10;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 1)) //ID 1
    {
        name = "Military Suit";
        desc = "An armoured camouflaged suit, perfect when fighting blind enemies.";
        portrait = spr_outfit_military_suit;
        price = 1000;
        attackDamage = 10;
        defenceProtection = 10;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 2)) //ID 2
    {
        name = "Jugganaut Suit";
        desc = "Used to be used in WW2 as well as for bomb defusing units.";
        portrait = spr_outfit_jugganaut;
        price = 1000;
        attackDamage = 10;
        defenceProtection = 10;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 3)) //ID 3
    {
        name = "Power Armour";
        desc = "Made up of strong individual combat pieces that go on a exoskeleton.";
        portrait = spr_outfit_power_armour;
        price = 1000;
        attackDamage = 70;
        defenceProtection = 65;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 4)) //ID 4
    {
        name = "Prototype Suit";
