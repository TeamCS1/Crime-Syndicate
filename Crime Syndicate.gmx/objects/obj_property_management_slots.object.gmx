        portrait = spr_outfit_prototype_suit;
        price = 1000;
        attackDamage = 33;
        defenceProtection = 04;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 5)) //ID 5
    {
        name = "Three Piece Suit (Normal)";
        desc = "Just a standard suit, best suited for spy missions.";
        portrait = spr_outfit_three_pieced_suit;
        price = 5000;
        attackDamage = 7;
        defenceProtection = 5;
        elementaryEffect = "None";
    }
 
    with(instance_find(obj_property_management_slots, 6)) //ID 5
    {
        name = "Three Piece Suit (Kevlar)";
        desc = "Offers modest amount of protection against bullet damage.";
        portrait = spr_outfit_three_pieced_suit;
        price = 100000;
        attackDamage = 26;
        defenceProtection = 32;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 7)) //ID 6
    {
        name = "Flak Jacket";
        desc = "Great for explosive damage, as long as it doesn't hit you in the face.";
        portrait = spr_outfit_flak_jacket;
        price = 50000;
        attackDamage = 35;
        defenceProtection = 40;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 8)) //ID 7
    {
        name = "Radiation Suit";
        desc = "This can be used to protect yourself against ionising radiation.";
        portrait = spr_outfit_radiation_suit;
        price = 10000;
        attackDamage = 25;
        defenceProtection = 80;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 9)) //ID 8
    {
        name = "Cloaking Device";
        desc = "This can be used to turn yourself invisible when it matters.";
        portrait = spr_outfit_cloaking_device;
        price = 40000;
        attackDamage = 30;
        defenceProtection = 100;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 10)) //ID 10
    {
        name = "Luxury Leather Gold Jacket";
        desc = "Once you wear this, money should come out and hot babes.";
        portrait = spr_outfit_gold_jacket;
        price = 1000000;
        attackDamage = 60;
        defenceProtection = 95;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 11)) //ID 11
    {
        name = "Spider Silk Armour";
        desc = "Carefully woven using durable spider silk.";
        portrait = spr_outfit_spider_silk_armour;
        price = 10000;
        attackDamage = 27;
        defenceProtection = 33;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 12)) //ID 12
    {
        name = "Handmade Bone Armour";
        desc = "Made with cobbled up bones and red cloth.";
        portrait = spr_outfit_bone_armour;
        price = 4000;
        attackDamage = 12;
        defenceProtection = 15;
        elementaryEffect = "None";
    }
    
    with(instance_find(obj_property_management_slots, 13)) //ID 13
    {
        name = "";
        desc = "";
    }
    
