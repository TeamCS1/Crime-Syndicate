    }
}

image_xscale = size;
image_yscale = size;

if instance_exists(obj_property_management_slots)
{ 
    y = start_y - (((instance_number(obj_property_management_slots) - 10) * 80) * obj_scrollbar_black_market.scroll_perc)
}
