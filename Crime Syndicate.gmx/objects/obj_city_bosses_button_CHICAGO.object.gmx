        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if !instance_exists(obj_upgradeStatsMenuGUI)
{
    global.chicagoOnJob = "citybosses_chicago";
    global.currentCity = "CHICAGO"
    
    if global.chicagoOnJob == "citybosses_chicago"
    {
        image_index = 1;
        
        with obj_JobListButtons1Chicago
        {
            image_index = 2
        }
        
        with obj_JobListButtons2Chicago
        {
            image_index = 2
        }
        
        //Creates City Bosses Menu
        with obj_TEXTURE_CHICAGO_PAGE1_2
        {
            if !instance_exists(obj_city_bosses_menu)
            {
                instance_create(x,y,obj_city_bosses_menu);
                show_debug_message("obj_city_bosses_menu Created")
            }
            
            instance_destroy();
        }
        
        with obj_city_bosses_button_CHICAGO
        {
            image_index = 1;
        }
        
        //if the mouse icon exists, destroy it.
        with obj_mouse_wheel_icon_anim
        {
            if instance_exists(obj_mouse_wheel_icon_anim)
            {
                instance_destroy();
            }
        }
        
        //destroy the controller also, to prevent changing city.
        with obj_worldMapChicagoControl
        {
            if instance_exists(obj_worldMapChicagoControl)
            {
                instance_destroy();
            }
        }
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
