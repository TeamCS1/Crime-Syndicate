{
    instance_create(x,y,obj_black_market_trips_select_dest_gui);
}

//if it exists reset position
else  
{
    obj_black_market_trips_select_dest_gui.x = 1121;
    obj_black_market_trips_select_dest_gui.y = 249;
}
</string>
