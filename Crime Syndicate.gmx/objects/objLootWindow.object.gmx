        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Draw the loot box based on location option (centered default)

// Moving window instructions
scrDrawText(view_xview[0] + 5,view_yview[0] + view_hview[0] - 40,"Mousewheel up/down to change window location.",c_black,ft_properties,1,fa_left);

// Draw the loot window
scrDrawLootWindow(lwLocation,lwColor,lwBackAlpha,lwBorder,lwBorderColor,lwLootSize,lwLootHeight);
</string>
