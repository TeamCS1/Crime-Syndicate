  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>/// Setup the loot options
/*
  lw = Loot Window (for organization)
*/

// Global Location to use for displaying loot
global._x1 = 0;
global._x2 = 0;
global._y1 = 0;
global._y2 = 0;

// Create loot table
//instance_create(0,0,objLootTable);

// Window Position &amp; Color
/*
  Location Options -
           0 = Left
           1 = Center
           2 = Right
*/
lwLootHeight = 64; // the size of the loot icons (usually square, so width as well)
lwLocation = 1;
lwColor = make_color_rgb(64,0,0); // black dark red
lwBackAlpha = 0.8;
lwBorder = true;
lwBorderColor = c_white;

//lwColor = make_color_rgb(25,62,118); // dark blue

randomize();

// Loot Information
lwLootSize = round(random_range(global.lootTableAmountInTableMin,global.lootTableAmountInTableMax)); // How many items drop?

// Setup the loot table that will show. Second number is the last number of items in array
for (i=0; i&lt;lwLootSize; i++) {
    lwLootTable[i] = round(random_range(0,global.lootWindowLastNumberInArray));
}

// GUI Information
instance_create(0,0,objLWClose);
lwClose = false;

// Draw the Loot on the window
for (i = 0; i &lt; lwLootSize; i++) {
    //scrDrawLoot(global._x1 + 5, global._y1 + (lwLootHeight * i) + (5*i+5),global.arrWeapons[lwLootTable[i],0],global.arrWeapons[lwLootTable[i],1],lwLootHeight);
    if (instance_number(objGreed) &lt; lwLootSize) {
       // Create the item
       jj = instance_create(global._x1 + 5, global._y1 + (lwLootHeight * i) + (5*i+5),objLoot);
       jj.loot = i;
       jj.item = lwLootTable[i];
       jj.sprite = global.arrWeapons[lwLootTable[i],0];
       jj.desc = global.arrWeapons[lwLootTable[i],1];
       
       // Create the greed icon
       ii = instance_create(global._x2, global._y1 + (lwLootHeight * i) + (5*i+5),objGreed);
       ii.loot = i;
       ii.parent = jj;
       
       // Create the need icon
       kk = instance_create(global._x2, global._y1 + (lwLootHeight * i) + (5*i+5),objNeed);
       kk.loot = i;
       
       // Set the children for loot
       jj.greed = ii;
       jj.need = kk;
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Kill the loot window if user closes GUI
if (lwClose == true)
{
    global.lootWindowLastNumberInArray = -1;
    global.lootTableChooseType = -1;
    global.lootTableAmountInTableMin = -1;
    global.lootTableAmountInTableMax = -1;
    
    //Cleanup window instances
    if instance_exists(objLootTableJobsRankingGlobals)
    {
        with objLootTableJobsRankingGlobals
        {
            instance_destroy();
        }
    }
    
    instance_destroy();
}
else
{
    if (instance_number(objLoot) == 0) &amp;&amp; !instance_exists(obj_loot_number)
    {
        lwClose = true;
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
