        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Init Globals
global.line1Damage = "";
global.line2Damage = "";
global.currentAIBarSectionTwo = global.healthCountMax * 1.5;  //1.3 easy, 1.5 normal, 1.7 hard.
global.currentAIMaximumSectionTwo = global.healthCountMax;
global.currentAICountSectionTwo = global.currentAIMaximumSectionTwo;

///Init locals
backColour = c_gray;
isDead = false;
isRoomRestarted = true;
barHeight = 273;

//returns the name, titles and descriptions of the Hitmen from the script
global.sectionTwoName = scr_HitmenNamesReturn(false);
global.sectionTwoTitle = scr_HitmenTitlesReturn();
global.sectionTwoDesc = scr_HitmenDescReturn();
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Calculate Section 2
randomize();

//Init variables
global.hitmenBountySectionTwo = 0;
global.hitmenDiffultyChanceSectionTwo = 0;
global.hitmenDiffultyChanceTextSectionTwo = "Impossible";
global.hitmenXPChanceSectionTwo = 0;

//Calculations

//difficulty select range. For section two this must be Normal and Hard ONLY!
global.hitmenDiffultyChanceSectionTwo += irandom_range(0, 1);

if global.hitmenDiffultyChanceSectionTwo == 0
{
    global.hitmenDiffultyChanceTextSectionTwo = "Normal"
    
}

else if global.hitmenDiffultyChanceSectionTwo == 1
{
    global.hitmenDiffultyChanceTextSectionTwo = "Hard"
    
}

//Based on the difficulties given to us, we need to be generous with xp
//Since there are 0% chance of legendaries, don't bother calculating it.

if global.hitmenXPChanceSectionTwo == 0 //Normal
{
    global.hitmenXPChanceSectionTwo += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 2.0));   
}

else if global.hitmenXPChanceSectionTwo == 1 //Hard
{
    global.hitmenXPChanceSectionTwo += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 3.0));   
}

//This section, scales the AI to the player's lower and upperbound.
global.currentPlayerLevelUpperBound += irandom_range(global.currentPlayerLevel, global.currentPlayerLevel + 10);
global.hitmenBountySectionTwo += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevelUpperBound * 1.5));
global.hitmenBountySectionTwo *= global.currentPlayerLevel * 2.0

//CALCULATE AI'S ATK AND DEFENCE DO NOT MOVE

showAttack = false;
global.damageOutputToAISectionTwo = 0
global.damageOutputToPlayerSectionTwo = 0;

global.AIDefenceProtectionSectionTwo = -1;
global.AIAttackDamageSectionTwo = -1;     //declares attack damage

//difficulty settings

if global.hitmenDiffultyChanceSectionTwo == 0     //is normal
{
    global.AIDefenceProtectionSectionTwo += irandom_range(global.defenceProtection - 7, global.defenceProtection + 2);
    global.AIAttackDamageSectionTwo += irandom_range(global.attackDamage - 6, global.attackDamage + 3);   
}

else if global.hitmenDiffultyChanceSectionTwo == 1     //is Hard
{
    global.AIDefenceProtectionSectionTwo += irandom_range(global.defenceProtection - 4, global.defenceProtection + 5);
    global.AIAttackDamageSectionTwo += irandom_range(global.attackDamage - 3, global.attackDamage + 6);   
}

//Prevents underflows
if global.AIDefenceProtectionSectionTwo &lt;= 0
{
    global.AIDefenceProtectionSectionTwo = 1;
}

if global.AIAttackDamageSectionTwo &lt;= 0
{
    global.AIAttackDamageSectionTwo = 1;
}

if global.hitmenXPChanceSectionTwo &lt;= 0
{
    global.hitmenXPChanceSectionTwo = 1;
}

if global.hitmenBountySectionTwo &lt;= 0
{
    global.hitmenBountySectionTwo = 1;
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
