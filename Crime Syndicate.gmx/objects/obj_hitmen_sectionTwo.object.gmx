        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Draw Section 2 Only
draw_set_font(ft_hitmen);
draw_set_colour(c_black);
draw_text(x + 105,y + 62,string(global.sectionTwoName) + string(global.sectionTwoTitle));
draw_text_ext(x + 27,y + 216,string(global.sectionTwoDesc),18,680);    //armaments
draw_text(x+205,y + 119, "$" + string(global.hitmenBountySectionTwo) + " +" + string(global.hitmenXPChanceSectionTwo) + "XP");
draw_text(x+215,y + 172, string(global.hitmenDiffultyChanceTextSectionTwo));

//AI
draw_text(x + 565,y + 62, string(global.AIAttackDamageSectionTwo));
draw_text(x + 590,y + 92, string(global.AIDefenceProtectionSectionTwo));

//PLAYER
draw_text(x + 592,y + 139, string(global.attackDamage));
draw_text(x + 615,y + 169, string(global.defenceProtection));
</string>
          </argument>
        </arguments>
