    <event eventtype="6" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Player Attack Damage Calculation

//local event variables | Only need to be declared here, nowhere else.

showAttack = true
playerHasAttacked = true

global.showSectionOne = false;
global.showSectionTwo = true;
global.showSectionThree = false;

global.damageOutputToAISectionTwo = 0     //resets Player damage output to 0, before performing re-calculation.

if global.hitmenDiffultyChanceTextSectionTwo == "Peaceful"
{
    global.damageOutputToAISectionTwo += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtectionSectionTwo); 
    global.damageOutputToAISectionTwo *= 3
}

else if global.hitmenDiffultyChanceTextSectionTwo == "Easy"
{
    global.damageOutputToAISectionTwo += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtectionSectionTwo); 
    global.damageOutputToAISectionTwo *= 2
}

else if global.hitmenDiffultyChanceTextSectionTwo == "Normal"
{
    global.damageOutputToAISectionTwo += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtectionSectionTwo); 
    global.damageOutputToAISectionTwo *= 1
}

else if global.hitmenDiffultyChanceTextSectionTwo == "Hard"
{
    global.damageOutputToAISectionTwo += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtectionSectionTwo); 
    global.damageOutputToAISectionTwo *= 0.5
}

else if global.hitmenDiffultyChanceTextSectionTwo == "Ex-Hard"
{
    global.damageOutputToAISectionTwo += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtectionSectionTwo); 
    global.damageOutputToAISectionTwo *= 0.3
}

if global.damageOutputToAISectionTwo &lt;= 0
{
    global.damageOutputToAISectionTwo = 1
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Enemy Attack Damage Calculation

global.damageOutputToPlayerSectionTwo = 0;        //resets AI damage output to 0, before performing re-calculation.

if global.hitmenDiffultyChanceTextSectionTwo == "Peaceful"
{
    global.damageOutputToPlayerSectionTwo += irandom_range(global.currentPlayerLevel, global.AIAttackDamageSectionTwo - global.defenceProtection); 
    global.damageOutputToPlayerSectionTwo *= 0.35
}

else if global.hitmenDiffultyChanceTextSectionTwo == "Easy"
{
    global.damageOutputToPlayerSectionTwo += irandom_range(global.currentPlayerLevel, global.AIAttackDamageSectionTwo - global.defenceProtection); 
    global.damageOutputToPlayerSectionTwo *= 0.50
}

else if global.hitmenDiffultyChanceTextSectionTwo == "Normal"
{
    global.damageOutputToPlayerSectionTwo += irandom_range(global.currentPlayerLevel, global.AIAttackDamageSectionTwo - global.defenceProtection); 
    global.damageOutputToPlayerSectionTwo *= 1.00
}

else if global.hitmenDiffultyChanceTextSectionTwo == "Hard"
{
    global.damageOutputToPlayerSectionTwo += irandom_range(global.currentPlayerLevel, global.AIAttackDamageSectionTwo - global.defenceProtection); 
    global.damageOutputToPlayerSectionTwo *= 1.25
}

else if global.hitmenDiffultyChanceTextSectionTwo == "Ex-Hard"
{
    global.damageOutputToPlayerSectionTwo += irandom_range(global.currentPlayerLevel, global.AIAttackDamageSectionTwo - global.defenceProtection); 
    global.damageOutputToPlayerSectionTwo *= 1.50
}

if global.damageOutputToPlayerSectionTwo &lt;= 0
{
    global.damageOutputToPlayerSectionTwo = 1
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Update Attack History To Player
if !instance_exists(obj_createPersonalMedic)
{
    if playerHasAttacked == true &amp;&amp; global.healthCount &gt; 25
    {
        global.line1Damage = global.damageOutputToAISectionTwo
        global.currentAICountSectionTwo -= global.damageOutputToAISectionTwo
        global.healthCount -= global.damageOutputToPlayerSectionTwo
        
        backColour = c_orange;
        alarm[0] = room_speed * 0.5;
        
        //Checks whether AI is dead, if so, update isDead flag.
        if global.currentAIBarSectionTwo &lt;= 0 
        {
            isDead = true;
            
        }
    }
    
    //UPDATE ATTACK HISTORY AI
    if playerHasAttacked == true
    {
        global.line2Damage = global.damageOutputToPlayerSectionTwo
    }
}

//Reset notifs state
obj_global.showOnce = true;
</string>
          </argument>
        </arguments>
      </action>
    </event>
