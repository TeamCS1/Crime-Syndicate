      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Attack History Draw Events

if showAttack == true &amp;&amp; global.showSectionTwo == true 
{
    global.line2Damage = round(global.damageOutputToPlayerSectionTwo);
    
    draw_set_font(ft_attack_history);
    draw_set_color(c_white);
    draw_text_ext(1515,460,"Player has attacked " + string(global.sectionTwoName)+ string(global.sectionTwoTitle) + " with " + string(global.line1Damage) + " damage.##"+
    string(global.sectionTwoName)+ string(global.sectionTwoTitle) + " has attacked Player with " + string(global.line2Damage) + " damage." ,20,300)
   

}


</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Draw AI Healthbar
global.currentAIBarSectionTwo = (global.currentAICountSectionTwo / global.currentAIMaximumSectionTwo) * 100;

draw_healthbar(x + 200,y + barHeight, x+ 700,y + barHeight + 30,global.currentAIBarSectionTwo,backColour,c_red,c_blue,0,true,true)
draw_set_colour(c_white);
draw_set_font(ft_properties);
draw_text(x+ 200,y + 275,"HP:" + string(global.currentAICountSectionTwo * 100) + "/" +
string(global.currentAIMaximumSectionTwo * 100));
draw_set_colour(c_black);

//Gives money and xp once the enemy is dead.
if global.currentAIBarSectionTwo &lt;= 0 &amp;&amp; !instance_exists(obj_hitman_killed_GUI)
{
    global.moneyCount += global.hitmenBountySectionTwo
    global.currentXP += global.hitmenXPChanceSectionTwo
            
    showAttack = false      //hides the attack history panel.
            
    //Creates hitmen killed GUI
    if !instance_exists(obj_hitman_killed_GUI)
    {
        instance_create(416,224,obj_hitman_killed_GUI)
        global.hitmenKilled++;
    } 
}
</string>
