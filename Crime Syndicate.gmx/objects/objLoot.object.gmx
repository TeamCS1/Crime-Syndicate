        global.gold_metal_powder += quantity
    }

    else if (item == 4)
    {
        quantity = irandom_range(4, 5)
        global.gun_powder += quantity
    }
    
    //---Blueprints - 9
    
    else if (item == 5)
    {
        quantity = irandom_range(4, 5)
        global.pistolBlueprint += quantity
    }

    else if (item == 6)
    {
        quantity = irandom_range(4, 5)
        global.shotgunBlueprint += quantity
    }

    else if (item == 7)
    {
        quantity = irandom_range(4, 5)
        global.sniperBlueprint += quantity
    }

    else if (item == 8)
    {
        quantity = irandom_range(4, 5)
        global.lmgBlueprint += quantity
    }

    else if (item == 9)
    {
        quantity = irandom_range(4, 5)
        global.throwablesBlueprint += quantity
    }

    else if (item == 10)
    {
        quantity = irandom_range(4, 5)
        global.meleeBlueprint += quantity
    }

    else if (item == 11)
    {
        quantity = irandom_range(4, 5)
        global.submachineBlueprint += quantity
    }

    else if (item == 12)
    {
        quantity = irandom_range(4, 5)
        global.automaticBlueprint += quantity
    }

    else if (item == 13)
    {
        quantity = irandom_range(4, 5)
        global.minesBlueprint += quantity
    }
    
    //---Fibers - 2
    
    else if (item == 14)
    {
        quantity = irandom_range(4, 5)
        global.ballistic_fiber += quantity
    }

    else if (item == 15)
    {
        quantity = irandom_range(4, 5)
        global.carbon_fiber += quantity
    }

    else
    {
        //for items not coded in
        quantity = irandom_range(0, 0)
    }
}

//Destroys after displaying number
global.lootNumberString = quantity;
instance_create(x, y, obj_loot_number)

// Destroy from item window
instance_destroy();
</string>
          </argument>
        </arguments>
      </action>
    </event>
