            <kind>1</kind>
            <string>// Keep the greed rolls in the right location
// If the loot window exists, keep the icon up
if (instance_exists(objLootWindow)) {
    x = global._x1 + 5;
    y = global._y1 + (objLootWindow.lwLootHeight * loot) + (5*loot+5);
} else {
  // otherwise, destroy it
  instance_destroy();
}
