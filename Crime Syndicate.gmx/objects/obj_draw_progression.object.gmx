            <string>draw_self();
draw_set_font(ft_progression);
draw_set_color(c_black);
draw_text_ext(50,100,string("Current Money: $" + string(scr_number_sep(global.moneyCount,",",3))), 12, 600)

draw_text_ext(50,200,string("Total Game Completion: " + string(global.gameCompletion) + "%"), 12, 600)
draw_text_ext(50,250,string("Jobs Completed: " + string(global.jobsCompleted)), 12, 600)
