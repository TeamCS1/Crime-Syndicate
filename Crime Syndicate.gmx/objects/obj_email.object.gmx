        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Convert frames to seconds
global.timePlayed = global.frames / global.frame_rate;

// Declare the variable for telemetry data
var telemetryData = "Player Level: " + string(global.currentPlayerLevel) + " " + 
                    "Time Played: " + string(global.timePlayed);

encrypt = base64_encode(telemetryData);

if obj_feedback_body.choice == 0
{
    encrypt = "Forbidden. User no consent"    
}


// Construct the email body
emailBody = "Write your bug report here...............] #Please don't edit anything below this line | Telemetry data: " + string(encrypt);

// Construct the "mailto" URL with the email body
email = "mailto:teamcs1enquiries@gmail.com?subject=Bug%20Report&amp;body=" + string(emailBody);
show_debug_message("Clicked");

if os_browser == browser_not_a_browser
{
    get_string_async("Please visit this site to submit","https://teamcs1.com/contact/");
}

else
{
    // Open the email client
    url_open(email);    
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>603</id>
