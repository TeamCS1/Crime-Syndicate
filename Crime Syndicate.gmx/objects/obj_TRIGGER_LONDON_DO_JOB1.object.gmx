            <string>if global.londonOnJob == "list1" &amp;&amp; global.currentPlayerLevel &gt;= 44
{
    if global.staminaCount &gt;= 20 &amp;&amp; !instance_exists(objLootWindow)
    {
        global.moneyCount += 1000000;
        global.currentXP += 40
        global.staminaCount -= 20
        
        //If the bar is less than or equal to full and the rank is not S, give completion
        if global.jobOneBarLondon &lt; 100 &amp;&amp; global.jobOneBarRankLondon &lt; 6
        {
            global.londonCompletion += 0.025
        }
        
        //Gives the final amount when maxed out fully.
        if global.jobOneBarLondon == 100 &amp;&amp; global.jobOneBarRankLondon == 6
        {
            global.londonCompletion += 2.5
        }
        
        global.jobOneBarLondon += 2
        global.jobsCompleted += 1;
        scr_JobPanelJobLootChances();
    }
}

if global.londonOnJob == "list2" &amp;&amp; global.currentPlayerLevel &gt;= 54
{
    if global.staminaCount &gt;= 45 &amp;&amp; !instance_exists(objLootWindow)
    {
        global.moneyCount += 8000000;
        global.currentXP += 84
