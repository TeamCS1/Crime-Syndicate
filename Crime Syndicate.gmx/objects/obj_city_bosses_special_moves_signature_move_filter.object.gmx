        <arguments>
          <argument>
            <kind>1</kind>
            <string>if !instance_exists(obj_city_bosses_pop_up_box)
{
    instance_create(mouse_x,mouse_y - 100,obj_city_bosses_pop_up_box)

    var _bossCount;
    _bossCount = 0;

    if global.currentCity == "NEW_YORK"
    {
        if global.newYorkCityBossTierOneInBattle == true
        {
            _bossCount = global.currentNewYorkCityBossBarTierOneCount;
        }
        else if global.newYorkCityBossTierTwoInBattle == true
        {
            _bossCount = global.currentNewYorkCityBossBarTierTwoCount;
        }
        else if global.newYorkCityBossTierThreeInBattle == true
        {
            _bossCount = global.currentNewYorkCityBossBarTierThreeCount;
        }
    }

    else if global.currentCity == "CHICAGO"
    {
        if global.chicagoCityBossTierOneInBattle == true
        {
            _bossCount = global.currentChicagoCityBossBarTierOneCount;
        }
        else if global.chicagoCityBossTierTwoInBattle == true
        {
            _bossCount = global.currentChicagoCityBossBarTierTwoCount;
        }
        else if global.chicagoCityBossTierThreeInBattle == true
        {
            _bossCount = global.currentChicagoCityBossBarTierThreeCount;
        }
    }

    else if global.currentCity == "LONDON"
    {
        if global.londonCityBossTierOneInBattle == true
        {
            _bossCount = global.currentLondonCityBossBarTierOneCount;
        }
        else if global.londonCityBossTierTwoInBattle == true
        {
            _bossCount = global.currentLondonCityBossBarTierTwoCount;
        }
        else if global.londonCityBossTierThreeInBattle == true
        {
            _bossCount = global.currentLondonCityBossBarTierThreeCount;
        }
    }

    else if global.currentCity == "LAS_VEGAS"
    {
        if global.lasVegasCityBossTierOneInBattle == true
        {
            _bossCount = global.currentLasVegasCityBossBarTierOneCount;
        }
        else if global.lasVegasCityBossTierTwoInBattle == true
        {
            _bossCount = global.currentLasVegasCityBossBarTierTwoCount;
        }
        else if global.lasVegasCityBossTierThreeInBattle == true
        {
            _bossCount = global.currentLasVegasCityBossBarTierThreeCount;
        }
    }

    if _bossCount &gt; 1
    {
        global.stringLength = 240;
        obj_city_bosses_pop_up_box.image_xscale = 7.10;
        obj_city_bosses_pop_up_box.image_yscale = 1.55;
        global.textToShow = "The BANK Bar must have a multiplier &gt; 1 to activate."
    }

    else if _bossCount &lt;= 1
    {
        global.stringLength = 240;
        obj_city_bosses_pop_up_box.image_xscale = 7.40;
        obj_city_bosses_pop_up_box.image_yscale = 1.55;
        global.textToShow = "Disabled. Use the Final Blow Move!"
    }

}
</string>
          </argument>
        </arguments>
      </action>
