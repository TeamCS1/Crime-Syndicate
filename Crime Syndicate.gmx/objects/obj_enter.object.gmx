        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Load script

//if its windows
if os_browser == browser_not_a_browser
{
    ini_open("savedata.ini")

    if ini_section_exists("blackmarket") 
    {
        scr_log_message(scr_DebugDate() + "Success: Save data section was found.")
        scr_LoadGameScript(); //Serialises the load script
        ini_close();
    }
    
    else
    {
        ini_close();
        scr_log_message(scr_DebugDate() + "Error: Save data section not found.")
        show_message("Unable to find saved data, please start a new game.");
        exit;
    } 
}

else
{
   scr_LoadGameScript(); //Serialises the load script
}
