    <event eventtype="6" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if menuChoice == 0  //new game
{
    scr_log_message(scr_DebugDate() + "SCENE: Switch to: rm_prologue1");
    show_debug_message("SCENE: Switch to: rm_prologue1");
    room_goto(rm_prologue1);
    
    if !instance_exists(obj_properties_income_generator)
    {
        instance_create(x,y,obj_properties_income_generator);
        scr_log_message(scr_DebugDate() + "CREATE: obj_properties_income_generator");
        show_debug_message("CREATE: obj_properties_income_generator");
    }
    
    if instance_exists(obj_webCreateTrophiesProgress)
    {
        instance_destroy(obj_webCreateTrophiesProgress,true);
        scr_log_message(scr_DebugDate() + "DESTROY: obj_webCreateTrophiesProgress");
        show_debug_message("DESTROY: obj_webCreateTrophiesProgress");
    }
    
    scr_log_message(scr_DebugDate() + "SCRIPT: called scr_essentials()");
    show_debug_message("SCRIPT: called scr_essentials()");
    scr_essentials();
}

else if menuChoice == 1 //load game
{
    alarm[0] = room_speed * 0.1;   //Triggers the load script in 0.1 seconds
}

else if menuChoice == 2  //options menu
{
    global.roomBeforePrevious = room;
    room_goto(rm_options_main);
}

else if menuChoice == 3
{
    if instance_exists(obj_STATUS_BARS_HUD)
    {
        with obj_STATUS_BARS_HUD
        {
            instance_destroy();
        }
    }
        scr_WebCreateTrophiesProgress();
        window_set_cursor(cr_hourglass);
}

else if menuChoice == 4
{
    game_end()
}
