    image_index = 1
}

if menuChoice == 2  //options menu
{
    image_index = 2
}

if menuChoice == 3  //trophies
{
    image_index = 3
}

if menuChoice == 4  //quit
{
    image_index = 4
}


if menuChoice &lt; 0
{
    image_index = 4
    menuChoice = 4
}

if menuChoice &gt; 4
{
    image_index = 0
    menuChoice = 0;
}

if instance_exists(obj_STATUS_BARS_HUD)
{
    with obj_STATUS_BARS_HUD
    {
        instance_destroy();
    }
}

if instance_exists(obj_global)
{
    with obj_global
    {
        instance_destroy();
    }
}
