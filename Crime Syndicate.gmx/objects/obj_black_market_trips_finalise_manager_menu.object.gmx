        <arguments>
          <argument>
            <kind>1</kind>
            <string>x = 1121;
y = 249;

//by default no trips should be started
global.tripOneActive = false;
toDraw = false;

//pass on variables
currentCityFinalise = "Nowhere";
tripStatus = "Trip 1 - Not Started";
firstLoop = true;
resourcesType = "None";
xpType = 0;

//Set up Countdown seconds with lag-free delta_time's microseconds
deltaSecond = 1000000 
totalSeconds = 0; //Any Positive Value in seconds before 65

//garbage collection!

if instance_exists(obj_black_market_trips_finalise)
{
    instance_destroy(obj_black_market_trips_finalise,true);
}

if instance_exists(obj_trips_view_cities)
{
    instance_destroy(obj_trips_view_cities);
}

if instance_exists(obj_trips_view_resource)
{
    instance_destroy(obj_trips_view_resource);
}

if instance_exists(obj_black_market_trips_select_dest_gui)
{
    instance_destroy(obj_black_market_trips_select_dest_gui);
}

if instance_exists(obj_black_market_trips_finalise_start_button)
{
    instance_destroy(obj_black_market_trips_finalise_start_button);
}

//temporilly destroys two buttons. In future should change the buttons to grey.
if instance_exists(obj_trip_upgrades_button_trigger)
{
    instance_destroy(obj_trip_upgrades_button_trigger);
}

if instance_exists(obj_black_market_trips_agents_button_trigger)
{
    instance_destroy(obj_black_market_trips_agents_button_trigger);
}

show_debug_message("Manager Menu...");


</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if global.tripOneActive == true
{
    if totalSeconds &lt; 0
    {
        totalSeconds = 0;
    }
    
    if totalSeconds &lt;= 0 &amp;&amp; firstLoop == true
    {
        totalSeconds = 0;
        tripStatus = "Trip 1 - Completed";
        
        if !instance_exists(obj_black_market_trips_finalise_manager_menu_create_loot_button) &amp;&amp; firstLoop == true
        {
            instance_create(x,y,obj_black_market_trips_finalise_manager_menu_create_loot_button)
            show_debug_message("CREATING LOOT BUTTON WOOOO")
        }
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_self();

if global.tripOneActive == true
{
    totalSeconds -= (delta_time/deltaSecond); //equals 1 second
}

var t,years,days,hours,minutes,seconds,timerDisplay;

//Integer Math
t = (60*60*24*365); years   = (totalSeconds div t);      //The last local variable
t = (60*60*24);     days    = (totalSeconds div t) % 365;//..will have no % value
t = (60*60);        hours   = (totalSeconds div t) % 24; // ..on the end.
t = (60);           minutes = (totalSeconds div t) % 60;
t = (1);            seconds = (totalSeconds div t) % 60;

//Convert Integers to writable String Values
years = string(years);
days  = string(days);
if (hours   &lt; 10) hours   = "0"+string(hours);   //If timer value is less than 10
else              hours   =     string(hours); // add "0" for two-digit counter
if (minutes &lt; 10) minutes = "0"+string(minutes); 
else              minutes =     string(minutes);
if (seconds &lt; 10) seconds = "0"+string(seconds); 
else              seconds =     string(seconds);

//Combine above strings into one string
timerDisplay = hours + ":" + minutes + ":" + seconds;

if toDraw == true
{
    draw_set_font(ft_properties);
    draw_set_color(c_black);
    draw_text(1170,450,"Your Agents are currently travelling to: " + string(global.selectedDestination)) //destination
    draw_text(1170,530,"XP: " + string(xpType));
    draw_text(1170,565,"Resources: " + string(resourcesType));
    
    draw_text(x + 50,y + 412,string(tripStatus));
    draw_text(x + 50,y + 450,"Remaining Time: " + timerDisplay);
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
