//Only draws completion when not in upgrade stats menu
if !instance_exists(obj_upgradeStatsMenuGUI)
{
    draw_set_color(c_white)
    
    draw_set_font(ft_job_panel)
    draw_text(63, 119,"New York: " + string(global.newYorkCompletion) + "% " + "/ 100%")
    
    draw_set_font(ft_job_panel_heading)
    draw_text(34, 27, "Job Panel")
}

draw_set_font(ft_job_panel)

if global.newYorkOnJob == "list1" &amp;&amp; !instance_exists(obj_upgradeStatsMenuGUI)
{
