        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Sets the slot 3 - 12
if !instance_exists(obj_black_market_trips_agents_pop_up_stats)
{
    instance_create(x + 200, y, obj_black_market_trips_agents_pop_up_stats);
}

if obj_black_market_trips_agents_panel_gui.mouseEnterCurrentPage == 1
{
    //sets the slot to 3
    obj_black_market_trips_agents_panel_gui.mouseEnterCurrentSlot = 3;

    //applies agent level to loot odds
    if global.slot3Status == "RECRUITED" &amp;&amp; added == false
    {
        global.slot3AgentLootOdds = global.slot3AgentLootOdds + global.slot3AgentLevel
        added = true;
    }
}

else if obj_black_market_trips_agents_panel_gui.mouseEnterCurrentPage == 2
{
    //sets the slot to 12
    obj_black_market_trips_agents_panel_gui.mouseEnterCurrentSlot = 3;

    //applies agent level to loot odds
    if global.slot12Status == "RECRUITED" &amp;&amp; added == false
    {
        global.slot12AgentLootOdds = global.slot12AgentLootOdds + global.slot12AgentLevel
        added = true;
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="6" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Script Recruited or Equipped 3 &amp; 12 Slots
if obj_black_market_trips_agents_panel_gui.mouseEnterCurrentPage == 1
{
    //if the current slot is empty and is clicked, purchase slot
    if global.slot3Status == "EMPTY" &amp;&amp; global.moneyCount &gt; global.slotPrice
    {
        global.moneyCount -= global.slotPrice;
        scr_GenerateEmployee();
    }
    
    else if global.slot3Status == "EMPTY" &amp;&amp; global.moneyCountMillion &gt; 0
    {
        global.moneyCountMillion -= 1;
        global.moneyCount += 1000000;
        global.moneyCount -= global.slotPrice;
        scr_GenerateEmployee();   
    }

    //if the current slot is recruited OR equipped then 
    if global.slot3Status == "RECRUITED" ||
       global.slot3Status == "EQUIPPED"
    {
            count += 1;

            if count &gt; 1
            {
                count = -1;
            }

            if count == 0
            {
                global.slot3Status = "RECRUITED"
                image_index = 0;
            }

            else if count == 1
            {
                global.slot3Status = "EQUIPPED"
                image_index = 1;
                count = -1;
            }
    }
}

else if obj_black_market_trips_agents_panel_gui.mouseEnterCurrentPage == 2
{
    //if the current slot is empty and is clicked, purchase slot
    if global.slot12Status == "EMPTY" &amp;&amp; global.moneyCount &gt; global.slotPrice
    {
        global.moneyCount -= global.slotPrice;
        scr_GenerateEmployee();
    }
    
    else if global.slot12Status == "EMPTY" &amp;&amp; global.moneyCountMillion &gt; 0
    {
        global.moneyCountMillion -= 1;
        global.moneyCount += 1000000;
        global.moneyCount -= global.slotPrice;
        scr_GenerateEmployee();   
    }

    //if the current slot is recruited OR equipped then 
    if global.slot12Status == "RECRUITED" ||
       global.slot12Status == "EQUIPPED"
    {
            count += 1;

            if count &gt; 1
            {
                count = -1;
            }

            if count == 0
            {
                global.slot12Status = "RECRUITED"
                image_index = 0;
            }

            else if count == 1
            {
                global.slot12Status = "EQUIPPED"
                image_index = 1;
                count = -1;
            }
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
