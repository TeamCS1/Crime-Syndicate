            <string>//if the current tab is not the shop menu
if obj_black_market_shop_gui_upper_piece.currentPage != 0
{
    with obj_black_market_slots
    {
        instance_destroy();
    }
    
    with obj_make_inventory
    {
        instance_destroy();
    }
    
    obj_black_market_shop_gui_upper_piece.currentPage = 0;
    
    if !instance_exists(obj_make_inventory)
    {
        instance_create(x,y,obj_make_inventory);
    }
}

