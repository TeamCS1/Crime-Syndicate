          <argument>
            <kind>1</kind>
            <string>//JOB 3 and 8
if global.newYorkOnJob == "list1" &amp;&amp; global.currentPlayerLevel &gt;= 4
{
    if global.staminaCount &gt;= 5 &amp;&amp; !instance_exists(objLootWindow)
    {
        global.moneyCount += 4000;
        global.currentXP += 7;
        global.staminaCount -= 5;
        global.jobThreeBarNewYork += 2;
        global.jobsCompleted += 1;
        scr_JobPanelJobLootChances();
        
        //If the bar is less than to full and the rank is not S, give completion
        if global.jobThreeBarNewYork &lt; 100 &amp;&amp; global.jobThreeBarRankNewYork != 6
        {
            global.newYorkCompletion += 0.025;
        }
        
        //Gives the final amount when maxed out fully.
        if global.jobThreeBarNewYork == 100 &amp;&amp; global.jobThreeBarRankNewYork == 6
        {
            global.newYorkCompletion += 2.5;
        }
    }
}

if global.newYorkOnJob == "list2" &amp;&amp; global.currentPlayerLevel &gt;= 14    //on page 2 and player level is at or higher than 14
{
    if global.staminaCount &gt;= 24 &amp;&amp; !instance_exists(objLootWindow)
    {
        global.moneyCount += 55000;
        global.currentXP += 36;
        global.staminaCount -= 24;
        global.jobEightBarNewYork += 2;
        global.jobsCompleted += 1;
        scr_JobPanelJobLootChances();
        
        //If the bar is less than to full and the rank is not S, give completion
        if global.jobEightBarNewYork &lt; 100 &amp;&amp; global.jobEightBarRankNewYork != 6
        {
            global.newYorkCompletion += 0.025;
        }
        
        //Gives the final amount when maxed out fully.
        if global.jobEightBarNewYork == 100 &amp;&amp; global.jobEightBarRankNewYork == 6
        {
            global.newYorkCompletion += 2.5;
        }
    }
}
</string>
          </argument>
