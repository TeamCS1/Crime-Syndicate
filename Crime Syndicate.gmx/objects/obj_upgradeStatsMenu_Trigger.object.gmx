            <string>if !instance_exists(obj_upgradeStatsMenuGUI)
{
    //create menu
    instance_create(18,23,obj_upgradeStatsMenuGUI);
    scr_log_message("CREATE: obj_upgradeStatsMenuGUI");
    show_debug_message("CREATE: obj_upgradeStatsMenuGUI");

    //create menu objects
    instance_create(43,993,obj_close_function);
    scr_log_message("CREATE: obj_close_function");
    show_debug_message("CREATE: obj_close_function");

    instance_create(43,993,obj_close_function_x);   //NEED BOTH
    scr_log_message("CREATE: obj_close_function_x");
    show_debug_message("CREATE: obj_close_function_x");
    
    instance_create(x,y,obj_health_button);
    scr_log_message("CREATE: obj_health_button");
    show_debug_message("CREATE: obj_health_button");

    instance_create(x,y,obj_health_regen_button);
    scr_log_message("CREATE: obj_health_regen_button");
    show_debug_message("CREATE: obj_health_regen_button");
    
    instance_create(x,y,obj_stamina_button);
    scr_log_message("CREATE: obj_stamina_button");
    show_debug_message("CREATE: obj_stamina_button");
    
    instance_create(x,y,obj_stamina_regen_button);
    scr_log_message("CREATE: obj_stamina_regen_button");
    show_debug_message("CREATE: obj_stamina_regen_button");
    
    instance_create(x,y,obj_attack_damage_button);
    scr_log_message("CREATE: obj_attack_damage_button");
    show_debug_message("CREATE: obj_attack_damage_button");
    
    instance_create(x,y,obj_defence_protection_button);
    scr_log_message("CREATE: obj_defence_protection_button");
    show_debug_message("CREATE: obj_defence_protection_button");

    //disallow changing of screens while menu open
    if room == rm_prologue_world_map || room == rm_city_bosses_battle_visualiser  //is new york
    {
        with obj_worldMapNewYorkControl
        {
            instance_destroy();
            scr_log_message("DESTROY: obj_worldMapNewYorkControl");
            show_debug_message("DESTROY: obj_worldMapNewYorkControl");
        }
    }
    
    else if room == rm_world_map_chicago || room == rm_city_bosses_battle_visualiser    //is chicago
    {
        with obj_worldMapChicagoControl
        {
            instance_destroy();
            scr_log_message("DESTROY: obj_worldMapChicagoControl");
            show_debug_message("DESTROY: obj_worldMapChicagoControl");
        }
    }
    
    else if room == rm_world_map_london || room == rm_city_bosses_battle_visualiser    //is london
    {
        with obj_worldMapLondonControl
        {
            instance_destroy();
            scr_log_message("DESTROY: obj_worldMapLondonControl");
            show_debug_message("DESTROY: obj_worldMapLondonControl");
        }
    }
    
    else if room == rm_world_map_las_vegas || room == rm_city_bosses_battle_visualiser    //is las vegas
    {
        with obj_worldMapLasVegasControl
        {
            instance_destroy();
            scr_log_message("DESTROY: obj_worldMapLasVegasControl");
            show_debug_message("DESTROY: obj_worldMapLasVegasControl");
        }
    }
    
    //New York
    if instance_exists(obj_JobListButtons1NewYork)
    {
        with obj_JobListButtons1NewYork
        {
            x -= 1000;
        }
        
        with obj_JobListButtons2NewYork
        {
            x -= 1000;
        }

        
        with obj_city_bosses_button_new_york
        {
            x -= 1000;
        }
    }
    
    //Chicago
    if instance_exists(obj_JobListButtons1Chicago)
    {
        with obj_JobListButtons1Chicago
        {
            x -= 1000;
        }
        
        with obj_JobListButtons2Chicago
        {
            x -= 1000;
        }

        
        with obj_city_bosses_button_CHICAGO
        {
            x -= 1000;
        }
    }
    
    //London
    if instance_exists(obj_JobListButtons1London)
    {
        with obj_JobListButtons1London
        {
            x -= 1000;
        }
        
        with obj_JobListButtons2London
        {
            x -= 1000;
        }

        
        with obj_city_bosses_button_LONDON
        {
            x -= 1000;
        }
    }

    //Las Vegas
    if instance_exists(obj_JobListButtons1LasVegas)
    {
        with obj_JobListButtons1LasVegas
        {
            x -= 1000;
        }
        
        with obj_JobListButtons2LasVegas
        {
            x -= 1000;
        }

        
        with obj_city_bosses_button_LAS_VEGAS
        {
            x -= 1000;
        }
    }
}
