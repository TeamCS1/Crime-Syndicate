        <arguments>
          <argument>
            <kind>1</kind>
            <string>global.loading_game_data += amount;

if global.loading_game_data &gt;= 100
{
    global.loading_game_data = 100
    instance_destroy()
    
    room_goto(rm_main_menu)
}

if global.loading_game_data &gt;= 0 &amp;&amp; global.loading_game_data &lt; 1.5
{
    amount = 0.01;
    gameDataString = "\\Adjusting Resolution"; 
}

if global.loading_game_data &gt;= 1.6 &amp;&amp; global.loading_game_data &lt; 30
{
    amount = 0.40;
    gameDataString = "\\Loading Small Textures";
}

else if global.loading_game_data &gt; 31 &amp;&amp; global.loading_game_data &lt; 45
{
    amount = 0.45;
    gameDataString = "\\Loading Trophy Profiles";
}

else if global.loading_game_data &gt; 46 &amp;&amp; global.loading_game_data &lt; 69
{
    amount = 0.45;
    gameDataString = "\\Applying Seasonal Updates";
}

else if global.loading_game_data &gt; 70 &amp;&amp; global.loading_game_data &lt; 90
{
    amount = 0.30;
    gameDataString = "\\Verifying Game Integrity";
    
}

else if global.loading_game_data &gt; 91 &amp;&amp; global.loading_game_data &lt; 100
{
    amount = 0.45;
    gameDataString = "\\Finalizing";
}

if global.loading_game_data &gt;= 99
    {
        scr_log_message(scr_DebugDate() + string("Verifying Game Integrity - SUCCESS"));
    }

</string>
          </argument>
