            <string>if global.lasVegasOnJob == "list1" &amp;&amp; global.currentPlayerLevel &gt;= 48
{
    if global.staminaCount &gt;= 23 &amp;&amp; !instance_exists(objLootWindow)   
    {
        global.moneyCount += 14000000;
        global.currentXP += 53
        global.staminaCount -= 23
        
        //If the bar is less than to full and the rank is not S, give completion
        if global.jobThreeBarLasVegas &lt; 100 &amp;&amp; global.jobThreeBarRankLasVegas &lt; 6
        {
            global.lasVegasCompletion += 0.025
        }
        
        //Gives the final amount when maxed out fully.
        if global.jobThreeBarLasVegas == 100 &amp;&amp; global.jobThreeBarRankLasVegas == 6
        {
            global.lasVegasCompletion += 2.5
        }
        
        global.jobThreeBarLasVegas += 2
        global.jobsCompleted += 1;
        scr_JobPanelJobLootChances();
    }
}

if global.lasVegasOnJob == "list2" &amp;&amp; global.currentPlayerLevel &gt;= 58
{
    if global.staminaCount &gt;= 54 &amp;&amp; !instance_exists(objLootWindow)
    {
        global.moneyCount += 31000000;
        global.currentXP += 106
        global.staminaCount -= 54
        
