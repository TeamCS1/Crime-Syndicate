    <event eventtype="6" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>toDraw = true;
alpha = 1.0;
beginCountdown = false;
tripStartedSuccessfully = false;

//Calculate Trip prices
calculation = 0;
calculation = (global.rentCostSlotsTotals + global.agencyTotalFeeEquippedFinalise + global.distanceFee);

if global.rentCostSlotsTotals &gt;= 25000 &amp;&amp; global.agencyTotalEquipped &gt;= 1 &amp;&amp; obj_black_market_trips_finalise.loadoutIsTicked == true &amp;&amp; obj_black_market_trips_finalise.AgencyIsTicked == true &amp;&amp; scr_deduct_money(calculation)
{

    tripStartedSuccessfully = true;
    show_debug_message("Taken out: " + string(calculation))


    //Which trip to start
    if global.tripOneActive == false
    {
        
        if !instance_exists(obj_black_market_trips_finalise_manager_menu)
        {
            instance_create(x,y,obj_black_market_trips_finalise_manager_menu);
            
            //bring menu to focus
            obj_black_market_trips_finalise_manager_menu.x = 1121;
            obj_black_market_trips_finalise_manager_menu.y = 249;
        }
    
        if global.selectedDestination == "Bristol"
        {
            global.tripOneActive = true;
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Building Supplies";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }
        
        else if global.selectedDestination == "Peterborough"
        {
            global.tripOneActive = true;
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Metals and Wood";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }
        
        else if global.selectedDestination == "Sheffield"
        {
            global.tripOneActive = true;
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Metals and Wood";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }
        
        else if global.selectedDestination == "Leeds"
        {
            global.tripOneActive = true;
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Gears and Plans";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }
        
        else if global.selectedDestination == "Birmingham"
        {
            global.tripOneActive = true;        
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Technical Electronics and Plans";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }
        
        else if global.selectedDestination == "Liverpool"
        {
            global.tripOneActive = true;
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Powders and Plans";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }
        
        else if global.selectedDestination == "Newcastle"
        {
            global.tripOneActive = true;
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Ores and Metals";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }
        
        else if global.selectedDestination == "Manchester"
        {
            global.tripOneActive = true;
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Fabrics and Plans";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }
        
        else if global.selectedDestination == "London"
        {
            global.tripOneActive = true;
            obj_black_market_trips_finalise_manager_menu.toDraw = true;
            obj_black_market_trips_finalise_manager_menu.totalSeconds = 60;
            obj_black_market_trips_finalise_manager_menu.resourcesType = "Powders, Fabrics and Plans";
            obj_black_market_trips_finalise_manager_menu.xpType = "100";
            obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - In Progress";
        }                     
    } 
}

//error catcher
else
{
    //check what is missing to activate trip
    if global.rentCostSlotsTotals &lt;= 0
    {
        transportType = "You must select at least one Transport Type to proceed.";       
    } 
    
    else
    {
        transportType = "";
    }
    
    if global.agencyTotalEquipped &lt;= 0
    {
        agencyTotals = "#You must select at least one Employee to proceed.";       
    } 
    
    else
    {
        agencyTotals = "";
    }
    
    if global.moneyCount &lt;= calculation
    {
        funds = "#Insufficient funds for chosen trip.";       
    } 
    
    else
    {
        funds = "";
    }   
            
}

alarm[0] = room_speed * 1;
window_set_cursor(cr_default);

</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>
//When closing the menu
if instance_exists(obj_black_market_trips_finalise) &amp;&amp; tripStartedSuccessfully == true
{
    with obj_black_market_trips_finalise
    {
        instance_destroy();
    }
    
    with obj_black_market_trips_finalise_start_button
    {
        instance_destroy();
    }
    
    with obj_black_market_trips_finalise_cancel_button
    {
        instance_destroy();
    }
    
    scr_DestinationsCreateManageTrips(); 
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_font(ft_black_market_heading)
draw_set_color(c_black)
scr_center_text_on_button("Confirm",0)

if toDraw == true
{
    draw_set_alpha(alpha);
    draw_rectangle_colour(760,300,760 + 685, 300 + 90,customCol, customCol,customCol,customCol,0) 
    draw_set_font(ft_properties);
    draw_set_color(c_black);
    draw_text(760,310,string(transportType) + string(agencyTotals) + string(funds));
    draw_set_alpha(1.0);
} 
if beginCountdown == true
{
    alpha -= 0.01;
}

if alpha &lt; 0
{
    alpha = 0;
}

                   
</string>
          </argument>
        </arguments>
      </action>
    </event>
