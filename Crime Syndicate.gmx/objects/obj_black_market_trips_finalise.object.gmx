        <arguments>
          <argument>
            <kind>1</kind>
            <string>x = 1121;
y = 249;

calculateCosts = 0;
calculateCosts = (global.rentCostSlotsTotals + global.agencyTotalFeeEquippedFinalise + global.distanceFee)

if global.rentCostSlotsTotals &lt;= 0 
{
    customCol = c_red;
}

else

{
    customCol = c_black;
}

if global.agencyTotalFeeEquippedFinalise &lt;= 0 
{
    customCol2 = c_red;
}

else

{
    customCol2 = c_black;
}
</string>
