        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_self();
draw_set_font(ft_properties);
draw_set_color(c_black);
draw_text_ext(x + 50,y + 100,string("Send your Agents to: ") + string(global.selectedDestination) + string("?"),30,400);
draw_text(x+50,y+150,"Grand Total Cost: $" + string(calculateCosts));
draw_text(x+50,y+230,"Final Confirmation");

//Body
draw_text(x+50,y+270,"Confirm Trips Loadout");
draw_text(x+50,y+317,"Confirm Agents Panel");
draw_text(x+50,y+355,"Distance Fee: $" + string(global.distanceFee));
draw_text_ext(x+50,y+398, "Transport Rent Cost: $" + string(scr_number_sep(global.rentCostSlotsTotals,",",3)),30,400);
draw_set_color(c_black);
draw_text_ext(x + 50,y + 445, "Agents Fee: $" + string(scr_number_sep(global.agencyTotalFeeEquippedFinalise,",",3)),30,400);
draw_text(x+50,y+485,"Success Rate Chance: 100%");
draw_text(x+50,y+530,"Estimated Flight Time: 1 Minute(s)");

if loadoutIsTicked == false
{
    draw_sprite(spr_tickboxes_black_market,0,x + 518,y + 268);
}

else if loadoutIsTicked == true
{
    isActive = true;
    draw_sprite(spr_tickboxes_black_market,1,x + 518,y + 268);
    
}

if AgencyIsTicked == false
{
    draw_sprite(spr_tickboxes_black_market,0,x + 518,y + 313);
}

else if AgencyIsTicked == true
{
    isActive = true;
    draw_sprite(spr_tickboxes_black_market,1,x + 518,y + 313);
       
}
</string>
