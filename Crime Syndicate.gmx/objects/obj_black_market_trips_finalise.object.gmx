          <argument>
            <kind>1</kind>
            <string>//Sets window location
x = 1121;
y = 249;

//init variables
loadoutIsTicked = false;
AgencyIsTicked = false;
customCol = c_black;
customCol2 = c_black;
isActive = true;

//Create the buttons
if !instance_exists(obj_black_market_trips_finalise_start_button)
{
    instance_create(x,y,obj_black_market_trips_finalise_start_button);
}

if !instance_exists(obj_black_market_trips_finalise_cancel_button)
{
    instance_create(x,y,obj_black_market_trips_finalise_cancel_button);
}

