        {
            instance_destroy();
            show_debug_message("DESTROY: obj_city_bosses_pop_up_box")
        }
    }

    //Checks what City you're in and destroys that City active job instances
    if global.currentCity == "LAS_VEGAS"
    {
        if instance_exists(obj_lasVegasJobOneBar)
        {
            with obj_lasVegasJobOneBar
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_lasVegasJobTwoBar)
        {
            with obj_lasVegasJobTwoBar
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_lasVegasJobThreeBar)
        {
            with obj_lasVegasJobThreeBar
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_lasVegasJobFourBar)
        {
            with obj_lasVegasJobFourBar
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_lasVegasJobFiveBar)
        {
            with obj_lasVegasJobFiveBar
            {
                instance_destroy();
            }
        }

        //---
        
        if instance_exists(obj_TRIGGER_LAS_VEGAS_DO_JOB1)
        {
            with obj_TRIGGER_LAS_VEGAS_DO_JOB1
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_TRIGGER_LAS_VEGAS_DO_JOB2)
        {
            with obj_TRIGGER_LAS_VEGAS_DO_JOB2
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_TRIGGER_LAS_VEGAS_DO_JOB3)
        {
            with obj_TRIGGER_LAS_VEGAS_DO_JOB3
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_TRIGGER_LAS_VEGAS_DO_JOB4)
        {
            with obj_TRIGGER_LAS_VEGAS_DO_JOB4
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_TRIGGER_LAS_VEGAS_DO_JOB5)
        {
            with obj_TRIGGER_LAS_VEGAS_DO_JOB5
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_worldMapLasVegasControl)
        {
            with obj_worldMapLasVegasControl
            {
                instance_destroy();
            }
        }
    }

    //Removes the Button after transition to Battle Screen
    if instance_exists(obj_city_bosses_tier_one_button)
    {
        with obj_city_bosses_tier_one_button
        {
            x -= 1000
        }
    }
    
    //Removes the Button after transition to Battle Screen
    if instance_exists(obj_city_bosses_tier_two_button)
    {
        with obj_city_bosses_tier_two_button
        {
            x -= 1000
        }
    }
    
    //Removes the Button after transition to Battle Screen
    if instance_exists(obj_city_bosses_tier_three_button)
    {
        with obj_city_bosses_tier_three_button
        {
            x -= 1000
        }
    }
    
    global.lasVegasCityBossTierOneInBattle = true;
}
