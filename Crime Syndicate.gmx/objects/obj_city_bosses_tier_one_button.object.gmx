        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Write Tier 1 Info &amp; Postphone Option
if global.currentCity == "NEW_YORK"
{
    if global.newYorkCityBossTierOneInBattle == false &amp;&amp; global.newYorkCityBossTierOneIsDefeated == false
    {
        //If not in battle and not defeated
        global.cityBossesDifficulty = "BEGINNER"

        global.cityBossATK = 25
        global.cityBossDEF = 25
        global.cityBossAILevel = 10

        global.tierOneHasStarted = true;

        ini_open("savedata.ini")

        ini_write_real("citybosses", "tierOneHasStarted", global.tierOneHasStarted);

        ini_write_real("citybosses", "newYorkCityBossTierOneInBattle", global.newYorkCityBossTierOneInBattle);

        ini_write_real("citybosses", "currentNewYorkCityBossBarTierOne", global.currentNewYorkCityBossBarTierOne);
        ini_write_real("citybosses", "currentNewYorkCityBossBarTierOneMaximum", global.currentNewYorkCityBossBarTierOneMaximum);
        ini_write_real("citybosses", "currentNewYorkCityBossBarTierOneCount", global.currentNewYorkCityBossBarTierOneCount);
        ini_write_real("citybosses", "currentNewYorkCityBossTierOneXP", global.currentNewYorkCityBossTierOneXP);
        ini_write_real("citybosses", "currentNewYorkCityBossTierOneCash", global.currentNewYorkCityBossTierOneCash);

        show_debug_message("WRITE: tierOneHasStarted, TRUE")

        ini_close();
    }

    else if global.newYorkCityBossTierOneInBattle == true &amp;&amp; global.newYorkCityBossTierOneIsDefeated == false
    {
        //If in battle and not defeated!  Post-phone option here.
    }
}

//---

else if global.currentCity == "CHICAGO"
{
    if global.chicagoCityBossTierOneInBattle == false &amp;&amp; global.chicagoCityBossTierOneIsDefeated == false
    {
        //If not in battle and not defeated
        global.cityBossesDifficulty = "BEGINNER"

        global.cityBossATK = 50
        global.cityBossDEF = 50
        global.cityBossAILevel = 40

        ini_open("savedata.ini")

        ini_write_real("citybosses", "chicagoCityBossTierOneInBattle", global.chicagoCityBossTierOneInBattle);

        ini_write_real("citybosses", "currentChicagoCityBossBarTierOne", global.currentChicagoCityBossBarTierOne);
        ini_write_real("citybosses", "currentChicagoCityBossBarTierOneMaximum", global.currentChicagoCityBossBarTierOneMaximum);
