        ini_write_real("citybosses", "currentChicagoCityBossTierOneXP", global.currentChicagoCityBossTierOneXP);
        ini_write_real("citybosses", "currentChicagoCityBossTierOneCash", global.currentChicagoCityBossTierOneCash);

        ini_close();
    }

    else if global.chicagoCityBossTierOneInBattle == true &amp;&amp; global.chicagoCityBossTierOneIsDefeated == false
    {
        //If in battle and not defeated!  Post-phone option here.
    }
}

//---

else if global.currentCity == "LONDON"
{
    if global.londonCityBossTierOneInBattle == false &amp;&amp; global.londonCityBossTierOneIsDefeated == false
    {
        //If not in battle and not defeated
        global.cityBossesDifficulty = "BEGINNER"

        global.cityBossATK = 100
