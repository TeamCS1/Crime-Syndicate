else if global.currentPlayerLevel == 499       //level to check
{
    global.currentXPNeededToLevelUp = 12000      //amount needed to level up
        
    if global.currentXP &gt;= global.currentXPNeededToLevelUp  //if xp has been met
    {
        scr_LevelUpAdditioner();
    }
}

else if global.currentPlayerLevel == 500       //level to check
{
    global.currentXPNeededToLevelUp = 12000      //amount needed to level up
        
    if global.currentXP &gt;= global.currentXPNeededToLevelUp  //if xp has been met
    {
        scr_LevelUpAdditioner();
    }
}

else if global.currentPlayerLevel == 501       //level to check
{
    global.currentXPNeededToLevelUp = 13000      //amount needed to level up
        
    if global.currentXP &gt;= global.currentXPNeededToLevelUp  //if xp has been met
    {
        global.skillPointsRemaining += 5;
        global.currentXP = 0;
        global.staminaCount = global.staminaCountMax;
        global.healthCount = global.healthCountMax;
        global.skillPointsEarned += 5;
        //global.currentPlayerLevel += 1
    }
}
