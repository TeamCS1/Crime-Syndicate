    global.trophiesEarned += 1;
    
    ini_open("profile25.ini")
    ini_write_real("Profile","Icon",2)
    ini_close()
    
    ini_open("savedata.ini")
    ini_write_real("Trophies", "earnedLondonCityBossDefeatedT3", global.earnedLondonCityBossDefeatedT3)
    ini_write_real("Trophies", "trophiesEarned", global.trophiesEarned);
    ini_close();
    
    show_debug_message("London City Boss Defeated | Trophy Given")
    
    if !instance_exists(obj_draw_trophy_notification)
    {
        instance_create(29,84,obj_draw_trophy_notification)
    }
}


if global.lasVegasCityBossTierThreeIsDefeated == true &amp;&amp; global.earnedLasVegasCityBossDefeatedT3 == false
{
