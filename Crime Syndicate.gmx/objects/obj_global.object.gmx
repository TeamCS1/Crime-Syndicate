    }
}

//The Harbinger Trophy 
if global.cityBossesMult &gt;= 15 &amp;&amp; global.earnedTheHarbinger == false
{
    global.trophyName = "The Harbinger";
    global.trophyGradeText = "Gold";
    global.earnedTheHarbinger = true
    global.trophyGrade = 3;
    global.trophiesEarned += 1;

    ini_open("profile28.ini")
    ini_write_real("Profile", "Icon", 3)
    ini_close()

    ini_open("savedata.ini")
    ini_write_real("Trophies", "earnedTheHarbinger", global.earnedTheHarbinger);
    ini_write_real("Trophies", "trophiesEarned", global.trophiesEarned);
    ini_close();

    show_debug_message("The Harbinger | Trophy Given")

    if !instance_exists(obj_draw_trophy_notification)
    {
        instance_create(29, 84, obj_draw_trophy_notification)
    }
}

