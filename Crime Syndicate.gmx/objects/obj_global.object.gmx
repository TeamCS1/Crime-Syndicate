        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Stamina 

if global.staminaCount &lt; 0
{
    global.staminaCount = 0;
}

if global.staminaCount &lt; global.staminaCountMax
{
    global.staminaCount += global.staminaInceaseRate / 60    //idle stamina increase
}

if global.staminaCount &gt;= global.staminaCountMax
{
    floor(global.staminaCount = global.staminaCountMax);
}


</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Health

if global.healthCount &lt; 0
{
    global.healthCount = 0;
}

if global.healthCount &lt; global.healthCountMax
{
    global.healthCount += global.healthInceaseRate / 60;    //idle stamina increase
}

if global.healthCount &gt;= global.healthCountMax
{
    floor(global.healthCount = global.healthCountMax);
}

if global.healthCount &lt;= 25 &amp;&amp; showOnce == true
{
    scr_CreateNotification(17,22,"Warning: Health too low &lt; 25, you're in Hospital.");
    global.timesInHospital += 1;
    showOnce = false;
      
}

if global.healthCount &gt; 25
{
    showOnce = true;   
}



</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>/// Top Secret Money Sorting Machine - Tiered System

// Cap to billions directly (2000000000 or more)
if global.moneyCount &gt;= 2000000000 {
    global.moneyCountBillion += 2;
    global.moneyCount = 0;
    global.moneySuffix = "Billion";
}

// Million conversion while in billion tier
if global.moneyCountBillion &gt; 0 {
    if global.moneyCount &gt;= 1000000 {
        global.moneyCountMillion += 1;
        global.moneyCount -= 1000000;
    }
    else if global.moneyCountMillion &gt;= 1000 {
        global.moneyCountBillion += 1;
        global.moneyCountMillion -= 1000;
    }
}

// Safety check to prevent negative money
if global.moneyCount &lt; 0 {
    global.moneyCount = 0;
}

// Edge Case 1: Borrow from billions to refill millions when empty
if global.moneyCountBillion &gt; 1 &amp;&amp; global.moneyCountMillion &lt;= 0 {
    global.moneyCountMillion = 999;
    global.moneyCountBillion -= 1;
    //global.totalPropertiesIncome += 1000000; // Optional bonus?
    show_debug_message("OUTPUT: Edge Case 1 Triggered");
}

// Edge Case 3: If all values depleted, reset suffix
if global.moneyCountBillion &lt;= 0 &amp;&amp; global.moneyCountMillion &lt;= 0 {
    global.moneySuffix = "";
}

