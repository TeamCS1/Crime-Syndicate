    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Init Globals
global.line1Damage = "";
global.line2Damage = "";
global.currentAIBar = global.healthCountMax * 1.3;  //1.3 easy, 1.5 normal, 1.7 hard.
global.currentAIMaximum = global.healthCountMax;
global.currentAICount = global.currentAIMaximum;

///Init locals
backColour = c_gray;
isDead = false;
isRoomRestarted = true;
barHeight = 273;

//returns the name, titles and descriptions of the Hitmen from the script
global.sectionOneName = scr_HitmenNamesReturn(false);
global.sectionOneTitle = scr_HitmenTitlesReturn();
global.sectionOneDesc = scr_HitmenDescReturn();
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Calculate Section 1
randomize();

//Init variables
global.hitmenBounty = 0;
global.hitmenDiffultyChance = 0;
global.hitmenDiffultyChanceText = "Impossible";
global.hitmenXPChance = 0;

//Calculations

//Choose a difficulty, since its section 1 there's only three difficulties
global.hitmenDiffultyChance += irandom_range(1, 3);

if global.hitmenDiffultyChance == 1
{
    global.hitmenDiffultyChanceText = "Peaceful";   
}

else if global.hitmenDiffultyChance == 2
{
    global.hitmenDiffultyChanceText = "Easy";    
}

else if global.hitmenDiffultyChance == 3
{
    global.hitmenDiffultyChanceText = "Normal";    
}

//Based on the difficulties given to us, we need to be generous with xp
//Since there are 0% chance of legendaries, don't bother calculating it.

if global.hitmenDiffultyChance == 1 //Peaceful
{
    global.hitmenXPChance += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 1.2));   
}

else if global.hitmenDiffultyChance == 2 //Easy
{
    global.hitmenXPChance += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 1.5));   
}

else if global.hitmenDiffultyChance == 3 //Normal
{
    global.hitmenXPChance += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 2.0));   
}

//Calculate money
global.currentPlayerLevelUpperBound = irandom_range(global.currentPlayerLevel - 5, global.currentPlayerLevel + 10);
global.hitmenBounty += irandom_range(global.currentPlayerLevel, global.currentPlayerLevelUpperBound * 1.5);
global.hitmenBounty *= global.currentPlayerLevel * global.hitmenDiffultyChance

//CALCULATE AI'S ATK AND DEFENCE DO NOT MOVE
showAttack = false;
global.damageOutputToAI = 0
global.damageOutputToPlayer = 0;

global.AIDefenceProtection = -1;
global.AIAttackDamage = -1;

if global.hitmenDiffultyChance == 1     //is peaceful difficulty
{
    global.AIDefenceProtection += irandom_range(global.defenceProtection - 15, global.defenceProtection - 9);
    global.AIAttackDamage += irandom_range(global.attackDamage - 20, global.attackDamage - 15);   
}

if global.hitmenDiffultyChance == 2     //is easy
{
    global.AIDefenceProtection += irandom_range(global.defenceProtection - 10, global.defenceProtection - 6);
    global.AIAttackDamage += irandom_range(global.attackDamage - 15, global.attackDamage - 15);   
}

if global.hitmenDiffultyChance == 3     //is normal
{
    global.AIDefenceProtection += irandom_range(global.defenceProtection - 7, global.defenceProtection + 2);
    global.AIAttackDamage += irandom_range(global.attackDamage - 6, global.attackDamage + 3);   
}

//Prevents underflows
if global.AIDefenceProtection &lt;= 0
{
    global.AIDefenceProtection = 1;
}

if global.AIAttackDamage &lt;= 0
{
    global.AIAttackDamage = 1;
}

if global.hitmenXPChance &lt;= 0
{
    global.hitmenXPChance = 1;
}

if global.hitmenBounty &lt;= 0
{
    global.hitmenBounty = 1;
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
