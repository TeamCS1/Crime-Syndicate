      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Draw Section 1 Only
draw_set_font(ft_hitmen);
draw_set_colour(c_black);
draw_text(x + 105,y + 62,string(global.sectionOneName)+ string(global.sectionOneTitle));
draw_text_ext(x + 27,y + 216,string(global.sectionOneDesc),18,680);
draw_text(x+205,y + 119, "$" + string(scr_number_sep(global.hitmenBounty,",",3)) + " +" + string(global.hitmenXPChance) + "XP")
draw_text(x+215,y + 172, string(global.hitmenDiffultyChanceText));

//Player
draw_text(x + 565,y + 62, string(global.attackDamage));
draw_text(x + 590,y + 92, string(global.defenceProtection));

//AI
draw_text(x + 592,y + 139, string(global.AIAttackDamage));
draw_text(x + 615,y + 169, string(global.AIDefenceProtection));
</string>
          </argument>
        </arguments>
      </action>
