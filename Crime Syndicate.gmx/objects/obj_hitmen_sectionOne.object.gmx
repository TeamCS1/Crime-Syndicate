    <event eventtype="6" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Player Attack Damage Calculation

//local event variables | Only need to be declared here, nowhere else.

showAttack = true
playerHasAttacked = true
global.showSectionOne = true;
global.showSectionTwo = false;
global.showSectionThree = false;

global.damageOutputToAI = 0     //resets Player damage output to 0, before performing re-calculation.

global.line1Damage = "";    //clears history
global.line2Damage = "";    //clears history

if global.hitmenDiffultyChanceText == "Peaceful"
{
    global.damageOutputToAI += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtection); 
    global.damageOutputToAI *= 3
}

else if global.hitmenDiffultyChanceText == "Easy"
{
    global.damageOutputToAI += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtection); 
    global.damageOutputToAI *= 2
}

else if global.hitmenDiffultyChanceText == "Normal"
{
    global.damageOutputToAI += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtection); 
    global.damageOutputToAI *= 1
}

else if global.hitmenDiffultyChanceText == "Hard"
{
    global.damageOutputToAI += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtection); 
    global.damageOutputToAI *= 0.5
}

else if global.hitmenDiffultyChanceText == "Ex-Hard"
{
    global.damageOutputToAI += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtection); 
    global.damageOutputToAI *= 0.3
}

if global.damageOutputToAI &lt;= 0
{
    global.damageOutputToAI = 1
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Enemy Attack Damage Calculation

global.damageOutputToPlayer = 0;        //resets AI damage output to 0, before performing re-calculation.

if global.hitmenDiffultyChanceText == "Peaceful"
{
    global.damageOutputToPlayer += irandom_range(global.currentPlayerLevel, global.AIAttackDamage - global.defenceProtection); 
    global.damageOutputToPlayer *= 0.35
}

else if global.hitmenDiffultyChanceText == "Easy"
{
    global.damageOutputToPlayer += irandom_range(global.currentPlayerLevel, global.AIAttackDamage - global.defenceProtection); 
    global.damageOutputToPlayer *= 0.50
}

else if global.hitmenDiffultyChanceText == "Normal"
{
    global.damageOutputToPlayer += irandom_range(global.currentPlayerLevel, global.AIAttackDamage - global.defenceProtection); 
    global.damageOutputToPlayer *= 1.00
}

if global.damageOutputToPlayer &lt;= 0
{
    global.damageOutputToPlayer = 1
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Update Attack History To Player
if !instance_exists(obj_createPersonalMedic)
{
    if playerHasAttacked == true &amp;&amp; global.healthCount &gt; 25
    {
        global.line1Damage = global.damageOutputToAI
        global.currentAICount -= global.damageOutputToAI
        global.healthCount -= global.damageOutputToPlayer
        
        backColour = c_orange;
        alarm[0] = room_speed * 0.5;
    }
    
    //UPDATE ATTACK HISTORY AI
    
    if playerHasAttacked == true
    {
        global.line2Damage = global.damageOutputToPlayer;
    }
}

//Reset notifs state
obj_global.showOnce = true;
</string>
          </argument>
        </arguments>
      </action>
    </event>
