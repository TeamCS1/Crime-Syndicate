            <string>itemEntered = id; 

with itemEntered
{
     obj_properties_menu_pointer_bmh.newYorkPropertySelection = itemEntered.name;
     //global.newYorkPropertySelection = itemEntered.name; 
     obj_properties_menu_pointer_bmh.propertyDescription = itemEntered.desc;
     obj_properties_menu_pointer_bmh.propertyCost = itemEntered.price;
     obj_properties_menu_pointer_bmh.propertyStorage = itemEntered.storage;
     obj_properties_menu_pointer_bmh.propertyQuantity = itemEntered.quantity;
}
