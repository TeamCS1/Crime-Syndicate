        <arguments>
          <argument>
            <kind>1</kind>
            <string>if stringType == "Collect"
{
    scr_log_message(scr_DebugDate() + "Function Call: scr_CreateTripsLootCities");
    show_debug_message("Function Call: scr_CreateTripsLootCities");
    //drop the loot!
    scr_CreateTripsLootCities();
    
    scr_log_message(scr_DebugDate() + "Function Call: scr_CreateTripsPickers");
    show_debug_message("Function Call: scr_CreateTripsPickers");
    scr_CreateTripsPickers();
    
    obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - Awaiting Start...";
    
    //here goes rewards
    global.agencyLevelHubPoints += 525;
    global.currentXP += 100;
    
    //update button
    HasCollected = true;
    stringType = "Close";
    
    //Reset Trips state
    global.selectedDestination = "Nowhere";
    global.tripOneActive = false;
    obj_black_market_trips_finalise_manager_menu.tripStatus = "Trip 1 - Not Started";
    obj_black_market_trips_finalise_manager_menu.toDraw = true;
    obj_black_market_trips_finalise_manager_menu.totalSeconds = 0;
    obj_black_market_trips_finalise_manager_menu.resourcesType = "None";
    obj_black_market_trips_finalise_manager_menu.xpType = "0"; 
    
    //destroy itself
    instance_destroy();
}





</string>
          </argument>
        </arguments>
      </action>
