            <string>///City Bosses Draw Event Chicago

//Only draws completion when not in upgrade stats menu
if !instance_exists(obj_upgradeStatsMenuGUI)
{
    if global.currentCity == "CHICAGO"
    {
        //Main Heading
        draw_set_color(c_white)

        draw_set_font(ft_job_panel_heading)
        draw_text(34, 27, "City Bosses Panel")

        //Draw Tier 1 City Boss Healthbar
        global.currentChicagoCityBossBarTierOne = (global.currentChicagoCityBossBarTierOneCount / global.currentChicagoCityBossBarTierOneMaximum) * 100;

        if global.chicagoCityBossTierOneIsDefeated == false &amp;&amp; global.chicagoCityBossTierOneInBattle == false
        {
            draw_healthbar(x1, y1 + 20, x2, y2 + 20, global.currentChicagoCityBossBarTierOne, global.backColour, c_red, c_purple, 0, true, true)

            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_white)

            draw_text(50, 245 + 20, "City Boss Health: " + string(scr_number_sep(global.currentChicagoCityBossBarTierOneCount, ",", 3)) + " / " + string(scr_number_sep(global.currentChicagoCityBossBarTierOneMaximum, ",", 3)))
            draw_text(44, 355, "Completion Bonus: " + string(scr_number_sep(global.currentChicagoCityBossTierOneXP, ",", 3)) + "XP | $" + string(scr_number_sep(global.currentChicagoCityBossTierOneCash, ",", 3)))

            draw_set_font(ft_city_bosses_heading)
