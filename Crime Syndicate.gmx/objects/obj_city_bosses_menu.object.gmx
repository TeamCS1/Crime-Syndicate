        else if global.lasVegasCityBossTierOneIsDefeated == true &amp;&amp; global.lasVegasCityBossTierOneInBattle == false
        {
            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_gray)

            draw_text(47, 300, "You have Defeated this City Boss, well done.")
        }

        //lasVegas City Boss ATK &amp; DEF Tier 1
        draw_set_font(ft_city_bosses_body)
        draw_set_color(c_white)

        draw_text(805, 355, + string(scr_number_sep(25, ",", 3)) + "ATK")
        draw_text(930, 355, + string(scr_number_sep(25, ",", 3)) + "DEF")

        //Start of Tier 2

        //Draw Tier 2 City Boss Healthbar
        global.currentLasVegasCityBossBarTierTwo = (global.currentLasVegasCityBossBarTierTwoCount / global.currentLasVegasCityBossBarTierTwoMaximum) * 100;

        if global.lasVegasCityBossTierTwoIsDefeated == false &amp;&amp; global.lasVegasCityBossTierTwoInBattle == false
        {
            draw_healthbar(x1, 491, x2, 491 + 35, global.currentLasVegasCityBossBarTierTwo, global.backColour, c_red, c_purple, 0, true, true)

            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_white)

            draw_text(50, 495, "City Boss Health: " + string(scr_number_sep(global.currentLasVegasCityBossBarTierTwoCount, ",", 3)) + " / " + string(scr_number_sep(global.currentLasVegasCityBossBarTierTwoMaximum, ",", 3)))
            draw_text(44, 590, "Completion Bonus: " + string(scr_number_sep(global.currentLasVegasCityBossTierTwoXP, ",", 3)) + "XP | $" + string(scr_number_sep(global.currentLasVegasCityBossTierTwoCash, ",", 3)) + " | Unlocks: Moscow")

            draw_set_font(ft_city_bosses_heading)
            draw_set_color(c_white)

            draw_text_ext(40, 425, "Tier 2 City Boss - Moe Dalitz (Intermediate)", 25, 800)
        }

        else if global.lasVegasCityBossTierTwoIsDefeated == true &amp;&amp; global.lasVegasCityBossTierTwoInBattle == false
        {
            draw_set_font(ft_city_bosses_heading)
            draw_set_color(c_gray)

            draw_text_ext(40, 425, "Tier 2 City Boss - Moe Dalitz (Intermediate)", 25, 800)
        }

        //Checks Player Level - Tier 2 and Defeated Part
        if global.lasVegasCityBossTierTwoIsDefeated == false &amp;&amp; global.lasVegasCityBossTierTwoInBattle == false
        {
            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_orange)
            draw_text(47, 531, "Level 110 City Boss")

            if global.currentPlayerLevel &lt; 110
            {
                draw_set_color(c_red)
                draw_text(260, 531, "REQ: Level 110, you are: Level " + string(global.currentPlayerLevel) + " (Too low!)")
            }

            else
            {
                draw_set_color(c_green)
                draw_text(260, 531, "REQ: Level 110, you are: Level " + string(global.currentPlayerLevel) + " (Suitable)")
            }
        }

        else if global.lasVegasCityBossTierTwoIsDefeated == true &amp;&amp; global.lasVegasCityBossTierTwoInBattle == false
        {
            draw_set_font(ft_city_bosses_body)
