      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///City Bosses Draw Event New York

//Only draws completion when not in upgrade stats menu
if !instance_exists(obj_upgradeStatsMenuGUI)
{
    if global.currentCity == "NEW_YORK"
    {
        //Main Heading
        draw_set_color(c_white)

        draw_set_font(ft_job_panel_heading)
        draw_text(34, 27, "City Bosses Panel")

        if global.newYorkCityBossTierOneIsDefeated == false &amp;&amp; global.newYorkCityBossTierOneInBattle == false
        {
            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_orange)
            draw_text(47, 290, "Level 10 City Boss")

            if global.currentPlayerLevel &lt; 10
            {
                draw_set_color(c_red)
                draw_text(250, 290, "REQ: Level 10, you are: Level " + string(global.currentPlayerLevel) + " (Too low!)")
            }

            else
            {
                draw_set_color(c_green)
                draw_text(250, 290, "REQ: Level 10, you are: Level " + string(global.currentPlayerLevel) + " (Suitable)")
            }
        }

        else if global.newYorkCityBossTierOneIsDefeated == true &amp;&amp; global.newYorkCityBossTierOneInBattle == false
        {
            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_gray)

            draw_text(40, 290, "You have Defeated this City Boss, well done.")
        }

        //Draw Tier 1 City Boss Healthbar

        global.currentNewYorkCityBossBarTierOne = (global.currentNewYorkCityBossBarTierOneCount / global.currentNewYorkCityBossBarTierOneMaximum) * 100;

        if global.newYorkCityBossTierOneIsDefeated == false &amp;&amp; global.newYorkCityBossTierOneInBattle == false
        {
            draw_healthbar(x1, y1, x2, y2, global.currentNewYorkCityBossBarTierOne, global.backColour, c_red, c_purple, 0, true, true)

            draw_set_color(c_white)
            draw_text(50, 245, "City Boss Health: " + string(scr_number_sep(global.currentNewYorkCityBossBarTierOneCount, ",", 3)) + " / " + string(scr_number_sep(global.currentNewYorkCityBossBarTierOneMaximum, ",", 3)))
            draw_text(44, 355, "Completion Bonus: " + string(scr_number_sep(global.currentNewYorkCityBossTierOneXP, ",", 3)) + "XP | $" + string(scr_number_sep(global.currentNewYorkCityBossTierOneCash, ",", 3)))

            draw_set_font(ft_city_bosses_heading)
            draw_set_color(c_white)

            draw_text(40, 200, "Tier 1 - Corrupt NYPD (Beginner)")
        }

        else if global.newYorkCityBossTierOneIsDefeated == true &amp;&amp; global.newYorkCityBossTierOneInBattle == false
        {
            draw_set_font(ft_city_bosses_heading)
            draw_set_color(c_gray)

            draw_text(40, 200, "Tier 1 - Corrupt NYPD (Beginner)")
        }

        draw_set_font(ft_city_bosses_body)
        draw_set_color(c_white)

        //New York City Boss ATK &amp; DEF
        draw_text(805, 355, +string(scr_number_sep(25, ",", 3)) + "ATK")
        draw_text(930, 355, +string(scr_number_sep(25, ",", 3)) + "DEF")

        //Start of Tier 2
        if global.currentCity == "NEW_YORK"
        {
            //Main Heading
            draw_set_color(c_white)

            draw_set_font(ft_job_panel_heading)
            draw_text(34, 27, "City Bosses Panel")

            if global.newYorkCityBossTierTwoIsDefeated == false &amp;&amp; global.newYorkCityBossTierTwoInBattle == false
            {
                draw_set_font(ft_city_bosses_body)
                draw_set_color(c_orange)
                draw_text(47, 531, "Level 20 City Boss")

                if global.currentPlayerLevel &lt; 20
                {
                    draw_set_color(c_red)
                    draw_text(250, 531, "REQ: Level 20, you are: Level " + string(global.currentPlayerLevel) + " (Too low!)")
                }

                else
                {
                    draw_set_color(c_green)
                    draw_text(250, 531, "REQ: Level 20, you are: Level " + string(global.currentPlayerLevel) + " (Suitable)")
                }
            }

            else if global.newYorkCityBossTierTwoIsDefeated == true &amp;&amp; global.newYorkCityBossTierTwoInBattle == false
            {
                draw_set_font(ft_city_bosses_body)
                draw_set_color(c_gray)

                draw_text(40, 525, "You have Defeated this City Boss and have unlocked: Chicago, well done.")
            }

            //Draw Tier 2 City Boss Healthbar

            global.currentNewYorkCityBossBarTierTwo = (global.currentNewYorkCityBossBarTierTwoCount / global.currentNewYorkCityBossBarTierTwoMaximum) * 100;

            if global.newYorkCityBossTierTwoIsDefeated == false &amp;&amp; global.newYorkCityBossTierTwoInBattle == false
            {
                draw_healthbar(x1, 491, x2, 491 + 35, global.currentNewYorkCityBossBarTierTwo, global.backColour, c_red, c_purple, 0, true, true)

                draw_set_font(ft_city_bosses_body)
                draw_set_color(c_white)

                draw_text(50, 495, "City Boss Health: " + string(scr_number_sep(global.currentNewYorkCityBossBarTierTwoCount, ",", 3)) + " / " + string(scr_number_sep(global.currentNewYorkCityBossBarTierTwoMaximum, ",", 3)))
                draw_text(44, 590, "Completion Bonus: " + string(scr_number_sep(global.currentNewYorkCityBossTierTwoXP, ",", 3)) + "XP | $" + string(scr_number_sep(global.currentNewYorkCityBossTierTwoCash, ",", 3)) + " | Unlocks: Chicago")

                draw_set_font(ft_city_bosses_heading)
                draw_set_color(c_white)

                draw_text_ext(40, 425, "Tier 2 - New York City Boss 'Giovanni' (Intermediate)", 30, 800)
            }

            else if global.newYorkCityBossTierTwoIsDefeated == true &amp;&amp; global.newYorkCityBossTierTwoInBattle == false
            {
                draw_set_font(ft_city_bosses_heading)
                draw_set_color(c_gray)

                draw_text_ext(40, 425, "Tier 2 - New York City Boss 'Giovanni' (Intermediate)", 30, 800)
            }

            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_white)

            //New York City Boss ATK &amp; DEF
            draw_text(805, 590, +string(scr_number_sep(45, ",", 3)) + "ATK")
            draw_text(930, 590, +string(scr_number_sep(90, ",", 3)) + "DEF")
        }
        //---

        //Start of new Tier 3
        if global.currentCity == "NEW_YORK"
        {
            //Main Heading
            draw_set_color(c_white)

            draw_set_font(ft_job_panel_heading)
            draw_text(34, 27, "City Bosses Panel")

            if global.newYorkCityBossTierThreeIsDefeated == false &amp;&amp; global.newYorkCityBossTierThreeInBattle == false
            {
                draw_set_font(ft_city_bosses_body)
                draw_set_color(c_orange)
                draw_text(47, 764, "Level 30 City Boss")

                if global.currentPlayerLevel &lt; 30
                {
                    draw_set_color(c_red)
                    draw_text(250, 764, "REQ: Level 30, you are: Level " + string(global.currentPlayerLevel) + " (Too low!)")
                }

                else
                {
                    draw_set_color(c_green)
                    draw_text(250, 764, "REQ: Level 30, you are: Level " + string(global.currentPlayerLevel) + " (Suitable)")
                }
            }

            else if global.newYorkCityBossTierThreeIsDefeated == true &amp;&amp; global.newYorkCityBossTierThreeInBattle == false
            {
                draw_set_font(ft_city_bosses_body)
                draw_set_color(c_gray)

                draw_text(40, 760, "You have Defeated this City Boss, well done.")
            }

            //Draw Tier 3 City Boss Healthbar

            global.currentNewYorkCityBossBarTierThree = (global.currentNewYorkCityBossBarTierThreeCount / global.currentNewYorkCityBossBarTierThreeMaximum) * 100;

            if global.newYorkCityBossTierThreeIsDefeated == false &amp;&amp; global.newYorkCityBossTierThreeInBattle == false
            {
                draw_healthbar(x1, 718, x2, 718 + 35, global.currentNewYorkCityBossBarTierThree, global.backColour, c_red, c_purple, 0, true, true)


                draw_set_font(ft_city_bosses_body)
                draw_set_color(c_white)

                draw_text(50, 722, "City Boss Health: " + string(scr_number_sep(global.currentNewYorkCityBossBarTierThreeCount, ",", 3)) + " / " + string(scr_number_sep(global.currentNewYorkCityBossBarTierThreeMaximum, ",", 3)))
