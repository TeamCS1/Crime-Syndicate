    <event eventtype="2" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Read

//Read data first.
ini_open("savedata.ini")

//NEW YORK
global.tierOneHasStarted = ini_read_real("citybosses","tierOneHasStarted",false)
global.newYorkCityBossTierOneInBattle = ini_read_real("citybosses","newYorkCityBossTierOneInBattle",false)
global.newYorkCityBossTierOneIsDefeated = ini_read_real("citybosses","newYorkCityBossTierOneIsDefeated",false)

global.tierTwoHasStarted = ini_read_real("citybosses","tierTwoHasStarted",false)
global.newYorkCityBossTierTwoInBattle = ini_read_real("citybosses","newYorkCityBossTierTwoInBattle",false)
global.newYorkCityBossTierTwoIsDefeated = ini_read_real("citybosses","newYorkCityBossTierTwoIsDefeated",false)

global.tierThreeHasStarted = ini_read_real("citybosses","tierThreeHasStarted",false)
global.newYorkCityBossTierThreeInBattle = ini_read_real("citybosses","newYorkCityBossTierThreeInBattle",false)
global.newYorkCityBossTierThreeIsDefeated = ini_read_real("citybosses","newYorkCityBossTierThreeIsDefeated",false)

//CHICAGO
global.tierOneHasStartedChicago = ini_read_real("citybosses","tierOneHasStartedChicago",false)
global.chicagoCityBossTierOneInBattle = ini_read_real("citybosses","chicagoCityBossTierOneInBattle",false)
global.chicagoCityBossTierOneIsDefeated = ini_read_real("citybosses","chicagoCityBossTierOneIsDefeated",false)

global.tierTwoHasStartedChicago = ini_read_real("citybosses","tierTwoHasStartedChicago",false)
global.chicagoCityBossTierTwoInBattle = ini_read_real("citybosses","chicagoCityBossTierTwoInBattle",false)
global.chicagoCityBossTierTwoIsDefeated = ini_read_real("citybosses","chicagoCityBossTierTwoIsDefeated",false)

//global.tierThreeHasStarted = ini_read_real("citybosses","tierThreeHasStarted",false)
global.chicagoCityBossTierThreeInBattle = ini_read_real("citybosses","chicagoCityBossTierThreeInBattle",false)
global.chicagoCityBossTierThreeIsDefeated = ini_read_real("citybosses","chicagoCityBossTierThreeIsDefeated",false)

//LONDON
//global.tierOneHasStarted = ini_read_real("citybosses","tierOneHasStarted",false)
global.londonCityBossTierOneInBattle = ini_read_real("citybosses","londonCityBossTierOneInBattle",false)
global.londonCityBossTierOneIsDefeated = ini_read_real("citybosses","londonCityBossTierOneIsDefeated",false)

//global.tierTwoHasStarted = ini_read_real("citybosses","tierTwoHasStarted",false)
global.londonCityBossTierTwoInBattle = ini_read_real("citybosses","londonCityBossTierTwoInBattle",false)
global.londonCityBossTierTwoIsDefeated = ini_read_real("citybosses","londonCityBossTierTwoIsDefeated",false)

//global.tierThreeHasStarted = ini_read_real("citybosses","tierThreeHasStarted",false)
global.londonCityBossTierThreeInBattle = ini_read_real("citybosses","londonCityBossTierThreeInBattle",false)
global.londonCityBossTierThreeIsDefeated = ini_read_real("citybosses","londonCityBossTierThreeIsDefeated",false)

//LAS VEGAS
//global.tierOneHasStarted = ini_read_real("citybosses","tierOneHasStarted",false)
global.lasVegasCityBossTierOneInBattle = ini_read_real("citybosses","lasVegasCityBossTierOneInBattle",false)
global.lasVegasCityBossTierOneIsDefeated = ini_read_real("citybosses","lasVegasCityBossTierOneIsDefeated",false)

//global.tierTwoHasStarted = ini_read_real("citybosses","tierTwoHasStarted",false)
global.lasVegasCityBossTierTwoInBattle = ini_read_real("citybosses","lasVegasCityBossTierTwoInBattle",false)
global.lasVegasCityBossTierTwoIsDefeated = ini_read_real("citybosses","lasVegasCityBossTierTwoIsDefeated",false)

//global.tierThreeHasStarted = ini_read_real("citybosses","tierThreeHasStarted",false)
global.lasVegasCityBossTierThreeInBattle = ini_read_real("citybosses","lasVegasCityBossTierThreeInBattle",false)
global.lasVegasCityBossTierThreeIsDefeated = ini_read_real("citybosses","lasVegasCityBossTierThreeIsDefeated",false)

ini_close();

show_debug_message("READ: City Bosses.")

alarm[0] = room_speed * 10
</string>
