        }

        //Checks Player Level - Tier 1 and Defeated Part
        if global.chicagoCityBossTierOneIsDefeated == false &amp;&amp; global.chicagoCityBossTierOneInBattle == false
        {
            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_orange)
            draw_text(47, 300, "Level 40 City Boss")

