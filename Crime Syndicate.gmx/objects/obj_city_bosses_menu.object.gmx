            draw_text(44, 828, "Completion Bonus: " + string(scr_number_sep(global.currentLasVegasCityBossTierThreeXP, ",", 3)) + "XP | $" + string(scr_number_sep(global.currentLasVegasCityBossTierThreeCash, ",", 3)))

            draw_set_font(ft_city_bosses_heading)
            draw_set_color(c_white)

            draw_text_ext(40, 670, "Tier 3 City Boss - Tony Cornero 'The Hat' (Veteran)", 25, 800)
        }

        else if global.lasVegasCityBossTierThreeIsDefeated == true &amp;&amp; global.lasVegasCityBossTierThreeInBattle == false
        {
