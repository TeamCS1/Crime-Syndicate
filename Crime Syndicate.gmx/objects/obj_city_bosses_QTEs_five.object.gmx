<!--This Document is generated by GameMaker, if you edit it by hand then you do so at your own risk!-->
<object>
  <spriteName>spr_city_bosses_QTEs_five</spriteName>
  <solid>0</solid>
  <visible>-1</visible>
  <depth>-3</depth>
  <persistent>0</persistent>
  <parentName>&lt;undefined&gt;</parentName>
  <maskName>&lt;undefined&gt;</maskName>
  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>image_speed = 0;

sectionOne = false;
sectionTwo = false;
sectionThree = false;
sectionFour = false;
sectionFive = false;

startPosX = 250;
count = 0;

randomize();
QTE1 = choose("A","W","S","D")

randomize();
QTE2 = choose("A","W","S","D")

randomize();
QTE3 = choose("A","W","S","D")

randomize();
QTE4 = choose("A","W","S","D")

randomize();
QTE5 = choose("A","W","S","D")
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>startPosX += 1.00

if keyboard_check(ord(string_upper(QTE1))) &amp;&amp; sectionOne == true 
{
    image_index = 1
    count += 5
}

if keyboard_check(ord(string_upper(QTE2))) == true &amp;&amp; sectionTwo == true 
{
    image_index = 2
    count += 5
}

if keyboard_check(ord(string_upper(QTE3))) &amp;&amp; sectionOne == true &amp;&amp; sectionTwo == true &amp;&amp; sectionThree == true 
{
    image_index = 3
    count += 5
}

if keyboard_check(ord(string_upper(QTE4))) &amp;&amp; sectionOne == true &amp;&amp; sectionTwo == true &amp;&amp; sectionThree == true &amp;&amp; sectionFour == true 
{
    image_index = 4
    count += 5
}

if keyboard_check(ord(string_upper(QTE5))) &amp;&amp; sectionOne == true &amp;&amp; sectionTwo == true &amp;&amp; sectionThree == true &amp;&amp; sectionFour == true &amp;&amp; sectionFive == true 
{
    image_index = 5
    count += 5
}

if startPosX &gt;= 445 &amp;&amp; startPosX &lt;= 543
{
    sectionOne = true
}

if startPosX &gt;= 553 &amp;&amp; startPosX &lt;= 657
{
    sectionTwo = true
}

if startPosX &gt;= 660 &amp;&amp; startPosX &lt;= 763
{
    sectionThree = true
}

if startPosX &gt;= 765 &amp;&amp; startPosX &lt;= 870
{
    sectionFour = true
}

if startPosX &gt;= 872 &amp;&amp; startPosX &lt;= 968
{
    sectionFive = true
}

//If the key is pressed at the wrong time
if keyboard_check(ord(QTE1)) &amp;&amp; sectionOne == false &amp;&amp; image_index = 1||
    keyboard_check(ord(QTE2)) &amp;&amp; sectionTwo == false &amp;&amp; image_index = 2 ||
    keyboard_check(ord(QTE3)) &amp;&amp; sectionThree == false &amp;&amp; image_index = 3 ||
    keyboard_check(ord(QTE4)) &amp;&amp; sectionFour == false &amp;&amp; image_index = 4 ||
    keyboard_check(ord(QTE5)) &amp;&amp; sectionFive == false &amp;&amp; image_index = 5
{
    global.cityBossesMult = 1
    instance_destroy();
}

if startPosX &gt;= 1024
{
    global.cityBossesMult = 1
    instance_destroy();
}

if global.cityBossesDifficulty == "INTERMEDIATE"
{
    //If QTE is successful
    if count &gt;= 2500 &amp;&amp; startPosX &gt;= 1024
    {
        //Give Zone Score Intermediate Trophy!
        if global.earnedZoneScoreIntermediate == false
        {
            global.trophyName = "Zone Score Intermediate";
            global.trophyGradeText = "Bronze";
            global.earnedZoneScoreIntermediate = true
            global.trophyGrade = 1;
            global.trophiesEarned += 1;

            ini_open("profile19.ini")
            ini_write_real("Profile", "Icon", 1)
            ini_close()

            ini_open("savedata.ini")
            ini_write_real("Trophies", "earnedZoneScoreIntermediate", global.earnedZoneScoreIntermediate);
            ini_write_real("Trophies", "trophiesEarned", global.trophiesEarned);
            ini_close();

            show_debug_message("Zone Score Intermediate | Trophy Given")

            if !instance_exists(obj_draw_trophy_notification)
            {
                    instance_create(29, 84, obj_draw_trophy_notification)
            }
        }
    
        if instance_exists(obj_city_bosses_special_moves_signature_move_ButtonHandler)
        {
            obj_city_bosses_special_moves_signature_move_ButtonHandler.doAttackSignatureMove = true;
            
            //Give Signature Specialist Trophy 
            if global.earnedSignatureSpecialist == false
            {
                global.trophyName = "Signature Specialist";
                global.trophyGradeText = "Silver";
                global.earnedSignatureSpecialist = true
                global.trophyGrade = 2;
                global.trophiesEarned += 1;

                ini_open("profile21.ini")
                ini_write_real("Profile", "Icon", 2)
                ini_close()

                ini_open("savedata.ini")
                ini_write_real("Trophies", "earnedSignatureSpecialist", global.earnedSignatureSpecialist);
                ini_write_real("Trophies", "trophiesEarned", global.trophiesEarned);
                ini_close();

                show_debug_message("Signature Specialist | Trophy Given")

                if !instance_exists(obj_draw_trophy_notification)
                {
                    instance_create(29, 84, obj_draw_trophy_notification)
                }
            }
            
            global.qtePerformed += 1;
            show_debug_message("OUTPUT: QTE Success! (doAttackSignatureMove)") 
        }
    
        else if instance_exists(obj_city_bosses_special_moves_final_blow_ButtonHandler)
        {
            obj_city_bosses_special_moves_final_blow_ButtonHandler.doAttackFinalBlowMove = true;
            
            //Give Bringer of Death Trophy 
            if global.earnedBringerOfDeath == false
            {
                global.trophyName = "Bringer of Death";
                global.trophyGradeText = "Silver";
                global.earnedBringerOfDeath = true
                global.trophyGrade = 2;
                global.trophiesEarned += 1;

                ini_open("profile22.ini")
                ini_write_real("Profile", "Icon", 2)
                ini_close()

                ini_open("savedata.ini")
                ini_write_real("Trophies", "earnedBringerOfDeath", global.earnedBringerOfDeath);
                ini_write_real("Trophies", "trophiesEarned", global.trophiesEarned);
                ini_close();

                show_debug_message("Bringer Of Death | Trophy Given")

                if !instance_exists(obj_draw_trophy_notification)
                {
                    instance_create(29, 84, obj_draw_trophy_notification)
                }
            }
            
            global.qtePerformed += 1;
            show_debug_message("OUTPUT: QTE Success! (doAttackFinalBlowMove)") 
        }

        global.cityBossesMult = 1
    
        //create info GUI (move these two lines to the right place!
        show_debug_message("Create Info GUI") 
    }
}


</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_self();

draw_set_font(ft_city_bosses_heading)
draw_set_color(c_blue)

draw_text(x + 50,y + 15,string(QTE1))
draw_text(x + 150,y + 15,string(QTE2))
draw_text(x + 250,y + 15,string(QTE3))
draw_text(x + 350,y + 15,string(QTE4))
draw_text(x + 450,y + 15,string(QTE5))

draw_set_color(c_purple)
draw_text(startPosX,y + 55,string("|"))
draw_text(35,y + 65,string(startPosX))

draw_set_font(ft_city_bosses_heading)
draw_text(350,603,"Zones Score: " + string(count) + " / 2500")
</string>
          </argument>
        </arguments>
      </action>
    </event>
  </events>
