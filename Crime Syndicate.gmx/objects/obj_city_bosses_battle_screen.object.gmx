        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Battle Screen Handler Chicago

if global.currentCity == "CHICAGO"
{
    //If AI Bar goes below 0 
    if global.currentChicagoCityBossBarTierOneCount &lt; 1 || 
       global.currentChicagoCityBossBarTierTwoCount &lt; 1 ||
       global.currentChicagoCityBossBarTierThreeCount &lt; 1
    {
        //Keeps AI Health at 1 not 0.
        if global.currentChicagoCityBossBarTierOneCount &lt; 1
        {
            global.currentChicagoCityBossBarTierOneCount = 1
        }
        
