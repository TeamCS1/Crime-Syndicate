      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Universal City Boss Multiplier. !Variable name needs to be changed
if global.currentNewYorkCityBossBarMultiplierTierOne &gt;= 100
{
    global.currentNewYorkCityBossBarMultiplierTierOne = 1;
    global.cityBossesMult += 1;
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Trophies | City Bosses

if finisherMove == true
{
    floor(trophyCalculation = 30 * global.healthCountMax / 100)
    
    if trophyCalculation &gt;= global.healthCount
    {
        global.trophyName = "On the Verge of Death";
        global.trophyGradeText = "Bronze";
        global.earnedVergeOfDeath = true
        global.trophyGrade = 1;
        global.trophiesEarned += 1;
    
        ini_open("profile16.ini")
        ini_write_real("Profile","Icon",1)
        ini_close()
    
        ini_open("savedata.ini")
        ini_write_real("Trophies", "earnedVergeOfDeath", global.earnedVergeOfDeath);
        ini_write_real("Trophies", "trophiesEarned", global.trophiesEarned);
        ini_close();
    
        show_debug_message("On the Verge of Death | Trophy Given")
    
        if !instance_exists(obj_draw_trophy_notification)
        {
            instance_create(29,84,obj_draw_trophy_notification)
        }
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>422</id>
        <kind>1</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>0</useapplyto>
        <exetype>0</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///City Bosses Battle Draw Event
draw_self();

//Only draws when not in upgrade stats menu
if !instance_exists(obj_upgradeStatsMenuGUI)
{
    draw_set_color(c_white)
    draw_text(783, 680, "QTE's Performed: " + string(global.qtePerformed))
    
    if global.currentCity == "NEW_YORK"
    {
        //Tier 1
        if global.newYorkCityBossTierOneInBattle == true
        {
            draw_set_font(ft_city_bosses_heading)
            draw_set_color(c_white)
            draw_text(50, 80, string(global.cityBossNameTierOne))

            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_orange)
            draw_text(820, 80, "Level 10 City Boss")

            //Draw Tier 1 City Boss Healthbar
            global.currentNewYorkCityBossBarTierOne = (global.currentNewYorkCityBossBarTierOneCount / global.currentNewYorkCityBossBarTierOneMaximum) * 100;

            draw_healthbar(x1, y1, x2, y2, global.currentNewYorkCityBossBarTierOne, global.backColour, c_red, c_purple, 0, true, true)

            draw_healthbar(x1, 230, x2 - 400, 230 + 15, global.currentNewYorkCityBossBarMultiplierTierOne, c_gray, c_red, c_red, 0, true, true)

            draw_set_font(ft_city_bosses_mult);
            draw_set_color(c_white);
            draw_text(424, 215, "BANK: x" + string(global.cityBossesMult));

            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_white)

            draw_text(50, 126, "City Boss Health: " + string(scr_number_sep(global.currentNewYorkCityBossBarTierOneCount, ",", 3)) + " / " + string(scr_number_sep(global.currentNewYorkCityBossBarTierOneMaximum, ",", 3)))
            draw_text(44, 300, "Completion Bonus: " + string(scr_number_sep(global.currentNewYorkCityBossTierOneXP, ",", 3)) + "XP | $" + string(scr_number_sep(global.currentNewYorkCityBossTierOneCash, ",", 3)))

            //New York City Boss ATK &amp; DEF
            draw_text(820, 125, +string(scr_number_sep(25, ",", 3)) + "ATK")
            draw_text(930, 125, +string(scr_number_sep(25, ",", 3)) + "DEF")

            //---
        }

        //Tier 2
        if global.newYorkCityBossTierTwoInBattle == true
        {
            draw_set_font(ft_city_bosses_heading)
            draw_set_color(c_white)
            draw_text(50, 80, string(global.cityBossNameTierTwo))

            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_orange)
            draw_text(820, 300, "Level 20 City Boss")

            //Draw Tier 1 City Boss Healthbar
            global.currentNewYorkCityBossBarTierTwo = (global.currentNewYorkCityBossBarTierTwoCount / global.currentNewYorkCityBossBarTierTwoMaximum) * 100;

            draw_healthbar(x1, y1, x2, y2, global.currentNewYorkCityBossBarTierTwo, global.backColour, c_red, c_purple, 0, true, true)

            draw_healthbar(x1, 230, x2 - 400, 230 + 15, global.currentNewYorkCityBossBarMultiplierTierOne, c_gray, c_red, c_red, 0, true, true)

            draw_set_font(ft_city_bosses_mult);
            draw_set_color(c_white);
            draw_text(424, 215, "BANK: x" + string(global.cityBossesMult));

            draw_set_font(ft_city_bosses_body)
            draw_set_color(c_white)

            draw_text(50, 126, "City Boss Health: " + string(scr_number_sep(global.currentNewYorkCityBossBarTierTwoCount, ",", 3)) + " / " + string(scr_number_sep(global.currentNewYorkCityBossBarTierTwoMaximum, ",", 3)))
            draw_text(44, 300, "Completion Bonus: " + string(scr_number_sep(global.currentNewYorkCityBossTierTwoXP, ",", 3)) + "XP | $" + string(scr_number_sep(global.currentNewYorkCityBossTierTwoCash, ",", 3)))

            //New York City Boss ATK &amp; DEF
            draw_text(820, 125, +string(scr_number_sep(45, ",", 3)) + "ATK")
            draw_text(930, 125, +string(scr_number_sep(90, ",", 3)) + "DEF")

            //---
        }

        //Tier 3
        if global.newYorkCityBossTierThreeInBattle == true
        {
            draw_set_font(ft_city_bosses_heading)
            draw_set_color(c_white)
