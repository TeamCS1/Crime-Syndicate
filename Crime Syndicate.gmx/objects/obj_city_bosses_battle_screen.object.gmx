    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Battle Screen Handler New York

if global.currentCity == "NEW_YORK"
{
    //If AI Bar goes below 0 
    if global.currentNewYorkCityBossBarTierOneCount &lt; 1 || 
       global.currentNewYorkCityBossBarTierTwoCount &lt; 1 ||
       global.currentNewYorkCityBossBarTierThreeCount &lt; 1
    {
        //Keeps AI Health at 1 not 0.
        if global.currentNewYorkCityBossBarTierOneCount &lt; 1
        {
            global.currentNewYorkCityBossBarTierOneCount = 1
        }
        
        if global.currentNewYorkCityBossBarTierTwoCount &lt; 1
        {
            global.currentNewYorkCityBossBarTierTwoCount = 1
        }
        
        if global.currentNewYorkCityBossBarTierThreeCount &lt; 1
        {
            global.currentNewYorkCityBossBarTierThreeCount = 1
        }
    
        //Destroys the Buttons
        if instance_exists(obj_city_bosses_weak_attack_button)
        {
            with obj_city_bosses_weak_attack_button
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_city_bosses_power_attack_button)
        {

            with obj_city_bosses_power_attack_button
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_city_bosses_special_moves_signature_move_ButtonHandler)
        {
            with obj_city_bosses_special_moves_signature_move_ButtonHandler
            {
                instance_destroy();
            }
        }

        if instance_exists(obj_city_bosses_special_moves_final_blow_filter)
        {
            with obj_city_bosses_special_moves_final_blow_filter
            {
                instance_destroy();
            }
        }

        //Creates the greyed out variants.
        if !instance_exists(obj_city_bosses_weak_attack_button_filter)
        {
            instance_create(x, y, obj_city_bosses_weak_attack_button_filter)
        }

        if !instance_exists(obj_city_bosses_power_attack_button_filter)
        {
            instance_create(x, y, obj_city_bosses_power_attack_button_filter)
        }

        if !instance_exists(obj_city_bosses_special_moves_signature_move_filter)
        {
            instance_create(x, y, obj_city_bosses_special_moves_signature_move_filter)
        }

        if !instance_exists(obj_city_bosses_special_moves_final_blow_ButtonHandler)
        {
            instance_create(x, y, obj_city_bosses_special_moves_final_blow_ButtonHandler)
        }

        if obj_city_bosses_special_moves_final_blow_ButtonHandler.cityBossIsDead == true
        {
            instance_create(416, 224, obj_city_bosses_killed_GUI);
        }
    }

    //Shows Signature Button Handler, removes filter - Tier 1
    if global.cityBossesMult &gt; 1 &amp;&amp; global.currentNewYorkCityBossBarTierOneCount &gt; 1 
    {
        if instance_exists(obj_city_bosses_special_moves_signature_move_filter)
        {
            with obj_city_bosses_special_moves_signature_move_filter
            {
                instance_destroy();
            }
        }

        if !instance_exists(obj_city_bosses_special_moves_signature_move_ButtonHandler)
        {
            instance_create(554, 425, obj_city_bosses_special_moves_signature_move_ButtonHandler)
        }
    }
    
    //---
    
    //Shows Signature Button Handler, removes filter - Tier 2
    if global.cityBossesMult &gt; 1 &amp;&amp; global.currentNewYorkCityBossBarTierTwoCount &gt; 1 
    {
        if instance_exists(obj_city_bosses_special_moves_signature_move_filter)
        {
            with obj_city_bosses_special_moves_signature_move_filter
            {
                instance_destroy();
            }
        }

        if !instance_exists(obj_city_bosses_special_moves_signature_move_ButtonHandler)
        {
            instance_create(554, 425, obj_city_bosses_special_moves_signature_move_ButtonHandler)
        }
    }
    
    //---
    
    //Shows Signature Button Handler, removes filter - Tier 3
    if global.cityBossesMult &gt; 1 &amp;&amp; global.currentNewYorkCityBossBarTierThreeCount &gt; 1 
    {
        if instance_exists(obj_city_bosses_special_moves_signature_move_filter)
        {
            with obj_city_bosses_special_moves_signature_move_filter
            {
                instance_destroy();
            }
        }

        if !instance_exists(obj_city_bosses_special_moves_signature_move_ButtonHandler)
        {
            instance_create(554, 425, obj_city_bosses_special_moves_signature_move_ButtonHandler)
        }
    }
    
    //---

    //Else add the filter back in!
    else if global.cityBossesMult &lt;= 1
    {
        if !instance_exists(obj_city_bosses_special_moves_signature_move_filter)
        {
            instance_create(554, 425, obj_city_bosses_special_moves_signature_move_filter)
        }
    }
}

//If multiplier is not used and the bar is at 1
if global.cityBossesMult &gt; 1 &amp;&amp; global.currentNewYorkCityBossBarTierOneCount &lt;= 1
{
    if instance_exists(obj_city_bosses_special_moves_signature_move_ButtonHandler)
    {
        with obj_city_bosses_special_moves_signature_move_ButtonHandler
        {
            instance_destroy();
        }
        
        instance_create(554, 425, obj_city_bosses_special_moves_signature_move_filter)
    }
}
</string>
