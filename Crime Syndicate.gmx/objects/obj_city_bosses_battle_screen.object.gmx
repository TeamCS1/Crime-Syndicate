        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Destroy Buttons
if global.currentCity == "NEW_YORK"
{
    with obj_JobListButtons1NewYork
    {
        instance_destroy()
        show_debug_message("DESTROY: obj_JobListButtons1NewYork")
    }

    with obj_JobListButtons2NewYork
    {
        instance_destroy()
        show_debug_message("DESTROY: obj_JobListButtons2NewYork")
    }
}

else if global.currentCity == "CHICAGO"
{
    with obj_JobListButtons1Chicago
    {
        instance_destroy()
        show_debug_message("DESTROY: obj_JobListButtons1Chicago")
    }

    with obj_JobListButtons2Chicago
    {
        instance_destroy()
        show_debug_message("DESTROY: obj_JobListButtons2Chicago")
    }
}

else if global.currentCity == "LONDON"
{
    with obj_JobListButtons1London
    {
        instance_destroy()
        show_debug_message("DESTROY: obj_JobListButtons1London")
    }

    with obj_JobListButtons2London
    {
        instance_destroy()
        show_debug_message("DESTROY: obj_JobListButtons2London")
    }
}

else if global.currentCity == "LAS_VEGAS"
{
    with obj_JobListButtons1LasVegas
    {
        instance_destroy()
        show_debug_message("DESTROY: obj_JobListButtons1LasVegas")
    }

    with obj_JobListButtons2LasVegas
    {
        instance_destroy()
        show_debug_message("DESTROY: obj_JobListButtons2LasVegas")
    }
}
