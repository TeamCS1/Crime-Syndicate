            <kind>1</kind>
            <string>///Read Battle Info New York

if global.currentCity == "NEW_YORK"
{
    if global.newYorkCityBossTierOneInBattle == true
    {
        ini_open("savedata.ini");

        global.currentNewYorkCityBossBarTierOne = ini_read_real("citybosses", "currentNewYorkCityBossBarTierOne", 1);
        global.currentNewYorkCityBossBarTierOneMaximum = ini_read_real("citybosses", "currentNewYorkCityBossBarTierOneMaximum", 1);
        global.currentNewYorkCityBossBarTierOneCount = ini_read_real("citybosses", "currentNewYorkCityBossBarTierOneCount", 1);
        global.currentNewYorkCityBossTierOneXP = ini_read_real("citybosses", "currentNewYorkCityBossTierOneXP", 1);
        global.currentNewYorkCityBossTierOneCash = ini_read_real("citybosses", "currentNewYorkCityBossTierOneCash", 1);
        
        ini_close();
        show_message("READ COMPLETE")
    }
    
    if global.newYorkCityBossTierTwoInBattle == true
    {
        ini_open("savedata.ini");

        global.currentNewYorkCityBossBarTierTwo = ini_read_real("citybosses", "currentNewYorkCityBossBarTierTwo", 1);
        global.currentNewYorkCityBossBarTierTwoMaximum = ini_read_real("citybosses", "currentNewYorkCityBossBarTierTwoMaximum", 1);
        global.currentNewYorkCityBossBarTierTwoCount = ini_read_real("citybosses", "currentNewYorkCityBossBarTierTwoCount", 1);
        global.currentNewYorkCityBossTierTwoXP = ini_read_real("citybosses", "currentNewYorkCityBossTierTwoXP", 1);
        global.currentNewYorkCityBossTierTwoCash = ini_read_real("citybosses", "currentNewYorkCityBossTierTwoCash", 1);

        ini_close();
        show_message("READ COMPLETE")
    }
    
    //---
    
    if global.newYorkCityBossTierThreeInBattle == true
    {
        ini_open("savedata.ini");

        global.currentNewYorkCityBossBarTierThree = ini_read_real("citybosses", "currentNewYorkCityBossBarTierThree", 1);
        global.currentNewYorkCityBossBarTierThreeMaximum = ini_read_real("citybosses", "currentNewYorkCityBossBarTierThreeMaximum", 1);
        global.currentNewYorkCityBossBarTierThreeCount = ini_read_real("citybosses", "currentNewYorkCityBossBarTierThreeCount", 1);
        global.currentNewYorkCityBossTierThreeXP = ini_read_real("citybosses", "currentNewYorkCityBossTierThreeXP", 1);
        global.currentNewYorkCityBossTierThreeCash = ini_read_real("citybosses", "currentNewYorkCityBossTierThreeCash", 1);
        ini_close();
        show_message("READ COMPLETE")
        
    }
}

