        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Create Buttons

if !instance_exists(obj_city_bosses_special_moves_signature_move_filter)
{
    instance_create(x,y,obj_city_bosses_special_moves_signature_move_filter);
    show_debug_message("CREATE: obj_city_bosses_special_moves_signature_move_filter");
}

if !instance_exists(obj_city_bosses_special_moves_final_blow_filter)
{
    instance_create(x,y,obj_city_bosses_special_moves_final_blow_filter);
    show_debug_message("CREATE: obj_city_bosses_special_moves_final_blow_filter");
}

if !instance_exists(obj_city_bosses_weak_attack_button)
{
    instance_create(x,y,obj_city_bosses_weak_attack_button)
    show_debug_message("CREATE: obj_city_bosses_weak_attack_button");
}

if !instance_exists(obj_city_bosses_power_attack_button)
{
    instance_create(x,y,obj_city_bosses_power_attack_button)
    show_debug_message("CREATE: obj_city_bosses_power_attack_button");
}

if !instance_exists(obj_city_bosses_flee_ButtonHandler)
{
    instance_create(x,y,obj_city_bosses_flee_ButtonHandler)
    show_debug_message("CREATE: obj_city_bosses_flee_ButtonHandler");
}

if !instance_exists(obj_explanationOfCityBossesBattleSystem)
{
    instance_create(x,y,obj_explanationOfCityBossesBattleSystem)
    show_debug_message("CREATE: obj_explanationOfCityBossesBattleSystem");
}

