    <event eventtype="6" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Player Attack Damage Calculation

//local event variables | Only need to be declared here, nowhere else.

showAttack = true
playerHasAttacked = true

global.showSectionOne = false;
global.showSectionTwo = false;
global.showSectionThree = true;

global.damageOutputToAISectionThree = 0     //resets Player damage output to 0, before performing re-calculation.

if global.hitmenDiffultyChanceTextSectionThree == "Hard"
{
    global.damageOutputToAISectionThree += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtectionSectionThree); 
    global.damageOutputToAISectionThree *= 0.5
}

else if global.hitmenDiffultyChanceTextSectionThree == "Extra Hard"
{
    global.damageOutputToAISectionThree += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtectionSectionThree); 
    global.damageOutputToAISectionThree *= 0.3
}

else if global.hitmenDiffultyChanceTextSectionThree == "Legendary"
{
    global.damageOutputToAISectionThree += irandom_range(global.currentPlayerLevel, global.attackDamage - global.AIDefenceProtectionSectionThree); 
    global.damageOutputToAISectionThree *= 0.1
}

if global.damageOutputToAISectionThree &lt;= 0
{
    global.damageOutputToAISectionThree = 1
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Enemy Attack Damage Calculation

global.damageOutputToPlayerSectionThree = 0;        //resets AI damage output to 0, before performing re-calculation.

if global.hitmenDiffultyChanceTextSectionThree == "Hard"
{
    global.damageOutputToPlayerSectionThree += irandom_range(global.currentPlayerLevel, global.AIAttackDamageSectionThree - global.defenceProtection); 
    global.damageOutputToPlayerSectionThree *= 1.25
}

else if global.hitmenDiffultyChanceTextSectionThree == "Extra Hard"
{
    global.damageOutputToPlayerSectionThree += irandom_range(global.currentPlayerLevel, global.AIAttackDamageSectionThree - global.defenceProtection); 
    global.damageOutputToPlayerSectionThree *= 1.50
}

else if global.hitmenDiffultyChanceTextSectionThree == "Legendary"
{
    global.damageOutputToPlayerSectionThree += irandom_range(global.currentPlayerLevel, global.AIAttackDamageSectionThree - global.defenceProtection); 
    global.damageOutputToPlayerSectionThree *= 2.00
}

if global.damageOutputToPlayerSectionThree &lt;= 0
{
    global.damageOutputToPlayerSectionThree = 1
}
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Update Attack History To Player
if !instance_exists(obj_createPersonalMedic)
{
    if playerHasAttacked == true &amp;&amp; global.healthCount &gt; 25
    {
        global.line1Damage = global.damageOutputToAISectionThree;
        global.currentAICountSectionThree -= global.damageOutputToAISectionThree;
        global.healthCount -= global.damageOutputToPlayerSectionThree;
        
        backColour = c_orange;
        alarm[0] = room_speed * 0.5;
    }
    
    //UPDATE ATTACK HISTORY AI
    
    if playerHasAttacked == true
    {
        global.line2Damage = global.damageOutputToPlayerSectionThree;
    }
}

//Reset notifs state
obj_global.showOnce = true;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>422</id>
