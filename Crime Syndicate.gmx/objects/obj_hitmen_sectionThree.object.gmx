      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Draw Section 3 Only
draw_set_font(ft_hitmen);
draw_set_colour(isLegendaryColour);
draw_text_ext(x + 105,y + 55,string(global.sectionThreeName) + string(global.sectionThreeTitle),18,300);
draw_set_colour(c_black);
draw_text_ext(x + 27,y + 216,string(global.sectionThreeDesc),18,680);    //armaments
draw_text(x+205,y + 119, "$" + string(global.hitmenBountySectionThree) + " +" + string(global.hitmenXPChanceSectionThree) + "XP");
draw_set_colour(isLegendaryColour);
draw_text(x+215,y + 172, string(global.hitmenDiffultyChanceTextSectionThree));
draw_set_colour(c_black);

//AI
draw_text(x + 565,y + 62, string(global.AIAttackDamageSectionThree));
draw_text(x + 590,y + 92, string(global.AIDefenceProtectionSectionThree));

//PLAYER
draw_text(x + 592,y + 139, string(global.attackDamage));
draw_text(x + 615,y + 169, string(global.defenceProtection));
</string>
          </argument>
        </arguments>
      </action>
