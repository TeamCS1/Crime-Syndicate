  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Init Globals
global.line1Damage = "";
global.line2Damage = "";
global.currentAIBarSectionThree = global.healthCountMax * 1.7;  //1.3 easy, 1.5 normal, 1.7 hard.
global.currentAIMaximumSectionThree = global.healthCountMax;
global.currentAICountSectionThree = global.currentAIMaximumSectionThree;

///Init locals
backColour = c_gray;
isLegendaryColour = c_black;
isDead = false;
isRoomRestarted = true;
barHeight = 273;

//returns the name, titles and descriptions of the Hitmen from the script
global.sectionThreeName = scr_HitmenNamesReturn(true);
global.sectionThreeTitle = scr_HitmenTitlesReturn();
global.sectionThreeDesc = scr_HitmenDescReturn();
</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Calculate Section 3
randomize();

//Init variables
global.hitmenBountySectionThree = 0;
global.hitmenDiffultyChanceSectionThree = 0;
global.hitmenDiffultyChanceTextSectionThree = "Impossible";
global.hitmenXPChanceSectionThree = 0;

//Calculations

//difficulty select range. For section three this must be Hard, Extra Hard and Legendary ONLY!
global.hitmenDiffultyChanceSectionThree += irandom_range(0, 1);

if global.hitmenDiffultyChanceSectionThree == 0
{
    global.hitmenDiffultyChanceTextSectionThree = "Hard"
    
}

else if global.hitmenDiffultyChanceSectionThree == 1
{
    isLegendaryColour = c_blue;
    global.hitmenDiffultyChanceTextSectionThree = "Extra Hard"    
}

//checks if a name contains Legendary, and if it does, appends
if string_pos("(Legendary)", global.sectionThreeName) != 0
{
    isLegendaryColour = c_orange;
    global.hitmenDiffultyChanceTextSectionThree = "Legendary"
}

//---

//Based on the difficulties given to us, we need to be generous with xp
//Since there are a chance of legendaries, we have to calculate it.

if global.hitmenXPChanceSectionThree == 0 //Hard
{
    global.hitmenXPChanceSectionThree += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 3.0));   
}

else if global.hitmenXPChanceSectionThree == 1 //Extra Hard
{
    global.hitmenXPChanceSectionThree += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 5.0));   
}

//checks if a name contains Legendary, and if it does, appends
if string_pos("(Legendary)", global.sectionThreeName) != 0
{
    global.hitmenXPChanceSectionThree = 0;
    global.hitmenXPChanceSectionThree += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 15.0));
}

//---

//This section, scales the AI to the player's lower and upperbound.
global.currentPlayerLevelUpperBound += irandom_range(global.currentPlayerLevel, global.currentPlayerLevel + 10);
global.hitmenBountySectionThree += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevelUpperBound * 1.5));
global.hitmenBountySectionThree *= global.currentPlayerLevel * 5.0

//checks if a name contains Legendary, and if it does, appends
if string_pos("(Legendary)", global.sectionThreeName) != 0
{
    global.hitmenBountySectionThree += irandom_range(global.currentPlayerLevel, (global.currentPlayerLevel * 15.0));
}

//CALCULATE AI'S ATK AND DEFENCE DO NOT MOVE

showAttack = false;
global.damageOutputToAISectionThree = 0
global.damageOutputToPlayerSectionThree = 0;

global.AIDefenceProtectionSectionThree = -1;
global.AIAttackDamageSectionThree = -1;     //declares attack damage

//difficulty settings

if global.hitmenDiffultyChanceSectionThree == 0     //is hard
{
    global.AIDefenceProtectionSectionThree += irandom_range(global.defenceProtection - 4, global.defenceProtection + 5);
    global.AIAttackDamageSectionThree += irandom_range(global.attackDamage - 3, global.attackDamage + 6);   
}

else if global.hitmenDiffultyChanceSectionThree == 1     //is extra Hard
{
    global.AIDefenceProtectionSectionThree += irandom_range(global.defenceProtection, global.defenceProtection + 10);
    global.AIAttackDamageSectionThree += irandom_range(global.attackDamage, global.attackDamage + 10);   
}

//checks if a name contains Legendary, and if it does, appends
if string_pos("(Legendary)", global.sectionThreeName) != 0
{
    global.AIDefenceProtectionSectionThree = 0;
    global.AIAttackDamageSectionThree = 0;
    
    global.AIDefenceProtectionSectionThree += irandom_range(global.defenceProtection, global.defenceProtection + 15);
    global.AIAttackDamageSectionThree += irandom_range(global.attackDamage, global.attackDamage + 15);
}

//Prevents underflows
if global.AIDefenceProtectionSectionThree &lt;= 0
{
    global.AIDefenceProtectionSectionThree = 1;
}

if global.AIAttackDamageSectionThree &lt;= 0
{
    global.AIAttackDamageSectionThree = 1;
}

if global.hitmenXPChanceSectionThree &lt;= 0
{
    global.hitmenXPChanceSectionThree = 1;
}

if global.hitmenBountySectionThree &lt;= 0
{
    global.hitmenBountySectionThree = 1;
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
