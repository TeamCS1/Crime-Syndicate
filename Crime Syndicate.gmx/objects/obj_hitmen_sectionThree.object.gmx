      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Attack History Draw Events

if showAttack == true &amp;&amp; global.showSectionThree == true 
{
    global.line2Damage = round(global.damageOutputToPlayerSectionThree);
    
    draw_set_font(ft_attack_history);
    draw_set_color(c_white);
    draw_text_ext(1515,460,"Player has attacked " + string(global.sectionThreeName)+ string(global.sectionThreeTitle) + " with " + string(global.line1Damage) + " damage.##"+
    string(global.sectionThreeName)+ string(global.sectionThreeTitle) + " has attacked Player with " + string(global.line2Damage) + " damage." ,20,300)
   

}


</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Draw AI Healthbar

global.currentAIBarSectionThree = (global.currentAICountSectionThree / global.currentAIMaximumSectionThree) * 100;

draw_healthbar(x + 200,y + barHeight, x+ 700,y + barHeight + 30,global.currentAIBarSectionThree,backColour,c_red,c_blue,0,true,true)
draw_set_colour(c_white);
draw_set_font(ft_properties);
draw_text(x+ 200,y + 275,"HP:" + string(global.currentAIBarSectionThree * 1000) + "/" +
string(global.currentAIMaximumSectionThree * 1000));

draw_set_colour(c_black);

//Checks whether AI is dead, if so, update isDead flag.
if global.currentAIBarSectionThree &lt;= 0 
{
    isDead = true;        
}
    
//Gives money and xp once the enemy is dead.
if global.currentAIBarSectionThree &lt;= 0 &amp;&amp; isDead == true &amp;&amp; playerHasAttacked == true &amp;&amp; !instance_exists(obj_hitman_killed_GUI)
{
    global.moneyCount += global.hitmenBountySectionThree
    global.currentXP += global.hitmenXPChanceSectionThree
    global.skillPointsRemaining += 1;       
            
    isDead = false      //exits the loop, to stop giving player money.
    showAttack = false      //hides the attack history panel.
            
    instance_create(416,224,obj_hitman_killed_GUI);
    global.hitmenKilled++;
}
</string>
          </argument>
        </arguments>
