else if(printOut) &amp;&amp; obj_black_market_shop_gui_upper_piece.currentPage == 16
{
    if y &gt;= scrollCutOff &amp;&amp; y &lt;=1040
    {
        draw_text_transformed_colour(x + 8,y + 12,name,1,1,0,c_red,c_blue,c_red,c_blue,1);
        draw_text(x+10,y +45,"Quantity: " + string(quantity));
        draw_sprite(portrait,0,x-85,y);
    }
}

else
{
    if y &gt;= scrollCutOff &amp;&amp; y &lt;=1040
    {
        draw_text_transformed_colour(x + 8,y + 12,name,1,1,0,c_red,c_blue,c_red,c_blue,1);
        draw_sprite(portrait,0,x-85,y);
    }    
}




