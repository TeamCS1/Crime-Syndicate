    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Button sizing
if position_meeting(mouse_x, mouse_y, self)
{
    if size &lt; 1.1
    {
        size += 0.02;
    }
}

else
{
    if size &gt; 1
    {
        size -= 0.02;
    }
}

image_xscale = size;
image_yscale = size;

if instance_exists(obj_black_market_slots)
{ 
    y = start_y - (((instance_number(obj_black_market_slots) - 10) * 80) * obj_scrollbar_black_market.scroll_perc)
}
//10 controls rows
//80 is the spacing between the rows



</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="6" enumb="7">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>itemSerialised = id; 

with itemSerialised
{
    show_debug_message("ITEM SERIALISED:");
    show_debug_message(string(itemSerialised.name));
}

//Create shared Inspector class

if !instance_exists(obj_sharedInspectorClass)
{
    instance_create(x,y,obj_sharedInspectorClass);
}

//Create Buy, Sell &amp; Scrap Buttons
if !instance_exists(obj_sharedInspectorClassBuy)
{
    instance_create(obj_sharedInspectorClass.x,obj_sharedInspectorClass.y,obj_sharedInspectorClassBuy);
}

//Transfer info to shared class
obj_sharedInspectorClass.name = itemSerialised.name;
obj_sharedInspectorClass.price = itemSerialised.price;
obj_sharedInspectorClass.attackDamage = itemSerialised.attackDamage;
obj_sharedInspectorClass.defenceProtection = itemSerialised.defenceProtection;
obj_sharedInspectorClass.elementaryEffect = itemSerialised.elementaryEffect;
obj_sharedInspectorClass.itemIndex = itemSerialised.itemIndex;
obj_sharedInspectorClass.portrait = itemSerialised.portrait;


</string>
          </argument>
        </arguments>
      </action>
    </event>
