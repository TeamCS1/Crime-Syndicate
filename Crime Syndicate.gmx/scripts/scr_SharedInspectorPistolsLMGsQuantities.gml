if obj_black_market_shop_gui_upper_piece.currentPage == 5   //Pistols & LMGs
{
    if itemIndex == 0   
    {
        quantity = global.pythonQuantity;
    }
    
    else if itemIndex == 1   
    {
        quantity = global.dragonPistolQuantity;
    }
    
    else if itemIndex == 2   
    {
        quantity = global.makarovPistolQuantity;
    }
    
    else if itemIndex == 3   
    {
        quantity = global.n9500PistolQuantity;
    }
    
    else if itemIndex == 4   
    {
        quantity = global.lmg2000Quantity;
    }
    
    else if itemIndex == 5   
    {
        quantity = global.hks2050Quantity;
    }
    
    else if itemIndex == 6   
    {
        quantity = global.m60Quantity;
    }   
}
