if obj_black_market_shop_gui_upper_piece.currentPage == 6   //SHOTGUNS
{
    if itemIndex == 0   
    {
        quantity = global.combat_shotgunQuantity;
    }
    
    else if itemIndex == 1   
    {
        quantity = global.sawed_off_shotgunQuantity;
    }
    
    else if itemIndex == 2   
    {
        quantity = global.assault_shotgunQuantity;
    }
    
    else if itemIndex == 3   
    {
        quantity = global.long_range_shotgunQuantity;
    }
    
    else if itemIndex == 4   
    {
        quantity = global.spez_12_shotgunQuantity;
    }
    
    else if itemIndex == 5   
    {
        quantity = global.standard_hunting_rifleQuantity;
    }
    
    else if itemIndex == 6   
    {
        quantity = global.powerful_hunting_rifleQuantity;
    }
}
