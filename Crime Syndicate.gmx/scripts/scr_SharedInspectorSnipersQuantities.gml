if obj_black_market_shop_gui_upper_piece.currentPage == 7  //SNIPERS
{
    if itemIndex == 0   
    {
        quantity = global.pipe_sniperQuantity;
    }
    
    else if itemIndex == 1   
    {
        quantity = global.bolt_action_sniperQuantity;
    }
    
    else if itemIndex == 2   
    {
        quantity = global.tactical_sniperQuantity;
    }
    
    else if itemIndex == 3   
    {
        quantity = global.marksman_sniperQuantity;
    }
    
    else if itemIndex == 4   
    {
        quantity = global.destroyer_aw308Quantity;
    }
}
