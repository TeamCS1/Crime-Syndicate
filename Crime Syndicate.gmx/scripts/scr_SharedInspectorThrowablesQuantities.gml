if obj_black_market_shop_gui_upper_piece.currentPage == 8  //THROWABLES
{
    if itemIndex == 0   
    {
        quantity = global.c4Quantity;
    }
    
    else if itemIndex == 1   
    {
        quantity = global.grenadeQuantity;
    }
    
    else if itemIndex == 2   
    {
        quantity = global.motolov_cocktailsQuantity;
    }
    
    else if itemIndex == 3   
    {
        quantity = global.landmineQuantity;
    }
    
    else if itemIndex == 4   
    {
        quantity = global.claymoreQuantity;
    }
    
    else if itemIndex == 5  
    {
        quantity = global.gas_bombQuantity;
    }

    else if itemIndex == 6   
    {
        quantity = global.shurikenQuantity;
    }
 
    else if itemIndex == 7   
    {
        quantity = global.throwing_knifeQuantity;
    }
}
